    item [3]:
        class = "IntervalTier" 
        name = "SPK-B-text" 
        xmin = 0 
        xmax = 93.02133333333333 
        intervals: size = 29 
        intervals [1]:
            xmin = 0 
            xmax = 1.6166808847233902 
            text = "" 
        intervals [2]:
            xmin = 1.6166808847233902 
            xmax = 10.339394692529373 
            text = "" 
        intervals [3]:
            xmin = 10.339394692529373 
            xmax = 12.087174506200277 
            text = "*у* *роз* Ну, шо уже сталось?" 
        intervals [4]:
            xmin = 12.087174506200277 
            xmax = 20.034814161184507 
            text = "" 
        intervals [5]:
            xmin = 20.034814161184507 
            xmax = 22.107072495346014 
            text = "*роз* Еммм, *роз* погано." 
        intervals [6]:
            xmin = 22.107072495346014 
            xmax = 32.94073880835708 
            text = "" 
        intervals [7]:
            xmin = 32.94073880835708 
            xmax = 38.99123425057215 
            text = "*роз* Ага. І коли по часу приблизно мій судочок до мене повернеться?" 
        intervals [8]:
            xmin = 38.99123425057215 
            xmax = 42.49467477539399 
            text = "" 
        intervals [9]:
            xmin = 42.49467477539399 
            xmax = 45.4796808354814 
            text = "Я, якщо чесно, теж на це дуже сподіваюсь." 
        intervals [10]:
            xmin = 45.4796808354814 
            xmax = 51.922305539417195 
            text = "" 
        intervals [11]:
            xmin = 51.922305539417195 
            xmax = 53.78235442996997 
            text = "Дякую, звісно." 
        intervals [12]:
            xmin = 53.78235442996997 
            xmax = 59.46861539023388 
            text = "Але було б добре, *роз* дуже добре, якби ти повернула мені мій судочок." 
        intervals [13]:
            xmin = 59.46861539023388 
            xmax = 62.55358079070443 
            text = "" 
        intervals [14]:
            xmin = 62.55358079070443 
            xmax = 67.10019410190642 
            text = "Ти вообще розумієш, це був мій улюблений судочек! Він був менший, ніж цей." 
        intervals [15]:
            xmin = 67.10019410190642 
            xmax = 67.38761928759293 
            text = "" 
        intervals [16]:
            xmin = 67.38761928759293 
            xmax = 70.26161153877604 
            text = "і його було зручно покласти з собою в сумку." 
        intervals [17]:
            xmin = 70.26161153877604 
            xmax = 70.27667380923684 
            text = "" 
        intervals [18]:
            xmin = 70.27667380923684 
            xmax = 71.09742246454351 
            text = "І цей такий" 
        intervals [19]:
            xmin = 71.09742246454351 
            xmax = 71.11276569629034 
            text = "" 
        intervals [20]:
            xmin = 71.11276569629034 
            xmax = 74.61686466018308 
            text = "А цей судочок він такий важкий дуже, а той був легший." 
        intervals [21]:
            xmin = 74.61686466018308 
            xmax = 78.13279030583388 
            text = "" 
        intervals [22]:
            xmin = 78.13279030583388 
            xmax = 80.35740553907702 
            text = "Ну я теж розумію, ти знаєш." 
        intervals [23]:
            xmin = 80.35740553907702 
            xmax = 80.56050204657055 
            text = "" 
        intervals [24]:
            xmin = 80.56050204657055 
            xmax = 83.50343785799645 
            text = "Я думаю, ікри найближчим часом не буде." 
        intervals [25]:
            xmin = 83.50343785799645 
            xmax = 86.46596779516192 
            text = "" 
        intervals [26]:
            xmin = 86.46596779516192 
            xmax = 88.20891964704657 
            text = "І цей судочок я теж собі забираю." 
        intervals [27]:
            xmin = 88.20891964704657 
            xmax = 90.58337597397717 
            text = "" 
        intervals [28]:
            xmin = 90.58337597397717 
            xmax = 92.50615619153245 
            text = "Ну добре, тоді я чекаю." 
        intervals [29]:
            xmin = 92.50615619153245 
            xmax = 93.02133333333333 
            text = "" 
