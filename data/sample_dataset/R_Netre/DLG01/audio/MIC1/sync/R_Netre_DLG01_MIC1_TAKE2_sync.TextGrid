item []: 
    item [1]:
        class = "IntervalTier" 
        name = "SPK-A-text" 
        xmin = 0 
        xmax = 93.02133333333333 
        intervals: size = 26 
        intervals [1]:
            xmin = 0 
            xmax = 1.6166808847233902 
            text = "" 
        intervals [2]:
            xmin = 1.6166808847233902 
            xmax = 5.534111469731455 
            text = "" 
        intervals [3]:
            xmin = 5.534111469731455 
            xmax = 7.922663921138971 
            text = "*у* *роз* Я, цейво, *роз* є новини." 
        intervals [4]:
            xmin = 7.922663921138971 
            xmax = 10.29273372392239 
            text = "*роз* Але ти не хвилюйся тільки! Це не критично." 
        intervals [5]:
            xmin = 10.29273372392239 
            xmax = 12.186587353899823 
            text = "" 
        intervals [6]:
            xmin = 12.186587353899823 
            xmax = 19.97622608892805 
            text = "*е* Твій судочок з-під баклажанової ікри загубився. *роз* Ну, не *роз* загубився, скоріше поїхав в подорож Києвом..." 
        intervals [7]:
            xmin = 19.97622608892805 
            xmax = 22.119946065582628 
            text = "" 
        intervals [8]:
            xmin = 22.119946065582628 
            xmax = 24.483492650457517 
            text = "*роз* Він випадково попав до моєї бабусі," 
        intervals [9]:
            xmin = 24.483492650457517 
            xmax = 24.498001859404752 
            text = "" 
        intervals [10]:
            xmin = 24.498001859404752 
            xmax = 29.27270712249945 
            text = "а інша бабуся була в гостях і забрала його собі, бо подумала, шо то її судочок." 
        intervals [11]:
            xmin = 29.27270712249945 
            xmax = 32.91635296505745 
            text = "Але я уже подзвонила, і сказала, щоб вона його повернула." 
        intervals [12]:
            xmin = 32.91635296505745 
            xmax = 38.970761089098005 
            text = "" 
        intervals [13]:
            xmin = 38.970761089098005 
            xmax = 42.48440617538489 
            text = "*роз* Ну, не *роз* знаю, сподіваюсь, що на цьому тижні." 
        intervals [14]:
            xmin = 42.48440617538489 
            xmax = 45.43578727793472 
            text = "" 
        intervals [15]:
            xmin = 45.43578727793472 
            xmax = 51.54505217137856 
            text = "Але я все одно тобі, в знак компенсації, купила судочок. Дивись, він навіть теж з оранжевою кришкою." 
        intervals [16]:
            xmin = 51.54505217137856 
            xmax = 59.413049346321785 
            text = "" 
        intervals [17]:
            xmin = 59.413049346321785 
            xmax = 62.648700224746165 
            text = "*роз* Я постараюсь його якомога швидше забрати" 
        intervals [18]:
            xmin = 62.648700224746165 
            xmax = 66.72057089716183 
            text = "" 
        intervals [19]:
            xmin = 66.72057089716183 
            xmax = 68.19656913437309 
            text = "Я знаю, знаю!" 
        intervals [20]:
            xmin = 68.19656913437309 
            xmax = 74.62644255174263 
            text = "" 
        intervals [21]:
            xmin = 74.62644255174263 
            xmax = 78.07280065788443 
            text = "*роз* Ну, я розумію, мені *роз* шкода…" 
        intervals [22]:
            xmin = 78.07280065788443 
            xmax = 83.6336719042311 
            text = "" 
        intervals [23]:
            xmin = 83.6336719042311 
            xmax = 86.34005094594727 
            text = "*е* *роз* Ех, що ж поробиш, гаразд." 
        intervals [24]:
            xmin = 86.34005094594727 
            xmax = 88.2166193115779 
            text = "" 
        intervals [25]:
            xmin = 88.2166193115779 
            xmax = 90.3376718297444 
            text = "*е* Та-та, взагалі без проблем." 
        intervals [26]:
            xmin = 90.3376718297444 
            xmax = 93.02133333333333 
            text = "" 
