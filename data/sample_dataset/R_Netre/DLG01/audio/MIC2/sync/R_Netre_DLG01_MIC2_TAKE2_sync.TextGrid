item []: 
    item [1]:
        class = "IntervalTier" 
        name = "SPK-A-text" 
        xmin = 0 
        xmax = 95.21632653061225 
        intervals: size = 27 
        intervals [1]:
            xmin = 0 
            xmax = 1.2773585747169922 
            text = "" 
        intervals [2]:
            xmin = 1.2773585747169922 
            xmax = 5.194789159725056 
            text = "" 
        intervals [3]:
            xmin = 5.194789159725056 
            xmax = 7.583341611132573 
            text = "*у* *роз* Я, цейво, *роз* є новини." 
        intervals [4]:
            xmin = 7.583341611132573 
            xmax = 9.953411413915992 
            text = "*роз* Але ти не хвилюйся тільки! Це не критично." 
        intervals [5]:
            xmin = 9.953411413915992 
            xmax = 11.847265043893424 
            text = "" 
        intervals [6]:
            xmin = 11.847265043893424 
            xmax = 19.636903778921653 
            text = "*е* Твій судочок з-під баклажанової ікри загубився. *роз* Ну, не *роз* загубився, скоріше поїхав в подорож Києвом..." 
        intervals [7]:
            xmin = 19.636903778921653 
            xmax = 21.78062375557623 
            text = "" 
        intervals [8]:
            xmin = 21.78062375557623 
            xmax = 24.14417034045112 
            text = "*роз* Він випадково попав до моєї бабусі," 
        intervals [9]:
            xmin = 24.14417034045112 
            xmax = 24.158679549398354 
            text = "" 
        intervals [10]:
            xmin = 24.158679549398354 
            xmax = 28.933384812493053 
            text = "а інша бабуся була в гостях і забрала його собі, бо подумала, шо то її судочок." 
        intervals [11]:
            xmin = 28.933384812493053 
            xmax = 32.577030655051054 
            text = "Але я уже подзвонила, і сказала, щоб вона його повернула." 
        intervals [12]:
            xmin = 32.577030655051054 
            xmax = 38.6314387790916 
            text = "" 
        intervals [13]:
            xmin = 38.6314387790916 
            xmax = 42.145083865378496 
            text = "*роз* Ну, не *роз* знаю, сподіваюсь, що на цьому тижні." 
        intervals [14]:
            xmin = 42.145083865378496 
            xmax = 45.09646496792832 
            text = "" 
        intervals [15]:
            xmin = 45.09646496792832 
            xmax = 51.20572986137216 
            text = "Але я все одно тобі, в знак компенсації, купила судочок. Дивись, він навіть теж з оранжевою кришкою." 
        intervals [16]:
            xmin = 51.20572986137216 
            xmax = 59.07372703631538 
            text = "" 
        intervals [17]:
            xmin = 59.07372703631538 
            xmax = 62.30937791473976 
            text = "*роз* Я постараюсь його якомога швидше забрати" 
        intervals [18]:
            xmin = 62.30937791473976 
            xmax = 66.38124858715544 
            text = "" 
        intervals [19]:
            xmin = 66.38124858715544 
            xmax = 67.8572468243667 
            text = "Я знаю, знаю!" 
        intervals [20]:
            xmin = 67.8572468243667 
            xmax = 74.28712024173623 
            text = "" 
        intervals [21]:
            xmin = 74.28712024173623 
            xmax = 77.73347834787803 
            text = "*роз* Ну, я розумію, мені *роз* шкода…" 
        intervals [22]:
            xmin = 77.73347834787803 
            xmax = 83.2943495942247 
            text = "" 
        intervals [23]:
            xmin = 83.2943495942247 
            xmax = 86.00072863594087 
            text = "*е* *роз* Ех, що ж поробиш, гаразд." 
        intervals [24]:
            xmin = 86.00072863594087 
            xmax = 87.8772970015715 
            text = "" 
        intervals [25]:
            xmin = 87.8772970015715 
            xmax = 89.998349519738 
            text = "*е* Та-та, взагалі без проблем." 
        intervals [26]:
            xmin = 89.998349519738 
            xmax = 95.11064655657641 
            text = "" 
        intervals [27]:
            xmin = 95.11064655657641 
            xmax = 95.21632653061225 
            text = "" 
