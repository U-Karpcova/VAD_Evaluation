    item [3]:
        class = "IntervalTier" 
        name = "SPK-B-text" 
        xmin = 0 
        xmax = 95.21632653061225 
        intervals: size = 30 
        intervals [1]:
            xmin = 0 
            xmax = 1.2773585747169922 
            text = "" 
        intervals [2]:
            xmin = 1.2773585747169922 
            xmax = 10.000072382522974 
            text = "" 
        intervals [3]:
            xmin = 10.000072382522974 
            xmax = 11.747852196193879 
            text = "*у* *роз* Ну, шо уже сталось?" 
        intervals [4]:
            xmin = 11.747852196193879 
            xmax = 19.695491851178108 
            text = "" 
        intervals [5]:
            xmin = 19.695491851178108 
            xmax = 21.767750185339615 
            text = "*роз* Еммм, *роз* погано." 
        intervals [6]:
            xmin = 21.767750185339615 
            xmax = 32.60141649835068 
            text = "" 
        intervals [7]:
            xmin = 32.60141649835068 
            xmax = 38.651911940565746 
            text = "*роз* Ага. І коли по часу приблизно мій судочок до мене повернеться?" 
        intervals [8]:
            xmin = 38.651911940565746 
            xmax = 42.155352465387594 
            text = "" 
        intervals [9]:
            xmin = 42.155352465387594 
            xmax = 45.14035852547501 
            text = "Я, якщо чесно, теж на це дуже сподіваюсь." 
        intervals [10]:
            xmin = 45.14035852547501 
            xmax = 51.5829832294108 
            text = "" 
        intervals [11]:
            xmin = 51.5829832294108 
            xmax = 53.443032119963576 
            text = "Дякую, звісно." 
        intervals [12]:
            xmin = 53.443032119963576 
            xmax = 59.129293080227484 
            text = "Але було б добре, *роз* дуже добре, якби ти повернула мені мій судочок." 
        intervals [13]:
            xmin = 59.129293080227484 
            xmax = 62.21425848069803 
            text = "" 
        intervals [14]:
            xmin = 62.21425848069803 
            xmax = 66.76087179190003 
            text = "Ти вообще розумієш, це був мій улюблений судочек! Він був менший, ніж цей." 
        intervals [15]:
            xmin = 66.76087179190003 
            xmax = 67.04829697758653 
            text = "" 
        intervals [16]:
            xmin = 67.04829697758653 
            xmax = 69.92228922876964 
            text = "і його було зручно покласти з собою в сумку." 
        intervals [17]:
            xmin = 69.92228922876964 
            xmax = 69.93735149923045 
            text = "" 
        intervals [18]:
            xmin = 69.93735149923045 
            xmax = 70.75810015453712 
            text = "І цей такий" 
        intervals [19]:
            xmin = 70.75810015453712 
            xmax = 70.77344338628394 
            text = "" 
        intervals [20]:
            xmin = 70.77344338628394 
            xmax = 74.27754235017669 
            text = "А цей судочок він такий важкий дуже, а той був легший." 
        intervals [21]:
            xmin = 74.27754235017669 
            xmax = 77.79346799582748 
            text = "" 
        intervals [22]:
            xmin = 77.79346799582748 
            xmax = 80.01808322907063 
            text = "Ну я теж розумію, ти знаєш." 
        intervals [23]:
            xmin = 80.01808322907063 
            xmax = 80.22117973656415 
            text = "" 
        intervals [24]:
            xmin = 80.22117973656415 
            xmax = 83.16411554799005 
            text = "Я думаю, ікри найближчим часом не буде." 
        intervals [25]:
            xmin = 83.16411554799005 
            xmax = 86.12664548515552 
            text = "" 
        intervals [26]:
            xmin = 86.12664548515552 
            xmax = 87.86959733704018 
            text = "І цей судочок я теж собі забираю." 
        intervals [27]:
            xmin = 87.86959733704018 
            xmax = 90.24405366397077 
            text = "" 
        intervals [28]:
            xmin = 90.24405366397077 
            xmax = 92.16683388152606 
            text = "Ну добре, тоді я чекаю." 
        intervals [29]:
            xmin = 92.16683388152606 
            xmax = 95.11064655657641 
            text = "" 
        intervals [30]:
            xmin = 95.11064655657641 
            xmax = 95.21632653061225 
            text = "" 
