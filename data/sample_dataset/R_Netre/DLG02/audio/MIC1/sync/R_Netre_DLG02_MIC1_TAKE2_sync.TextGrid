item []: 
    item [1]:
        class = "IntervalTier" 
        name = "SPK-A-text" 
        xmin = 0 
        xmax = 117.3275 
        intervals: size = 32 
        intervals [1]:
            xmin = 0 
            xmax = 8.644517121383858 
            text = "" 
        intervals [2]:
            xmin = 8.644517121383858 
            xmax = 15.002040275962214 
            text = "*у* *роз*Окей, але взагалі треба дізнатися, яка в нас локація. *роз* Чи вона не *роз* змінилась? Наче Маріїнський парк" 
        intervals [3]:
            xmin = 15.002040275962214 
            xmax = 18.236672770280755 
            text = "" 
        intervals [4]:
            xmin = 18.236672770280755 
            xmax = 21.553720345796513 
            text = "*а* гаразд, ну могли б і раніше сказати." 
        intervals [5]:
            xmin = 21.553720345796513 
            xmax = 24.86239030336329 
            text = "" 
        intervals [6]:
            xmin = 24.86239030336329 
            xmax = 25.809721828631915 
            text = "Тоді" 
        intervals [7]:
            xmin = 25.809721828631915 
            xmax = 25.82552831376826 
            text = "" 
        intervals [8]:
            xmin = 25.82552831376826 
            xmax = 31.438623995932545 
            text = "пропоную подумати, що хто має вдягати. Можливо, кожен прогляне картинки і скине в *о* ча" 
        intervals [9]:
            xmin = 31.438623995932545 
            xmax = 34.760545349627016 
            text = "" 
        intervals [10]:
            xmin = 34.760545349627016 
            xmax = 37.319455385780216 
            text = "*роз* Ну, щоб потім конфліктів не було?" 
        intervals [11]:
            xmin = 37.319455385780216 
            xmax = 44.169247721933225 
            text = "" 
        intervals [12]:
            xmin = 44.169247721933225 
            xmax = 44.828275333495476 
            text = "Хто?" 
        intervals [13]:
            xmin = 44.828275333495476 
            xmax = 46.28752648216811 
            text = "" 
        intervals [14]:
            xmin = 46.28752648216811 
            xmax = 49.44527853930366 
            text = "*роз* Ну, може варто написати, що ми хочемо своє?" 
        intervals [15]:
            xmin = 49.44527853930366 
            xmax = 55.34063981897695 
            text = "Може я хочу, умовно, спортивний стиль, вуличний. У мене як раз є класні джинси й нові кросівки" 
        intervals [16]:
            xmin = 55.34063981897695 
            xmax = 58.45171410938382 
            text = "" 
        intervals [17]:
            xmin = 58.45171410938382 
            xmax = 63.433215556943274 
            text = "*роз* Ну я ж погано в ньому виглядаю! Як таке взагалі можна вибрать на фотосесію!" 
        intervals [18]:
            xmin = 63.433215556943274 
            xmax = 66.50507037573877 
            text = "" 
        intervals [19]:
            xmin = 66.50507037573877 
            xmax = 70.36940565989148 
            text = "Ну *роз* а зараз я не хочу! Це ж на памʼять ми робим" 
        intervals [20]:
            xmin = 70.36940565989148 
            xmax = 70.46625325071113 
            text = "" 
        intervals [21]:
            xmin = 70.46625325071113 
            xmax = 73.07856457737313 
            text = "я хочу такий стиль, який я хочу!" 
        intervals [22]:
            xmin = 73.07856457737313 
            xmax = 77.08297324901744 
            text = "" 
        intervals [23]:
            xmin = 77.08297324901744 
            xmax = 82.59181933866229 
            text = "Та ні, це взагалі *пскл* ні *пскл* про *пскл* шо, як там можна взагалі самовиразитись?" 
        intervals [24]:
            xmin = 82.59181933866229 
            xmax = 86.91359518299348 
            text = "" 
        intervals [25]:
            xmin = 86.91359518299348 
            xmax = 90.65933760548458 
            text = "Та *роз* я ще сама не знаю! Мені треба час, шоб вирішити." 
        intervals [26]:
            xmin = 90.65933760548458 
            xmax = 92.98716984850346 
            text = "" 
        intervals [27]:
            xmin = 92.98716984850346 
            xmax = 95.03111102109521 
            text = "Ну, чого одразу так говорити?" 
        intervals [28]:
            xmin = 95.03111102109521 
            xmax = 99.66880089839535 
            text = "" 
        intervals [29]:
            xmin = 99.66880089839535 
            xmax = 102.80747014430227 
            text = "Я і пропоную, я ж сказала, вуличний стиль" 
        intervals [30]:
            xmin = 102.80747014430227 
            xmax = 112.90633021345401 
            text = "" 
        intervals [31]:
            xmin = 112.90633021345401 
            xmax = 116.57106386571104 
            text = "*роз* Ну, тоді нема сенсу *роз* мене про таке питати." 
        intervals [32]:
            xmin = 116.57106386571104 
            xmax = 117.3275 
            text = "" 
