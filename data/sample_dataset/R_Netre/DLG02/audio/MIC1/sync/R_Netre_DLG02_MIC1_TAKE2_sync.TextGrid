    item [3]:
        class = "IntervalTier" 
        name = "SPK-B-text" 
        xmin = 0 
        xmax = 117.3275 
        intervals: size = 45 
        intervals [1]:
            xmin = 0 
            xmax = 2.86485271865016 
            text = "" 
        intervals [2]:
            xmin = 2.86485271865016 
            xmax = 6.243888131341775 
            text = "*у* Так, ти уже вирішила чи підеш на фотосесію чи ні?" 
        intervals [3]:
            xmin = 6.243888131341775 
            xmax = 6.281419158896922 
            text = "" 
        intervals [4]:
            xmin = 6.281419158896922 
            xmax = 8.614993861681175 
            text = "Треба обговорити це, бо дата уже близько." 
        intervals [5]:
            xmin = 8.614993861681175 
            xmax = 14.86700127003615 
            text = "" 
        intervals [6]:
            xmin = 14.86700127003615 
            xmax = 18.097280246102294 
            text = "Ні-ні-ні, парк на Шулявці, ми вирішили поміняти." 
        intervals [7]:
            xmin = 18.097280246102294 
            xmax = 21.559015834804164 
            text = "" 
        intervals [8]:
            xmin = 21.559015834804164 
            xmax = 24.810579139438353 
            text = "Ну взагалі ми намагались якнайшвидше домовитись." 
        intervals [9]:
            xmin = 24.810579139438353 
            xmax = 30.85525732789194 
            text = "" 
        intervals [10]:
            xmin = 30.85525732789194 
            xmax = 34.87842848109366 
            text = "Кожен? Так це багато часу займе, обговорення кожного стилю." 
        intervals [11]:
            xmin = 34.87842848109366 
            xmax = 37.39017062003388 
            text = "" 
        intervals [12]:
            xmin = 37.39017062003388 
            xmax = 42.28375072804317 
            text = "Я думаю, нас з такими високими запросами просто не будуть слухати." 
        intervals [13]:
            xmin = 42.28375072804317 
            xmax = 42.29802212498446 
            text = "" 
        intervals [14]:
            xmin = 42.29802212498446 
            xmax = 42.99950546746889 
            text = "Скажуть" 
        intervals [15]:
            xmin = 42.99950546746889 
            xmax = 43.05116046675436 
            text = "" 
        intervals [16]:
            xmin = 43.05116046675436 
            xmax = 44.366557237553025 
            text = "робіть, як хочете." 
        intervals [17]:
            xmin = 44.366557237553025 
            xmax = 44.98310693483951 
            text = "" 
        intervals [18]:
            xmin = 44.98310693483951 
            xmax = 45.81789624565099 
            text = "Батьки." 
        intervals [19]:
            xmin = 45.81789624565099 
            xmax = 54.710386779844725 
            text = "" 
        intervals [20]:
            xmin = 54.710386779844725 
            xmax = 58.06662090466355 
            text = "В чаті написали, що ми домовлялися за діловий стиль" 
        intervals [21]:
            xmin = 58.06662090466355 
            xmax = 58.091400015071656 
            text = "" 
        intervals [22]:
            xmin = 58.091400015071656 
            xmax = 59.190082962324 
            text = "і взагалі-то" 
        intervals [23]:
            xmin = 59.190082962324 
            xmax = 63.38877010680077 
            text = "" 
        intervals [24]:
            xmin = 63.38877010680077 
            xmax = 67.10645969856094 
            text = "Так ти в ньому цілий рік ходила, і всі так ходили" 
        intervals [25]:
            xmin = 67.10645969856094 
            xmax = 73.21654730026857 
            text = "" 
        intervals [26]:
            xmin = 73.21654730026857 
            xmax = 78.73600354761614 
            text = "Ну, може тоді домовимось за напів діловий, кежуал такий?" 
        intervals [27]:
            xmin = 78.73600354761614 
            xmax = 82.79038578429959 
            text = "" 
        intervals [28]:
            xmin = 82.79038578429959 
            xmax = 83.38664806648174 
            text = "так" 
        intervals [29]:
            xmin = 83.38664806648174 
            xmax = 83.43630436630825 
            text = "" 
        intervals [30]:
            xmin = 83.43630436630825 
            xmax = 85.78566626329761 
            text = "Так поясни нормально, в чому ти хочеш прийти?" 
        intervals [31]:
            xmin = 85.78566626329761 
            xmax = 85.80553736007916 
            text = "" 
        intervals [32]:
            xmin = 85.80553736007916 
            xmax = 87.17587555458384 
            text = "І тоді напишемо про це в чаті." 
        intervals [33]:
            xmin = 87.17587555458384 
            xmax = 90.64388532433237 
            text = "" 
        intervals [34]:
            xmin = 90.64388532433237 
            xmax = 93.00001693622485 
            text = "Тоді взагалі можеш приходити в чому хочеш." 
        intervals [35]:
            xmin = 93.00001693622485 
            xmax = 95.49323249165141 
            text = "" 
        intervals [36]:
            xmin = 95.49323249165141 
            xmax = 97.96260091339511 
            text = "Тому шо якщо щось тобі не подобається," 
        intervals [37]:
            xmin = 97.96260091339511 
            xmax = 98.00559986601253 
            text = "" 
        intervals [38]:
            xmin = 98.00559986601253 
            xmax = 99.68722902094567 
            text = "треба пропонувати свій варіант." 
        intervals [39]:
            xmin = 99.68722902094567 
            xmax = 102.35029813591355 
            text = "" 
        intervals [40]:
            xmin = 102.35029813591355 
            xmax = 103.77603033724456 
            text = "Як ти собі це уявляєш?" 
        intervals [41]:
            xmin = 103.77603033724456 
            xmax = 105.07751087597123 
            text = "Я прийду в костюмі," 
        intervals [42]:
            xmin = 105.07751087597123 
            xmax = 107.4217550275089 
            text = "я уже купила новий, за кучу грошей," 
        intervals [43]:
            xmin = 107.4217550275089 
            xmax = 110.93857947645424 
            text = "а хтось вирішить вдіти спортивні штани!" 
        intervals [44]:
            xmin = 110.93857947645424 
            xmax = 112.9224068475704 
            text = "Якось дивно виглядає картинка." 
        intervals [45]:
            xmin = 112.9224068475704 
            xmax = 117.3275 
            text = "" 
