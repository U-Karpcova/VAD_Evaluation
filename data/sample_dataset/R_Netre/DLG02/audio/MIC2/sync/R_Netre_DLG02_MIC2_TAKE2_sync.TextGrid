    item [3]:
        class = "IntervalTier" 
        name = "SPK-B-text" 
        xmin = 0 
        xmax = 119.3665306122449 
        intervals: size = 45 
        intervals [1]:
            xmin = 0 
            xmax = 4.37759775577592 
            text = "" 
        intervals [2]:
            xmin = 4.37759775577592 
            xmax = 7.756633168467536 
            text = "*у* Так, ти уже вирішила чи підеш на фотосесію чи ні?" 
        intervals [3]:
            xmin = 7.756633168467536 
            xmax = 7.794164196022683 
            text = "" 
        intervals [4]:
            xmin = 7.794164196022683 
            xmax = 10.127738898806935 
            text = "Треба обговорити це, бо дата уже близько." 
        intervals [5]:
            xmin = 10.127738898806935 
            xmax = 16.37974630716191 
            text = "" 
        intervals [6]:
            xmin = 16.37974630716191 
            xmax = 19.61002528322805 
            text = "Ні-ні-ні, парк на Шулявці, ми вирішили поміняти." 
        intervals [7]:
            xmin = 19.61002528322805 
            xmax = 23.07176087192992 
            text = "" 
        intervals [8]:
            xmin = 23.07176087192992 
            xmax = 26.323324176564114 
            text = "Ну взагалі ми намагались якнайшвидше домовитись." 
        intervals [9]:
            xmin = 26.323324176564114 
            xmax = 32.3680023650177 
            text = "" 
        intervals [10]:
            xmin = 32.3680023650177 
            xmax = 36.39117351821942 
            text = "Кожен? Так це багато часу займе, обговорення кожного стилю." 
        intervals [11]:
            xmin = 36.39117351821942 
            xmax = 38.90291565715964 
            text = "" 
        intervals [12]:
            xmin = 38.90291565715964 
            xmax = 43.79649576516893 
            text = "Я думаю, нас з такими високими запросами просто не будуть слухати." 
        intervals [13]:
            xmin = 43.79649576516893 
            xmax = 43.810767162110224 
            text = "" 
        intervals [14]:
            xmin = 43.810767162110224 
            xmax = 44.512250504594654 
            text = "Скажуть" 
        intervals [15]:
            xmin = 44.512250504594654 
            xmax = 44.56390550388012 
            text = "" 
        intervals [16]:
            xmin = 44.56390550388012 
            xmax = 45.879302274678786 
            text = "робіть, як хочете." 
        intervals [17]:
            xmin = 45.879302274678786 
            xmax = 46.49585197196527 
            text = "" 
        intervals [18]:
            xmin = 46.49585197196527 
            xmax = 47.33064128277675 
            text = "Батьки." 
        intervals [19]:
            xmin = 47.33064128277675 
            xmax = 56.223131816970486 
            text = "" 
        intervals [20]:
            xmin = 56.223131816970486 
            xmax = 59.57936594178931 
            text = "В чаті написали, що ми домовлялися за діловий стиль" 
        intervals [21]:
            xmin = 59.57936594178931 
            xmax = 59.60414505219742 
            text = "" 
        intervals [22]:
            xmin = 59.60414505219742 
            xmax = 60.70282799944976 
            text = "і взагалі-то" 
        intervals [23]:
            xmin = 60.70282799944976 
            xmax = 64.90151514392653 
            text = "" 
        intervals [24]:
            xmin = 64.90151514392653 
            xmax = 68.61920473568671 
            text = "Так ти в ньому цілий рік ходила, і всі так ходили" 
        intervals [25]:
            xmin = 68.61920473568671 
            xmax = 74.72929233739434 
            text = "" 
        intervals [26]:
            xmin = 74.72929233739434 
            xmax = 80.2487485847419 
            text = "Ну, може тоді домовимось за напів діловий, кежуал такий?" 
        intervals [27]:
            xmin = 80.2487485847419 
            xmax = 84.30313082142536 
            text = "" 
        intervals [28]:
            xmin = 84.30313082142536 
            xmax = 84.89939310360751 
            text = "так" 
        intervals [29]:
            xmin = 84.89939310360751 
            xmax = 84.94904940343402 
            text = "" 
        intervals [30]:
            xmin = 84.94904940343402 
            xmax = 87.29841130042338 
            text = "Так поясни нормально, в чому ти хочеш прийти?" 
        intervals [31]:
            xmin = 87.29841130042338 
            xmax = 87.31828239720492 
            text = "" 
        intervals [32]:
            xmin = 87.31828239720492 
            xmax = 88.68862059170961 
            text = "І тоді напишемо про це в чаті." 
        intervals [33]:
            xmin = 88.68862059170961 
            xmax = 92.15663036145814 
            text = "" 
        intervals [34]:
            xmin = 92.15663036145814 
            xmax = 94.51276197335062 
            text = "Тоді взагалі можеш приходити в чому хочеш." 
        intervals [35]:
            xmin = 94.51276197335062 
            xmax = 97.00597752877718 
            text = "" 
        intervals [36]:
            xmin = 97.00597752877718 
            xmax = 99.47534595052088 
            text = "Тому шо якщо щось тобі не подобається," 
        intervals [37]:
            xmin = 99.47534595052088 
            xmax = 99.5183449031383 
            text = "" 
        intervals [38]:
            xmin = 99.5183449031383 
            xmax = 101.19997405807143 
            text = "треба пропонувати свій варіант." 
        intervals [39]:
            xmin = 101.19997405807143 
            xmax = 103.86304317303932 
            text = "" 
        intervals [40]:
            xmin = 103.86304317303932 
            xmax = 105.28877537437033 
            text = "Як ти собі це уявляєш?" 
        intervals [41]:
            xmin = 105.28877537437033 
            xmax = 106.590255913097 
            text = "Я прийду в костюмі," 
        intervals [42]:
            xmin = 106.590255913097 
            xmax = 108.93450006463466 
            text = "я уже купила новий, за кучу грошей," 
        intervals [43]:
            xmin = 108.93450006463466 
            xmax = 112.45132451358 
            text = "а хтось вирішить вдіти спортивні штани!" 
        intervals [44]:
            xmin = 112.45132451358 
            xmax = 114.43515188469617 
            text = "Якось дивно виглядає картинка." 
        intervals [45]:
            xmin = 114.43515188469617 
            xmax = 119.3665306122449 
            text = "" 
