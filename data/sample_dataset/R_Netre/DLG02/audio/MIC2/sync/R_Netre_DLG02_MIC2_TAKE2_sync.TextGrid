item []: 
    item [1]:
        class = "IntervalTier" 
        name = "SPK-A-text" 
        xmin = 0 
        xmax = 119.3665306122449 
        intervals: size = 32 
        intervals [1]:
            xmin = 0 
            xmax = 10.157262158509619 
            text = "" 
        intervals [2]:
            xmin = 10.157262158509619 
            xmax = 16.514785313087973 
            text = "*у* *роз*Окей, але взагалі треба дізнатися, яка в нас локація. *роз* Чи вона не *роз* змінилась? Наче Маріїнський парк" 
        intervals [3]:
            xmin = 16.514785313087973 
            xmax = 19.749417807406513 
            text = "" 
        intervals [4]:
            xmin = 19.749417807406513 
            xmax = 23.06646538292227 
            text = "*а* гаразд, ну могли б і раніше сказати." 
        intervals [5]:
            xmin = 23.06646538292227 
            xmax = 26.375135340489052 
            text = "" 
        intervals [6]:
            xmin = 26.375135340489052 
            xmax = 27.322466865757676 
            text = "Тоді" 
        intervals [7]:
            xmin = 27.322466865757676 
            xmax = 27.33827335089402 
            text = "" 
        intervals [8]:
            xmin = 27.33827335089402 
            xmax = 32.951369033058306 
            text = "пропоную подумати, що хто має вдягати. Можливо, кожен прогляне картинки і скине в *о* ча" 
        intervals [9]:
            xmin = 32.951369033058306 
            xmax = 36.27329038675278 
            text = "" 
        intervals [10]:
            xmin = 36.27329038675278 
            xmax = 38.83220042290598 
            text = "*роз* Ну, щоб потім конфліктів не було?" 
        intervals [11]:
            xmin = 38.83220042290598 
            xmax = 45.681992759058986 
            text = "" 
        intervals [12]:
            xmin = 45.681992759058986 
            xmax = 46.34102037062124 
            text = "Хто?" 
        intervals [13]:
            xmin = 46.34102037062124 
            xmax = 47.80027151929387 
            text = "" 
        intervals [14]:
            xmin = 47.80027151929387 
            xmax = 50.95802357642942 
            text = "*роз* Ну, може варто написати, що ми хочемо своє?" 
        intervals [15]:
            xmin = 50.95802357642942 
            xmax = 56.853384856102714 
            text = "Може я хочу, умовно, спортивний стиль, вуличний. У мене як раз є класні джинси й нові кросівки" 
        intervals [16]:
            xmin = 56.853384856102714 
            xmax = 59.96445914650958 
            text = "" 
        intervals [17]:
            xmin = 59.96445914650958 
            xmax = 64.94596059406904 
            text = "*роз* Ну я ж погано в ньому виглядаю! Як таке взагалі можна вибрать на фотосесію!" 
        intervals [18]:
            xmin = 64.94596059406904 
            xmax = 68.01781541286454 
            text = "" 
        intervals [19]:
            xmin = 68.01781541286454 
            xmax = 71.88215069701725 
            text = "Ну *роз* а зараз я не хочу! Це ж на памʼять ми робим" 
        intervals [20]:
            xmin = 71.88215069701725 
            xmax = 71.9789982878369 
            text = "" 
        intervals [21]:
            xmin = 71.9789982878369 
            xmax = 74.5913096144989 
            text = "я хочу такий стиль, який я хочу!" 
        intervals [22]:
            xmin = 74.5913096144989 
            xmax = 78.59571828614321 
            text = "" 
        intervals [23]:
            xmin = 78.59571828614321 
            xmax = 84.10456437578806 
            text = "Та ні, це взагалі *пскл* ні *пскл* про *пскл* шо, як там можна взагалі самовиразитись?" 
        intervals [24]:
            xmin = 84.10456437578806 
            xmax = 88.42634022011924 
            text = "" 
        intervals [25]:
            xmin = 88.42634022011924 
            xmax = 92.17208264261035 
            text = "Та *роз* я ще сама не знаю! Мені треба час, шоб вирішити." 
        intervals [26]:
            xmin = 92.17208264261035 
            xmax = 94.49991488562922 
            text = "" 
        intervals [27]:
            xmin = 94.49991488562922 
            xmax = 96.54385605822098 
            text = "Ну, чого одразу так говорити?" 
        intervals [28]:
            xmin = 96.54385605822098 
            xmax = 101.18154593552111 
            text = "" 
        intervals [29]:
            xmin = 101.18154593552111 
            xmax = 104.32021518142804 
            text = "Я і пропоную, я ж сказала, вуличний стиль" 
        intervals [30]:
            xmin = 104.32021518142804 
            xmax = 114.41907525057978 
            text = "" 
        intervals [31]:
            xmin = 114.41907525057978 
            xmax = 118.08380890283681 
            text = "*роз* Ну, тоді нема сенсу *роз* мене про таке питати." 
        intervals [32]:
            xmin = 118.08380890283681 
            xmax = 119.3665306122449 
            text = "" 
