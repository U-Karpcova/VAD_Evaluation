    item [3]:
        class = "IntervalTier" 
        name = "SPK-B-text" 
        xmin = 0 
        xmax = 80.21570833333334 
        intervals: size = 50 
        intervals [1]:
            xmin = 0 
            xmax = 3.02458434463285 
            text = "" 
        intervals [2]:
            xmin = 3.02458434463285 
            xmax = 4.116786564125061 
            text = "*у* Я вдома!" 
        intervals [3]:
            xmin = 4.116786564125061 
            xmax = 4.296461993155648 
            text = "" 
        intervals [4]:
            xmin = 4.296461993155648 
            xmax = 8.330450462882375 
            text = "А дістань мені, будь ласка, торта з холодильнику, я щас хочу зʼїсти" 
        intervals [5]:
            xmin = 8.330450462882375 
            xmax = 10.30201507387173 
            text = "" 
        intervals [6]:
            xmin = 10.30201507387173 
            xmax = 12.229098013748326 
            text = "Йо, тільки не кажи, що" 
        intervals [7]:
            xmin = 12.229098013748326 
            xmax = 13.572946336152054 
            text = "" 
        intervals [8]:
            xmin = 13.572946336152054 
            xmax = 17.004030278688166 
            text = "*роз* Ну, суперкайф, а я на нього сподівалась взагалі-то." 
        intervals [9]:
            xmin = 17.004030278688166 
            xmax = 17.835589480781923 
            text = "" 
        intervals [10]:
            xmin = 17.835589480781923 
            xmax = 20.530494376646562 
            text = "Ну, я ж просила залишити мені шматок!" 
        intervals [11]:
            xmin = 20.530494376646562 
            xmax = 20.538573240416135 
            text = "" 
        intervals [12]:
            xmin = 20.538573240416135 
            xmax = 21.925289697026574 
            text = "Невже це так складно було!" 
        intervals [13]:
            xmin = 21.925289697026574 
            xmax = 26.655163479723427 
            text = "" 
        intervals [14]:
            xmin = 26.655163479723427 
            xmax = 28.57605742286245 
            text = "Так а це був мій шматок торта," 
        intervals [15]:
            xmin = 28.57605742286245 
            xmax = 31.150878719034377 
            text = "і взагалі всі ці солодощі ж я купувала!" 
        intervals [16]:
            xmin = 31.150878719034377 
            xmax = 31.169841528664673 
            text = "" 
        intervals [17]:
            xmin = 31.169841528664673 
            xmax = 32.47365894071324 
            text = "Між іншим, за свій кошт!" 
        intervals [18]:
            xmin = 32.47365894071324 
            xmax = 32.49234848713639 
            text = "" 
        intervals [19]:
            xmin = 32.49234848713639 
            xmax = 34.82403232440507 
            text = "Ти знаєш скільки зараз торти коштують?" 
        intervals [20]:
            xmin = 34.82403232440507 
            xmax = 37.67690168481283 
            text = "" 
        intervals [21]:
            xmin = 37.67690168481283 
            xmax = 40.04201286205005 
            text = "Та чого зразу, я такого не казала." 
        intervals [22]:
            xmin = 40.04201286205005 
            xmax = 40.082891433685994 
            text = "" 
        intervals [23]:
            xmin = 40.082891433685994 
            xmax = 43.014106212454564 
            text = "Могла б просто подзвонити, я б усе докупила що треба." 
        intervals [24]:
            xmin = 43.014106212454564 
            xmax = 44.52457594855143 
            text = "" 
        intervals [25]:
            xmin = 44.52457594855143 
            xmax = 45.356598463193066 
            text = "Та Боже, ну" 
        intervals [26]:
            xmin = 45.356598463193066 
            xmax = 49.5773468830954 
            text = "Але ж тепер навіть і торта немає, і взагалі нема що їсти вдома, прекрасно." 
        intervals [27]:
            xmin = 49.5773468830954 
            xmax = 49.60076999193967 
            text = "" 
        intervals [28]:
            xmin = 49.60076999193967 
            xmax = 51.304538148486024 
            text = "Настрій просто в трубу." 
        intervals [29]:
            xmin = 51.304538148486024 
            xmax = 54.01580998477095 
            text = "" 
        intervals [30]:
            xmin = 54.01580998477095 
            xmax = 54.46115483024214 
            text = "Та" 
        intervals [31]:
            xmin = 54.46115483024214 
            xmax = 54.46759440425133 
            text = "" 
        intervals [32]:
            xmin = 54.46759440425133 
            xmax = 56.21691857719709 
            text = "Пізно вже буде бігти." 
        intervals [33]:
            xmin = 56.21691857719709 
            xmax = 56.235112302443724 
            text = "" 
        intervals [34]:
            xmin = 56.235112302443724 
            xmax = 58.95578474543407 
            text = "І до того ж -- я ж хотіла саме той торт, розумієш?" 
        intervals [35]:
            xmin = 58.95578474543407 
            xmax = 63.24760396564524 
            text = "Я його ще вчора ""на потім"" собі залишила, і сьодні думала про нього цілий день." 
        intervals [36]:
            xmin = 63.24760396564524 
            xmax = 69.31884742267545 
            text = "" 
        intervals [37]:
            xmin = 69.31884742267545 
            xmax = 69.99841716769991 
            text = "*роз* О" 
        intervals [38]:
            xmin = 69.99841716769991 
            xmax = 70.00402306889977 
            text = "" 
        intervals [39]:
            xmin = 70.00402306889977 
            xmax = 70.60525524019528 
            text = "*вд*" 
        intervals [40]:
            xmin = 70.60525524019528 
            xmax = 70.79924443591732 
            text = "*цок*n" 
        intervals [41]:
            xmin = 70.79924443591732 
            xmax = 72.2142159571932 
            text = "*роз* Ну, гаразд." 
        intervals [42]:
            xmin = 72.2142159571932 
            xmax = 72.28381751267571 
            text = "" 
        intervals [43]:
            xmin = 72.28381751267571 
            xmax = 73.56862533286524 
            text = "Звучить заманливо." 
        intervals [44]:
            xmin = 73.56862533286524 
            xmax = 73.9977201576256 
            text = "" 
        intervals [45]:
            xmin = 73.9977201576256 
            xmax = 74.79482541749827 
            text = "Але тоді!" 
        intervals [46]:
            xmin = 74.79482541749827 
            xmax = 75.09133894157064 
            text = "" 
        intervals [47]:
            xmin = 75.09133894157064 
            xmax = 76.82558123238626 
            text = "Купи шось реально смачне!" 
        intervals [48]:
            xmin = 76.82558123238626 
            xmax = 76.85501037706125 
            text = "" 
        intervals [49]:
            xmin = 76.85501037706125 
            xmax = 78.65028805972675 
            text = "Шоб компенсувати мені моральну шкоду!" 
        intervals [50]:
            xmin = 78.65028805972675 
            xmax = 80.21570833333334 
            text = "" 
