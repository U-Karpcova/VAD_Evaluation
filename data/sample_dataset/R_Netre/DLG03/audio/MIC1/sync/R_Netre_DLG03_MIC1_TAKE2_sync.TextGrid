item []: 
    item [1]:
        class = "IntervalTier" 
        name = "SPK-A-text" 
        xmin = 0 
        xmax = 80.21570833333334 
        intervals: size = 21 
        intervals [1]:
            xmin = 0 
            xmax = 8.154891286480089 
            text = "" 
        intervals [2]:
            xmin = 8.154891286480089 
            xmax = 10.520055834942266 
            text = "*у* *роз* А, *е* тут така справа" 
        intervals [3]:
            xmin = 10.520055834942266 
            xmax = 11.70446814636788 
            text = "" 
        intervals [4]:
            xmin = 11.70446814636788 
            xmax = 13.509821595198048 
            text = "*роз* я доїла весь торт." 
        intervals [5]:
            xmin = 13.509821595198048 
            xmax = 16.636732462700508 
            text = "" 
        intervals [6]:
            xmin = 16.636732462700508 
            xmax = 18.38137180430879 
            text = "*роз* Я не спеціально, чесно!" 
        intervals [7]:
            xmin = 18.38137180430879 
            xmax = 21.862517383972477 
            text = "" 
        intervals [8]:
            xmin = 21.862517383972477 
            xmax = 26.7177369738233 
            text = "Ну, а взагалі їсти нічого не було вдома, я зголодніла, прийшлося доїсти." 
        intervals [9]:
            xmin = 26.7177369738233 
            xmax = 33.981088981898374 
            text = "" 
        intervals [10]:
            xmin = 33.981088981898374 
            xmax = 37.76860973272132 
            text = "*роз* Знаю-знаю-знаю, ну але я шо тут мала голодать?" 
        intervals [11]:
            xmin = 37.76860973272132 
            xmax = 42.7453782341538 
            text = "" 
        intervals [12]:
            xmin = 42.7453782341538 
            xmax = 44.5141729261634 
            text = "Ти багато на себе береш." 
        intervals [13]:
            xmin = 44.5141729261634 
            xmax = 51.07792594730881 
            text = "" 
        intervals [14]:
            xmin = 51.07792594730881 
            xmax = 53.962235375498445 
            text = "Може я зараз швидко збігаю в магазин?" 
        intervals [15]:
            xmin = 53.962235375498445 
            xmax = 63.25460665599155 
            text = "" 
        intervals [16]:
            xmin = 63.25460665599155 
            xmax = 66.36632335269789 
            text = "*роз* Ну то я не проти збігати і взяти такий самий. *вд*" 
        intervals [17]:
            xmin = 66.36632335269789 
            xmax = 66.38862265059647 
            text = "" 
        intervals [18]:
            xmin = 66.38862265059647 
            xmax = 68.61392324136787 
            text = "Ще шось до чаю можна взять." 
        intervals [19]:
            xmin = 68.61392324136787 
            xmax = 78.66405451098996 
            text = "" 
        intervals [20]:
            xmin = 78.66405451098996 
            xmax = 79.58670567465205 
            text = "Домовились!" 
        intervals [21]:
            xmin = 79.58670567465205 
            xmax = 80.21570833333334 
            text = "" 
