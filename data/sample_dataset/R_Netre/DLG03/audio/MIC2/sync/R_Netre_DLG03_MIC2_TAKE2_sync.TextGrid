item []: 
    item [1]:
        class = "IntervalTier" 
        name = "SPK-A-text" 
        xmin = 0 
        xmax = 81.28 
        intervals: size = 21 
        intervals [1]:
            xmin = 0 
            xmax = 8.133356708116587 
            text = "" 
        intervals [2]:
            xmin = 8.133356708116587 
            xmax = 10.498521256578764 
            text = "*у* *роз* А, *е* тут така справа" 
        intervals [3]:
            xmin = 10.498521256578764 
            xmax = 11.682933568004378 
            text = "" 
        intervals [4]:
            xmin = 11.682933568004378 
            xmax = 13.488287016834546 
            text = "*роз* я доїла весь торт." 
        intervals [5]:
            xmin = 13.488287016834546 
            xmax = 16.615197884337004 
            text = "" 
        intervals [6]:
            xmin = 16.615197884337004 
            xmax = 18.359837225945288 
            text = "*роз* Я не спеціально, чесно!" 
        intervals [7]:
            xmin = 18.359837225945288 
            xmax = 21.840982805608974 
            text = "" 
        intervals [8]:
            xmin = 21.840982805608974 
            xmax = 26.696202395459796 
            text = "Ну, а взагалі їсти нічого не було вдома, я зголодніла, прийшлося доїсти." 
        intervals [9]:
            xmin = 26.696202395459796 
            xmax = 33.959554403534874 
            text = "" 
        intervals [10]:
            xmin = 33.959554403534874 
            xmax = 37.74707515435782 
            text = "*роз* Знаю-знаю-знаю, ну але я шо тут мала голодать?" 
        intervals [11]:
            xmin = 37.74707515435782 
            xmax = 42.7238436557903 
            text = "" 
        intervals [12]:
            xmin = 42.7238436557903 
            xmax = 44.4926383477999 
            text = "Ти багато на себе береш." 
        intervals [13]:
            xmin = 44.4926383477999 
            xmax = 51.05639136894531 
            text = "" 
        intervals [14]:
            xmin = 51.05639136894531 
            xmax = 53.940700797134944 
            text = "Може я зараз швидко збігаю в магазин?" 
        intervals [15]:
            xmin = 53.940700797134944 
            xmax = 63.23307207762805 
            text = "" 
        intervals [16]:
            xmin = 63.23307207762805 
            xmax = 66.34478877433439 
            text = "*роз* Ну то я не проти збігати і взяти такий самий. *вд*" 
        intervals [17]:
            xmin = 66.34478877433439 
            xmax = 66.36708807223297 
            text = "" 
        intervals [18]:
            xmin = 66.36708807223297 
            xmax = 68.59238866300437 
            text = "Ще шось до чаю можна взять." 
        intervals [19]:
            xmin = 68.59238866300437 
            xmax = 78.64251993262646 
            text = "" 
        intervals [20]:
            xmin = 78.64251993262646 
            xmax = 79.56517109628855 
            text = "Домовились!" 
        intervals [21]:
            xmin = 79.56517109628855 
            xmax = 81.28 
            text = "" 
