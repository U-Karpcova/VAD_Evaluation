    item [3]:
        class = "IntervalTier" 
        name = "SPK-B-text" 
        xmin = 0 
        xmax = 81.28 
        intervals: size = 50 
        intervals [1]:
            xmin = 0 
            xmax = 3.003049766269347 
            text = "" 
        intervals [2]:
            xmin = 3.003049766269347 
            xmax = 4.095251985761557 
            text = "*у* Я вдома!" 
        intervals [3]:
            xmin = 4.095251985761557 
            xmax = 4.274927414792145 
            text = "" 
        intervals [4]:
            xmin = 4.274927414792145 
            xmax = 8.308915884518873 
            text = "А дістань мені, будь ласка, торта з холодильнику, я щас хочу зʼїсти" 
        intervals [5]:
            xmin = 8.308915884518873 
            xmax = 10.280480495508229 
            text = "" 
        intervals [6]:
            xmin = 10.280480495508229 
            xmax = 12.207563435384824 
            text = "Йо, тільки не кажи, що" 
        intervals [7]:
            xmin = 12.207563435384824 
            xmax = 13.551411757788552 
            text = "" 
        intervals [8]:
            xmin = 13.551411757788552 
            xmax = 16.982495700324662 
            text = "*роз* Ну, суперкайф, а я на нього сподівалась взагалі-то." 
        intervals [9]:
            xmin = 16.982495700324662 
            xmax = 17.81405490241842 
            text = "" 
        intervals [10]:
            xmin = 17.81405490241842 
            xmax = 20.50895979828306 
            text = "Ну, я ж просила залишити мені шматок!" 
        intervals [11]:
            xmin = 20.50895979828306 
            xmax = 20.51703866205263 
            text = "" 
        intervals [12]:
            xmin = 20.51703866205263 
            xmax = 21.90375511866307 
            text = "Невже це так складно було!" 
        intervals [13]:
            xmin = 21.90375511866307 
            xmax = 26.633628901359923 
            text = "" 
        intervals [14]:
            xmin = 26.633628901359923 
            xmax = 28.554522844498948 
            text = "Так а це був мій шматок торта," 
        intervals [15]:
            xmin = 28.554522844498948 
            xmax = 31.129344140670874 
            text = "і взагалі всі ці солодощі ж я купувала!" 
        intervals [16]:
            xmin = 31.129344140670874 
            xmax = 31.14830695030117 
            text = "" 
        intervals [17]:
            xmin = 31.14830695030117 
            xmax = 32.45212436234974 
            text = "Між іншим, за свій кошт!" 
        intervals [18]:
            xmin = 32.45212436234974 
            xmax = 32.47081390877289 
            text = "" 
        intervals [19]:
            xmin = 32.47081390877289 
            xmax = 34.80249774604157 
            text = "Ти знаєш скільки зараз торти коштують?" 
        intervals [20]:
            xmin = 34.80249774604157 
            xmax = 37.65536710644933 
            text = "" 
        intervals [21]:
            xmin = 37.65536710644933 
            xmax = 40.02047828368655 
            text = "Та чого зразу, я такого не казала." 
        intervals [22]:
            xmin = 40.02047828368655 
            xmax = 40.061356855322494 
            text = "" 
        intervals [23]:
            xmin = 40.061356855322494 
            xmax = 42.992571634091064 
            text = "Могла б просто подзвонити, я б усе докупила що треба." 
        intervals [24]:
            xmin = 42.992571634091064 
            xmax = 44.50304137018793 
            text = "" 
        intervals [25]:
            xmin = 44.50304137018793 
            xmax = 45.335063884829566 
            text = "Та Боже, ну" 
        intervals [26]:
            xmin = 45.335063884829566 
            xmax = 49.5558123047319 
            text = "Але ж тепер навіть і торта немає, і взагалі нема що їсти вдома, прекрасно." 
        intervals [27]:
            xmin = 49.5558123047319 
            xmax = 49.57923541357617 
            text = "" 
        intervals [28]:
            xmin = 49.57923541357617 
            xmax = 51.283003570122524 
            text = "Настрій просто в трубу." 
        intervals [29]:
            xmin = 51.283003570122524 
            xmax = 53.994275406407446 
            text = "" 
        intervals [30]:
            xmin = 53.994275406407446 
            xmax = 54.43962025187864 
            text = "Та" 
        intervals [31]:
            xmin = 54.43962025187864 
            xmax = 54.44605982588783 
            text = "" 
        intervals [32]:
            xmin = 54.44605982588783 
            xmax = 56.19538399883359 
            text = "Пізно вже буде бігти." 
        intervals [33]:
            xmin = 56.19538399883359 
            xmax = 56.213577724080224 
            text = "" 
        intervals [34]:
            xmin = 56.213577724080224 
            xmax = 58.93425016707057 
            text = "І до того ж -- я ж хотіла саме той торт, розумієш?" 
        intervals [35]:
            xmin = 58.93425016707057 
            xmax = 63.22606938728174 
            text = "Я його ще вчора ""на потім"" собі залишила, і сьодні думала про нього цілий день." 
        intervals [36]:
            xmin = 63.22606938728174 
            xmax = 69.29731284431195 
            text = "" 
        intervals [37]:
            xmin = 69.29731284431195 
            xmax = 69.97688258933641 
            text = "*роз* О" 
        intervals [38]:
            xmin = 69.97688258933641 
            xmax = 69.98248849053627 
            text = "" 
        intervals [39]:
            xmin = 69.98248849053627 
            xmax = 70.58372066183178 
            text = "*вд*" 
        intervals [40]:
            xmin = 70.58372066183178 
            xmax = 70.77770985755382 
            text = "*цок*n" 
        intervals [41]:
            xmin = 70.77770985755382 
            xmax = 72.1926813788297 
            text = "*роз* Ну, гаразд." 
        intervals [42]:
            xmin = 72.1926813788297 
            xmax = 72.26228293431221 
            text = "" 
        intervals [43]:
            xmin = 72.26228293431221 
            xmax = 73.54709075450174 
            text = "Звучить заманливо." 
        intervals [44]:
            xmin = 73.54709075450174 
            xmax = 73.9761855792621 
            text = "" 
        intervals [45]:
            xmin = 73.9761855792621 
            xmax = 74.77329083913477 
            text = "Але тоді!" 
        intervals [46]:
            xmin = 74.77329083913477 
            xmax = 75.06980436320714 
            text = "" 
        intervals [47]:
            xmin = 75.06980436320714 
            xmax = 76.80404665402276 
            text = "Купи шось реально смачне!" 
        intervals [48]:
            xmin = 76.80404665402276 
            xmax = 76.83347579869775 
            text = "" 
        intervals [49]:
            xmin = 76.83347579869775 
            xmax = 78.62875348136325 
            text = "Шоб компенсувати мені моральну шкоду!" 
        intervals [50]:
            xmin = 78.62875348136325 
            xmax = 81.28 
            text = "" 
