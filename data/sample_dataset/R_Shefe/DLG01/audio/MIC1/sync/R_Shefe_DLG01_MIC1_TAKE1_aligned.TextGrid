item []: 
    item [1]:
        class = "IntervalTier" 
        name = "SPK-A-text" 
        xmin = 0 
        xmax = 116.00108843537414 
        intervals: size = 21 
        intervals [1]:
            xmin = 0 
            xmax = 3.3204074064940814 
            text = "" 
        intervals [2]:
            xmin = 3.3204074064940814 
            xmax = 14.374054206148182 
            text = "*у* От я сиділа й думала: лінгвістика – вона наука не така вже й стара, але й не наймолодша. За час її існування виникло багато всяких підрозділів та течій," 
        intervals [3]:
            xmin = 14.374054206148182 
            xmax = 21.2564341270847 
            text = "але досі ніхто не перевершить внесок Копенгагенської лінгвістичної школи." 
        intervals [4]:
            xmin = 21.2564341270847 
            xmax = 35.949381480771514 
            text = "" 
        intervals [5]:
            xmin = 35.949381480771514 
            xmax = 37.00396000115158 
            text = "Ну *роз* так." 
        intervals [6]:
            xmin = 37.00396000115158 
            xmax = 37.502356699139426 
            text = "" 
        intervals [7]:
            xmin = 37.502356699139426 
            xmax = 46.08228540445577 
            text = "У копенгагенців все чітко. Мова – це система, не залежить від соціальних чинників, а лінгвістика – точна та логічна наука." 
        intervals [8]:
            xmin = 46.08228540445577 
            xmax = 48.83111933687388 
            text = "Без всілякої поетичної маячні." 
        intervals [9]:
            xmin = 48.83111933687388 
            xmax = 53.645733494917174 
            text = "" 
        intervals [10]:
            xmin = 53.645733494917174 
            xmax = 61.78893517847015 
            text = "Стривай-стривай-стривай. Це я зараз чую аргументи на користь *сміх* Празької лінгвістичної школи?" 
        intervals [11]:
            xmin = 61.78893517847015 
            xmax = 76.49210599383431 
            text = "" 
        intervals [12]:
            xmin = 76.49210599383431 
            xmax = 77.11292024970594 
            text = "Ну як це?" 
        intervals [13]:
            xmin = 77.11292024970594 
            xmax = 77.6029637179227 
            text = "" 
        intervals [14]:
            xmin = 77.6029637179227 
            xmax = 81.43959581920936 
            text = "Він досліджував фігури плану вираження і фігури плану змісту." 
        intervals [15]:
            xmin = 81.43959581920936 
            xmax = 87.2396054038278 
            text = "" 
        intervals [16]:
            xmin = 87.2396054038278 
            xmax = 89.29558704291202 
            text = "Ну а як же його компонентний аналіз?" 
        intervals [17]:
            xmin = 89.29558704291202 
            xmax = 95.80080486186826 
            text = "" 
        intervals [18]:
            xmin = 95.80080486186826 
            xmax = 97.66084211279968 
            text = "ні" 
        intervals [19]:
            xmin = 97.66084211279968 
            xmax = 98.09972730683968 
            text = "" 
        intervals [20]:
            xmin = 98.09972730683968 
            xmax = 110.5717385235698 
            text = "Але копенгагенці насправді розвинули цілу теорію, по-новому окреслили предмет дослідження мовознавства, створили нову концепцію врешті-решт! А пражці що? *сарк* Придумали п’ятсот семантичних відтінків слова «стіл»?" 
        intervals [21]:
            xmin = 110.5717385235698 
            xmax = 116.00108843537414 
            text = "" 
