    item [3]:
        class = "IntervalTier" 
        name = "SPK-B-text" 
        xmin = 0 
        xmax = 116.00108843537414 
        intervals: size = 15 
        intervals [1]:
            xmin = 0 
            xmax = 21.257181393953715 
            text = "" 
        intervals [2]:
            xmin = 21.257181393953715 
            xmax = 35.31236139158674 
            text = "*у* Почекай-почекай-почекай. З усіх мовознавчих шкіл ти вибрала що? Ну тобто у світі, де є Гумбольдт, молодограматики, дескриптивісти, Ворф та Сепір зрештою, ти обрала Єльмслева?" 
        intervals [3]:
            xmin = 35.31236139158674 
            xmax = 48.83111933687388 
            text = "" 
        intervals [4]:
            xmin = 48.83111933687388 
            xmax = 54.269063278633375 
            text = "Так а нащо нам мова без соціуму? Який взагалі сенс в її існуванні? І чому" 
        intervals [5]:
            xmin = 54.269063278633375 
            xmax = 61.78893517847015 
            text = "" 
        intervals [6]:
            xmin = 61.78893517847015 
            xmax = 63.180434332547236 
            text = "А що з ними не так?" 
        intervals [7]:
            xmin = 63.180434332547236 
            xmax = 73.27924623263264 
            text = "От у кого справді немає прогалин в теорії – це у Матезіуса. Між іншим, саме *об* ві ця школа розвинула вчення про актуальне членування речення." 
        intervals [8]:
            xmin = 73.27924623263264 
            xmax = 76.09805591889162 
            text = "А що крім головного болю нам дав Єльмслев?" 
        intervals [9]:
            xmin = 76.09805591889162 
            xmax = 81.86671602724904 
            text = "" 
        intervals [10]:
            xmin = 81.86671602724904 
            xmax = 86.34928962209844 
            text = "Які до цього досліджував Сосюр. *сарк* Оце великий геній!" 
        intervals [11]:
            xmin = 86.34928962209844 
            xmax = 89.21233161457154 
            text = "" 
        intervals [12]:
            xmin = 89.21233161457154 
            xmax = 95.17186670433772 
            text = "Його компонентний аналіз – це нікому непотрібна маячня. Ти знаєш як його проводить?" 
        intervals [13]:
            xmin = 95.17186670433772 
            xmax = 110.25044541899187 
            text = "" 
        intervals [14]:
            xmin = 110.25044541899187 
            xmax = 112.46512560744222 
            text = "Ой, нічо не знаю, нічо не знаю." 
        intervals [15]:
            xmin = 112.46512560744222 
            xmax = 116.00108843537414 
            text = "" 
