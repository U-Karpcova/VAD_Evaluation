    item [3]:
        class = "IntervalTier" 
        name = "SPK-B-text" 
        xmin = 0 
        xmax = 120.98612244897959 
        intervals: size = 17 
        intervals [1]:
            xmin = 0 
            xmax = 25.07626536027189 
            text = "" 
        intervals [2]:
            xmin = 25.07626536027189 
            xmax = 40.83072815341812 
            text = "*у* Почекай-почекай-почекай-почекай. З усіх мовознавчих шкіл ти вибрала що? Ну тобто у світі, де є Гумбольдт, молодограматики, дескриптивісти, Ворф та Сепір зрештою, ти обрала Єльмслева?" 
        intervals [3]:
            xmin = 40.83072815341812 
            xmax = 55.22399969470437 
            text = "" 
        intervals [4]:
            xmin = 55.22399969470437 
            xmax = 60.72898086391047 
            text = "Так а нашо нам мова без соціуму? Який взагалі сенс в цьому існуванні? І чому-" 
        intervals [5]:
            xmin = 60.72898086391047 
            xmax = 68.66273802129648 
            text = "" 
        intervals [6]:
            xmin = 68.66273802129648 
            xmax = 69.83889032448178 
            text = "А що з ними не так?" 
        intervals [7]:
            xmin = 69.83889032448178 
            xmax = 79.9140957784699 
            text = "От у кого справді немає прогалин в теорії – це у Матезіуса. Між іншим, саме ця школа розвинула вчення про актуальне членування речення." 
        intervals [8]:
            xmin = 79.9140957784699 
            xmax = 83.16526063348846 
            text = "А що крім головного болю нам дав Єльмслев?" 
        intervals [9]:
            xmin = 83.16526063348846 
            xmax = 88.57734021644272 
            text = "" 
        intervals [10]:
            xmin = 88.57734021644272 
            xmax = 92.70149448564945 
            text = "Які до цього досліджував Сосюр. *сарк* Оце великий геній!" 
        intervals [11]:
            xmin = 92.70149448564945 
            xmax = 95.25366977717395 
            text = "" 
        intervals [12]:
            xmin = 95.25366977717395 
            xmax = 101.94145192449122 
            text = "Його компонентний аналіз – це нікому непотрібна маячня. Ти хоч знаєш як його проводить?" 
        intervals [13]:
            xmin = 101.94145192449122 
            xmax = 103.86502988536678 
            text = "" 
        intervals [14]:
            xmin = 103.86502988536678 
            xmax = 104.84947610253244 
            text = "ну от і все." 
        intervals [15]:
            xmin = 104.84947610253244 
            xmax = 117.55282982055898 
            text = "" 
        intervals [16]:
            xmin = 117.55282982055898 
            xmax = 120.1558254621911 
            text = "Ой нічо не знаю, нічо не знаю." 
        intervals [17]:
            xmin = 120.1558254621911 
            xmax = 120.98612244897959 
            text = "" 
