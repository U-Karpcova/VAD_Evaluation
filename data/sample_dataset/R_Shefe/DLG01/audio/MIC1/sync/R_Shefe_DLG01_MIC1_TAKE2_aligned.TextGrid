item []: 
    item [1]:
        class = "IntervalTier" 
        name = "SPK-A-text" 
        xmin = 0 
        xmax = 120.98612244897959 
        intervals: size = 19 
        intervals [1]:
            xmin = 0 
            xmax = 8.195725345792837 
            text = "" 
        intervals [2]:
            xmin = 8.195725345792837 
            xmax = 18.31532120106945 
            text = "*у* От я думала: *пл* лінгвістика – наука не така вже й стара, але й не наймолодша. За час її існування виникло дуже багато підрозділів та течій," 
        intervals [3]:
            xmin = 18.31532120106945 
            xmax = 25.203861155207576 
            text = "але досі ніхто не перевершить внесок *роз* Копенгагенської лінгвістичної школи." 
        intervals [4]:
            xmin = 25.203861155207576 
            xmax = 41.30579411174159 
            text = "" 
        intervals [5]:
            xmin = 41.30579411174159 
            xmax = 52.31163399820632 
            text = "Ну так. У копенгагенців все чітко. Мова – це система, не залежить від соціальних чинників, а лінгвістика – точна та логічна наука." 
        intervals [6]:
            xmin = 52.31163399820632 
            xmax = 55.22399969470437 
            text = "Без всілякої цієї поетичної маячні." 
        intervals [7]:
            xmin = 55.22399969470437 
            xmax = 60.39685855532758 
            text = "" 
        intervals [8]:
            xmin = 60.39685855532758 
            xmax = 68.5342651624121 
            text = "Стривай-стривай-стривай. Це я зараз чую аргументи на користь Празької лінгвістичної школи?" 
        intervals [9]:
            xmin = 68.5342651624121 
            xmax = 83.70861165064187 
            text = "" 
        intervals [10]:
            xmin = 83.70861165064187 
            xmax = 84.20873813701321 
            text = "Ну як це?" 
        intervals [11]:
            xmin = 84.20873813701321 
            xmax = 85.08969488364896 
            text = "" 
        intervals [12]:
            xmin = 85.08969488364896 
            xmax = 88.57734021644272 
            text = "Він досліджував фігури плану вираження і фігури плану змісту." 
        intervals [13]:
            xmin = 88.57734021644272 
            xmax = 93.2539959587398 
            text = "" 
        intervals [14]:
            xmin = 93.2539959587398 
            xmax = 95.32182437641917 
            text = "Ну а як же його компонентний аналіз?" 
        intervals [15]:
            xmin = 95.32182437641917 
            xmax = 102.56128771715439 
            text = "" 
        intervals [16]:
            xmin = 102.56128771715439 
            xmax = 103.86502988536678 
            text = "*роз* ну ні" 
        intervals [17]:
            xmin = 103.86502988536678 
            xmax = 105.60357706874623 
            text = "" 
        intervals [18]:
            xmin = 105.60357706874623 
            xmax = 118.78277274345753 
            text = "Але копенгагенці насправді розвинули цілу теорію, по-новому окреслили предмет дослідження мовознавства, створили нову концепцію все ж таки! А пражці що? Придумали п’ятсот семантичних відтінків слова «стіл»?" 
        intervals [19]:
            xmin = 118.78277274345753 
            xmax = 120.98612244897959 
            text = "" 
