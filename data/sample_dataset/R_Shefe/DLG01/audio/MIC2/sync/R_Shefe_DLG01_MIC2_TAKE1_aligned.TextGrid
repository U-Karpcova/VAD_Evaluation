item []: 
    item [1]:
        class = "IntervalTier" 
        name = "SPK-A-text" 
        xmin = 0 
        xmax = 116.00108843537414 
        intervals: size = 21 
        intervals [1]:
            xmin = 0 
            xmax = 4.365568704158548 
            text = "" 
        intervals [2]:
            xmin = 4.365568704158548 
            xmax = 15.41921550381265 
            text = "*у* От я сиділа й думала: лінгвістика – вона наука не така вже й стара, але й не наймолодша. За час її існування виникло багато всяких підрозділів та течій," 
        intervals [3]:
            xmin = 15.41921550381265 
            xmax = 22.301595424749166 
            text = "але досі ніхто не перевершить внесок Копенгагенської лінгвістичної школи." 
        intervals [4]:
            xmin = 22.301595424749166 
            xmax = 36.994542778435985 
            text = "" 
        intervals [5]:
            xmin = 36.994542778435985 
            xmax = 38.049121298816054 
            text = "Ну *роз* так." 
        intervals [6]:
            xmin = 38.049121298816054 
            xmax = 38.5475179968039 
            text = "" 
        intervals [7]:
            xmin = 38.5475179968039 
            xmax = 47.12744670212024 
            text = "У копенгагенців все чітко. Мова – це система, не залежить від соціальних чинників, а лінгвістика – точна та логічна наука." 
        intervals [8]:
            xmin = 47.12744670212024 
            xmax = 49.876280634538354 
            text = "Без всілякої поетичної маячні." 
        intervals [9]:
            xmin = 49.876280634538354 
            xmax = 54.690894792581645 
            text = "" 
        intervals [10]:
            xmin = 54.690894792581645 
            xmax = 62.83409647613462 
            text = "Стривай-стривай-стривай. Це я зараз чую аргументи на користь *сміх* Празької лінгвістичної школи?" 
        intervals [11]:
            xmin = 62.83409647613462 
            xmax = 77.53726729149878 
            text = "" 
        intervals [12]:
            xmin = 77.53726729149878 
            xmax = 78.1580815473704 
            text = "Ну як це?" 
        intervals [13]:
            xmin = 78.1580815473704 
            xmax = 78.64812501558717 
            text = "" 
        intervals [14]:
            xmin = 78.64812501558717 
            xmax = 82.48475711687382 
            text = "Він досліджував фігури плану вираження і фігури плану змісту." 
        intervals [15]:
            xmin = 82.48475711687382 
            xmax = 88.28476670149226 
            text = "" 
        intervals [16]:
            xmin = 88.28476670149226 
            xmax = 90.34074834057648 
            text = "Ну а як же його компонентний аналіз?" 
        intervals [17]:
            xmin = 90.34074834057648 
            xmax = 96.84596615953272 
            text = "" 
        intervals [18]:
            xmin = 96.84596615953272 
            xmax = 98.70600341046415 
            text = "ні" 
        intervals [19]:
            xmin = 98.70600341046415 
            xmax = 99.14488860450415 
            text = "" 
        intervals [20]:
            xmin = 99.14488860450415 
            xmax = 111.61689982123427 
            text = "Але копенгагенці насправді розвинули цілу теорію, по-новому окреслили предмет дослідження мовознавства, створили нову концепцію врешті-решт! А пражці що? *сарк* Придумали п’ятсот семантичних відтінків слова «стіл»?" 
        intervals [21]:
            xmin = 111.61689982123427 
            xmax = 116.00108843537414 
            text = "" 
