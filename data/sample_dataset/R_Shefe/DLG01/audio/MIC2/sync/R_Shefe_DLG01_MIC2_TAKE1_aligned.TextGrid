    item [3]:
        class = "IntervalTier" 
        name = "SPK-B-text" 
        xmin = 0 
        xmax = 116.00108843537414 
        intervals: size = 15 
        intervals [1]:
            xmin = 0 
            xmax = 22.302342691618183 
            text = "" 
        intervals [2]:
            xmin = 22.302342691618183 
            xmax = 36.35752268925121 
            text = "*у* Почекай-почекай-почекай. З усіх мовознавчих шкіл ти вибрала що? Ну тобто у світі, де є Гумбольдт, молодограматики, дескриптивісти, Ворф та Сепір зрештою, ти обрала Єльмслева?" 
        intervals [3]:
            xmin = 36.35752268925121 
            xmax = 49.876280634538354 
            text = "" 
        intervals [4]:
            xmin = 49.876280634538354 
            xmax = 55.314224576297846 
            text = "Так а нащо нам мова без соціуму? Який взагалі сенс в її існуванні? І чому" 
        intervals [5]:
            xmin = 55.314224576297846 
            xmax = 62.83409647613462 
            text = "" 
        intervals [6]:
            xmin = 62.83409647613462 
            xmax = 64.2255956302117 
            text = "А що з ними не так?" 
        intervals [7]:
            xmin = 64.2255956302117 
            xmax = 74.32440753029711 
            text = "От у кого справді немає прогалин в теорії – це у Матезіуса. Між іншим, саме *об* ві ця школа розвинула вчення про актуальне членування речення." 
        intervals [8]:
            xmin = 74.32440753029711 
            xmax = 77.14321721655608 
            text = "А що крім головного болю нам дав Єльмслев?" 
        intervals [9]:
            xmin = 77.14321721655608 
            xmax = 82.9118773249135 
            text = "" 
        intervals [10]:
            xmin = 82.9118773249135 
            xmax = 87.3944509197629 
            text = "Які до цього досліджував Сосюр. *сарк* Оце великий геній!" 
        intervals [11]:
            xmin = 87.3944509197629 
            xmax = 90.257492912236 
            text = "" 
        intervals [12]:
            xmin = 90.257492912236 
            xmax = 96.21702800200218 
            text = "Його компонентний аналіз – це нікому непотрібна маячня. Ти знаєш як його проводить?" 
        intervals [13]:
            xmin = 96.21702800200218 
            xmax = 111.29560671665634 
            text = "" 
        intervals [14]:
            xmin = 111.29560671665634 
            xmax = 113.51028690510668 
            text = "Ой, нічо не знаю, нічо не знаю." 
        intervals [15]:
            xmin = 113.51028690510668 
            xmax = 116.00108843537414 
            text = "" 
