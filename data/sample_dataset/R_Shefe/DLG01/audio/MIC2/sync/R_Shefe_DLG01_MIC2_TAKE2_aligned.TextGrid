    item [3]:
        class = "IntervalTier" 
        name = "SPK-B-text" 
        xmin = 0 
        xmax = 120.98612244897959 
        intervals: size = 17 
        intervals [1]:
            xmin = 0 
            xmax = 23.284812737905142 
            text = "" 
        intervals [2]:
            xmin = 23.284812737905142 
            xmax = 39.03927553105137 
            text = "*у* Почекай-почекай-почекай-почекай. З усіх мовознавчих шкіл ти вибрала що? Ну тобто у світі, де є Гумбольдт, молодограматики, дескриптивісти, Ворф та Сепір зрештою, ти обрала Єльмслева?" 
        intervals [3]:
            xmin = 39.03927553105137 
            xmax = 53.43254707233762 
            text = "" 
        intervals [4]:
            xmin = 53.43254707233762 
            xmax = 58.937528241543724 
            text = "Так а нашо нам мова без соціуму? Який взагалі сенс в цьому існуванні? І чому-" 
        intervals [5]:
            xmin = 58.937528241543724 
            xmax = 66.87128539892973 
            text = "" 
        intervals [6]:
            xmin = 66.87128539892973 
            xmax = 68.04743770211505 
            text = "А що з ними не так?" 
        intervals [7]:
            xmin = 68.04743770211505 
            xmax = 78.12264315610315 
            text = "От у кого справді немає прогалин в теорії – це у Матезіуса. Між іншим, саме ця школа розвинула вчення про актуальне членування речення." 
        intervals [8]:
            xmin = 78.12264315610315 
            xmax = 81.37380801112172 
            text = "А що крім головного болю нам дав Єльмслев?" 
        intervals [9]:
            xmin = 81.37380801112172 
            xmax = 86.78588759407597 
            text = "" 
        intervals [10]:
            xmin = 86.78588759407597 
            xmax = 90.91004186328271 
            text = "Які до цього досліджував Сосюр. *сарк* Оце великий геній!" 
        intervals [11]:
            xmin = 90.91004186328271 
            xmax = 93.4622171548072 
            text = "" 
        intervals [12]:
            xmin = 93.4622171548072 
            xmax = 100.14999930212448 
            text = "Його компонентний аналіз – це нікому непотрібна маячня. Ти хоч знаєш як його проводить?" 
        intervals [13]:
            xmin = 100.14999930212448 
            xmax = 102.07357726300003 
            text = "" 
        intervals [14]:
            xmin = 102.07357726300003 
            xmax = 103.0580234801657 
            text = "ну от і все." 
        intervals [15]:
            xmin = 103.0580234801657 
            xmax = 115.76137719819224 
            text = "" 
        intervals [16]:
            xmin = 115.76137719819224 
            xmax = 118.36437283982437 
            text = "Ой нічо не знаю, нічо не знаю." 
        intervals [17]:
            xmin = 118.36437283982437 
            xmax = 120.98612244897959 
            text = "" 
