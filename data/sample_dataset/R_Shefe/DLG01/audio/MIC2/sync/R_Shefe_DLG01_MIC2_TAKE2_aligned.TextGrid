item []: 
    item [1]:
        class = "IntervalTier" 
        name = "SPK-A-text" 
        xmin = 0 
        xmax = 120.98612244897959 
        intervals: size = 19 
        intervals [1]:
            xmin = 0 
            xmax = 6.40427272342609 
            text = "" 
        intervals [2]:
            xmin = 6.40427272342609 
            xmax = 16.523868578702704 
            text = "*у* От я думала: *пл* лінгвістика – наука не така вже й стара, але й не наймолодша. За час її існування виникло дуже багато підрозділів та течій," 
        intervals [3]:
            xmin = 16.523868578702704 
            xmax = 23.41240853284083 
            text = "але досі ніхто не перевершить внесок *роз* Копенгагенської лінгвістичної школи." 
        intervals [4]:
            xmin = 23.41240853284083 
            xmax = 39.51434148937484 
            text = "" 
        intervals [5]:
            xmin = 39.51434148937484 
            xmax = 50.52018137583957 
            text = "Ну так. У копенгагенців все чітко. Мова – це система, не залежить від соціальних чинників, а лінгвістика – точна та логічна наука." 
        intervals [6]:
            xmin = 50.52018137583957 
            xmax = 53.43254707233762 
            text = "Без всілякої цієї поетичної маячні." 
        intervals [7]:
            xmin = 53.43254707233762 
            xmax = 58.605405932960835 
            text = "" 
        intervals [8]:
            xmin = 58.605405932960835 
            xmax = 66.74281254004535 
            text = "Стривай-стривай-стривай. Це я зараз чую аргументи на користь Празької лінгвістичної школи?" 
        intervals [9]:
            xmin = 66.74281254004535 
            xmax = 81.91715902827514 
            text = "" 
        intervals [10]:
            xmin = 81.91715902827514 
            xmax = 82.41728551464647 
            text = "Ну як це?" 
        intervals [11]:
            xmin = 82.41728551464647 
            xmax = 83.29824226128221 
            text = "" 
        intervals [12]:
            xmin = 83.29824226128221 
            xmax = 86.78588759407597 
            text = "Він досліджував фігури плану вираження і фігури плану змісту." 
        intervals [13]:
            xmin = 86.78588759407597 
            xmax = 91.46254333637305 
            text = "" 
        intervals [14]:
            xmin = 91.46254333637305 
            xmax = 93.53037175405242 
            text = "Ну а як же його компонентний аналіз?" 
        intervals [15]:
            xmin = 93.53037175405242 
            xmax = 100.76983509478765 
            text = "" 
        intervals [16]:
            xmin = 100.76983509478765 
            xmax = 102.07357726300003 
            text = "*роз* ну ні" 
        intervals [17]:
            xmin = 102.07357726300003 
            xmax = 103.8121244463795 
            text = "" 
        intervals [18]:
            xmin = 103.8121244463795 
            xmax = 116.99132012109078 
            text = "Але копенгагенці насправді розвинули цілу теорію, по-новому окреслили предмет дослідження мовознавства, створили нову концепцію все ж таки! А пражці що? Придумали п’ятсот семантичних відтінків слова «стіл»?" 
        intervals [19]:
            xmin = 116.99132012109078 
            xmax = 120.98612244897959 
            text = "" 
