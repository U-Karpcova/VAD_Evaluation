item []: 
    item [1]:
        class = "IntervalTier" 
        name = "SPK-A-text" 
        xmin = 0 
        xmax = 132.0910657596372 
        intervals: size = 29 
        intervals [1]:
            xmin = 0 
            xmax = 3.668445998513424 
            text = "" 
        intervals [2]:
            xmin = 3.668445998513424 
            xmax = 7.558017927879928 
            text = "*у* Нарешті дописала проєкт зі стилеметрії." 
        intervals [3]:
            xmin = 7.558017927879928 
            xmax = 10.388449447798022 
            text = "Ну це звісно убитись можна з цими ідіостилями." 
        intervals [4]:
            xmin = 10.388449447798022 
            xmax = 18.4129390093376 
            text = "Зате тепер, коли в мене з’явилося трохи часу, подивилася оцей серіал, про який всі говорять – ""Лише друзі""." 
        intervals [5]:
            xmin = 18.4129390093376 
            xmax = 18.686762409671463 
            text = "" 
        intervals [6]:
            xmin = 18.686762409671463 
            xmax = 20.218753652870014 
            text = "Повна туфта." 
        intervals [7]:
            xmin = 20.218753652870014 
            xmax = 22.416029172054916 
            text = "" 
        intervals [8]:
            xmin = 22.416029172054916 
            xmax = 23.435268063235412 
            text = "Зачекай." 
        intervals [9]:
            xmin = 23.435268063235412 
            xmax = 23.698864183734237 
            text = "" 
        intervals [10]:
            xmin = 23.698864183734237 
            xmax = 27.25901414349795 
            text = "В сенсі «класний»? Там же буквально немає сюжету." 
        intervals [11]:
            xmin = 27.25901414349795 
            xmax = 36.12176963532032 
            text = "" 
        intervals [12]:
            xmin = 36.12176963532032 
            xmax = 40.09944298953399 
            text = "Ну стосунки може й складні, але не мають ніякого сенсу." 
        intervals [13]:
            xmin = 40.09944298953399 
            xmax = 45.57994063391634 
            text = "Вибачте, але мене геть не хвилюють страждання багатих підлітків." 
        intervals [14]:
            xmin = 45.57994063391634 
            xmax = 45.84728198242279 
            text = "" 
        intervals [15]:
            xmin = 45.84728198242279 
            xmax = 53.583472254828365 
            text = "*сарк* «Моя мама була алкоголічка, померла, бо спилась, і я тепер теж буду пити, бо мене ніхто не любить»," 
        intervals [16]:
            xmin = 53.583472254828365 
            xmax = 61.029722126763524 
            text = "- каже чувак і витирає сльози пачкою купюр. Дуже на часі, *сміх* нічого не скажеш. Ледь стримую сльози." 
        intervals [17]:
            xmin = 61.029722126763524 
            xmax = 69.65483926439758 
            text = "" 
        intervals [18]:
            xmin = 69.65483926439758 
            xmax = 74.07222567798316 
            text = "І я це навіть не згадала про те, що він заподіяв М’ю." 
        intervals [19]:
            xmin = 74.07222567798316 
            xmax = 81.80407867248994 
            text = "" 
        intervals [20]:
            xmin = 81.80407867248994 
            xmax = 83.01851100899877 
            text = "*цок* Ну звісно." 
        intervals [21]:
            xmin = 83.01851100899877 
            xmax = 92.07680258838278 
            text = "" 
        intervals [22]:
            xmin = 92.07680258838278 
            xmax = 103.73545462661492 
            text = "Альо. У Вегаса принаймні була тіпа якась мотивація? Він – син мафії, усе його життя – це буквально межова ситуація, крок вліво – куля, крок вправо – ґрати, а" 
        intervals [23]:
            xmin = 103.73545462661492 
            xmax = 106.62024194680482 
            text = "" 
        intervals [24]:
            xmin = 106.62024194680482 
            xmax = 111.67841389650002 
            text = "Так його його батько бив! І тиснув на нього постійно! То що ти від нього хочеш тепер?" 
        intervals [25]:
            xmin = 111.67841389650002 
            xmax = 118.79671024909857 
            text = "" 
        intervals [26]:
            xmin = 118.79671024909857 
            xmax = 119.58986724215778 
            text = "Ну то й шо?" 
        intervals [27]:
            xmin = 119.58986724215778 
            xmax = 126.47516735611742 
            text = "" 
        intervals [28]:
            xmin = 126.47516735611742 
            xmax = 128.3379693892109 
            text = "*сміх* Ой все, почалось." 
        intervals [29]:
            xmin = 128.3379693892109 
            xmax = 132.0910657596372 
            text = "" 
