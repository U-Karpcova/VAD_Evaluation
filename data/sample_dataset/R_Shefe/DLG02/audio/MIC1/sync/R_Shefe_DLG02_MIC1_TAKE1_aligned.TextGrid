    item [3]:
        class = "IntervalTier" 
        name = "SPK-B-text" 
        xmin = 0 
        xmax = 132.0910657596372 
        intervals: size = 23 
        intervals [1]:
            xmin = 0 
            xmax = 18.0265472165745 
            text = "" 
        intervals [2]:
            xmin = 18.0265472165745 
            xmax = 20.218753652870014 
            text = "*у* *роз* О такий" 
        intervals [3]:
            xmin = 20.218753652870014 
            xmax = 22.04425760928826 
            text = "класний серіал." 
        intervals [4]:
            xmin = 22.04425760928826 
            xmax = 28.13709183836468 
            text = "" 
        intervals [5]:
            xmin = 28.13709183836468 
            xmax = 35.7279437719288 
            text = "В сенсі «немає сюжету»? Там такі перипетії, складні стосунки між персонажами! Не розумію, про що ти говориш." 
        intervals [6]:
            xmin = 35.7279437719288 
            xmax = 49.04679614460398 
            text = "" 
        intervals [7]:
            xmin = 49.04679614460398 
            xmax = 50.931450986058806 
            text = "Там так не було!" 
        intervals [8]:
            xmin = 50.931450986058806 
            xmax = 61.186247664881215 
            text = "" 
        intervals [9]:
            xmin = 61.186247664881215 
            xmax = 70.16445870998801 
            text = "Там не так все було! Рей просто загубився на життєвому шляху, йому взагалі-то не просто! Як ти можеш просто так" 
        intervals [10]:
            xmin = 70.16445870998801 
            xmax = 73.77062720103551 
            text = "" 
        intervals [11]:
            xmin = 73.77062720103551 
            xmax = 76.47103548175271 
            text = "*роз* Ну так, він винний." 
        intervals [12]:
            xmin = 76.47103548175271 
            xmax = 82.33480745708248 
            text = "Але і що? *м-м* Всі не без гріха. Ми всі помиляємось. Чого зразу здіймати ґвалт?" 
        intervals [13]:
            xmin = 82.33480745708248 
            xmax = 83.36972858703795 
            text = "" 
        intervals [14]:
            xmin = 83.36972858703795 
            xmax = 91.37748936633142 
            text = "А взагалі, я вважаю, *сміх* людина, якій подобається *сміх* Вегас з «Кіннпорша», не *роз* може *вд* так казати про Рея." 
        intervals [15]:
            xmin = 91.37748936633142 
            xmax = 103.16548611853722 
            text = "" 
        intervals [16]:
            xmin = 103.16548611853722 
            xmax = 106.05273666378977 
            text = "Він буквально катував людей." 
        intervals [17]:
            xmin = 106.05273666378977 
            xmax = 111.04097595773325 
            text = "" 
        intervals [18]:
            xmin = 111.04097595773325 
            xmax = 118.50799568084673 
            text = "А нічо шо той факт, шо у Рея мама померла, *пскл* мама! *сміх* Це тебе не хвилює?" 
        intervals [19]:
            xmin = 118.50799568084673 
            xmax = 119.78980235293092 
            text = "" 
        intervals [20]:
            xmin = 119.78980235293092 
            xmax = 122.53375712695286 
            text = "В сенсі ""то й шо?"" Ти взагалі розумієш, шо говориш?" 
        intervals [21]:
            xmin = 122.53375712695286 
            xmax = 122.89585053682772 
            text = "" 
        intervals [22]:
            xmin = 122.89585053682772 
            xmax = 126.07514035092234 
            text = "І це ти мені кажеш про співчуття до нужденних." 
        intervals [23]:
            xmin = 126.07514035092234 
            xmax = 132.0910657596372 
            text = "" 
