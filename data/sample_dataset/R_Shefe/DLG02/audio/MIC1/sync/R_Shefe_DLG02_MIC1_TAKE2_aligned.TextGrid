    item [3]:
        class = "IntervalTier" 
        name = "SPK-B-text" 
        xmin = 0 
        xmax = 128.84462585034012 
        intervals: size = 24 
        intervals [1]:
            xmin = 0 
            xmax = 19.154232451626502 
            text = "" 
        intervals [2]:
            xmin = 19.154232451626502 
            xmax = 20.823283842963175 
            text = "*у* Блін, такий класний серіал." 
        intervals [3]:
            xmin = 20.823283842963175 
            xmax = 28.05816371060422 
            text = "" 
        intervals [4]:
            xmin = 28.05816371060422 
            xmax = 29.26386836482436 
            text = "В сенсі «немає сюжету»?" 
        intervals [5]:
            xmin = 29.26386836482436 
            xmax = 29.578079567258246 
            text = "" 
        intervals [6]:
            xmin = 29.578079567258246 
            xmax = 36.52090311302896 
            text = "Там такі перипетії, такі складні стосунки між персонажами! Не розумію, про що ти говориш." 
        intervals [7]:
            xmin = 36.52090311302896 
            xmax = 48.679345822321714 
            text = "" 
        intervals [8]:
            xmin = 48.679345822321714 
            xmax = 50.701478208096376 
            text = "*вд* Там не так було!" 
        intervals [9]:
            xmin = 50.701478208096376 
            xmax = 60.34765367232987 
            text = "" 
        intervals [10]:
            xmin = 60.34765367232987 
            xmax = 70.85825511931039 
            text = "Так там не так було! Рей просто загубився на життєвому шляху. Ти не розумієш, йому взагалі-то не просто! Як ти можеш так просто" 
        intervals [11]:
            xmin = 70.85825511931039 
            xmax = 74.87415633946546 
            text = "" 
        intervals [12]:
            xmin = 74.87415633946546 
            xmax = 77.63171860408004 
            text = "*роз* Ну так, він тут винний." 
        intervals [13]:
            xmin = 77.63171860408004 
            xmax = 81.21702040040454 
            text = "Але то й що? Всі не без гріха. Ми всі помиляємось." 
        intervals [14]:
            xmin = 81.21702040040454 
            xmax = 82.82665460356014 
            text = "" 
        intervals [15]:
            xmin = 82.82665460356014 
            xmax = 92.03397968916606 
            text = "А взагалі, я вважаю, шо людина, якій подобається Вєгас з «Кіннпорша», *роз* не має права шось говорити про Рея. *м-м* І скаржитись взагалі." 
        intervals [16]:
            xmin = 92.03397968916606 
            xmax = 101.42481859874388 
            text = "" 
        intervals [17]:
            xmin = 101.42481859874388 
            xmax = 105.46904389366455 
            text = "Да-да-да. Він буквально катував людей." 
        intervals [18]:
            xmin = 105.46904389366455 
            xmax = 110.29451090233654 
            text = "" 
        intervals [19]:
            xmin = 110.29451090233654 
            xmax = 116.33270602557668 
            text = "А нічо шо той факт, шо у Рея мама померла, *пскл* мама! Це тебе не хвилює?" 
        intervals [20]:
            xmin = 116.33270602557668 
            xmax = 117.4967135224299 
            text = "" 
        intervals [21]:
            xmin = 117.4967135224299 
            xmax = 118.58163710524161 
            text = "В сенсі то й шо?" 
        intervals [22]:
            xmin = 118.58163710524161 
            xmax = 120.56272020793419 
            text = "Ти взагалі розумієш, шо говориш?" 
        intervals [23]:
            xmin = 120.56272020793419 
            xmax = 124.11280609412539 
            text = "І це ти мені кажеш про співчуття нужденних." 
        intervals [24]:
            xmin = 124.11280609412539 
            xmax = 128.84462585034012 
            text = "" 
