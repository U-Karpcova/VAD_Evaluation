item []: 
    item [1]:
        class = "IntervalTier" 
        name = "SPK-A-text" 
        xmin = 0 
        xmax = 128.84462585034012 
        intervals: size = 32 
        intervals [1]:
            xmin = 0 
            xmax = 4.811590458138257 
            text = "" 
        intervals [2]:
            xmin = 4.811590458138257 
            xmax = 8.319850426726136 
            text = "*у* Нарешті дописала проєкт зі стилеметрії!" 
        intervals [3]:
            xmin = 8.319850426726136 
            xmax = 11.241878916423325 
            text = "Це звісно убитись можна з цими ідіостилями." 
        intervals [4]:
            xmin = 11.241878916423325 
            xmax = 11.983781017212753 
            text = "" 
        intervals [5]:
            xmin = 11.983781017212753 
            xmax = 19.625136148680753 
            text = "Зате тепер, коли в мене з’явилося трохи часу, подивилася серіал оцей, про який зараз всі говорять – ""Лише друзі"" називається.n" 
        intervals [6]:
            xmin = 19.625136148680753 
            xmax = 20.45415753310849 
            text = "" 
        intervals [7]:
            xmin = 20.45415753310849 
            xmax = 21.541869896983563 
            text = "Тупо туфта." 
        intervals [8]:
            xmin = 21.541869896983563 
            xmax = 22.24731483497797 
            text = "" 
        intervals [9]:
            xmin = 22.24731483497797 
            xmax = 23.412937037555277 
            text = "Зачекай." 
        intervals [10]:
            xmin = 23.412937037555277 
            xmax = 23.602192747055977 
            text = "" 
        intervals [11]:
            xmin = 23.602192747055977 
            xmax = 27.125665948542373 
            text = "В сенсі «класний»? Там же буквально немає сюжету." 
        intervals [12]:
            xmin = 27.125665948542373 
            xmax = 37.13602192731589 
            text = "" 
        intervals [13]:
            xmin = 37.13602192731589 
            xmax = 46.024635242888614 
            text = "Ну стосунки може й складні, *сміх* але не мають ніякого сенсу. *сміх* Вибачте, але мене геть не хвилюють страждання багатих підлітків." 
        intervals [14]:
            xmin = 46.024635242888614 
            xmax = 46.52888517093044 
            text = "" 
        intervals [15]:
            xmin = 46.52888517093044 
            xmax = 53.06604677094215 
            text = "«Моя мама була алкоголічка, померла, бо спилась, і я тепер теж буду пити, бо мене ніхто не любить»," 
        intervals [16]:
            xmin = 53.06604677094215 
            xmax = 59.973302451992005 
            text = "- каже чувак і витирає сльози пачкою купюр. Дуже на часі, *сміх* нічого не скажеш. *сміх* Ледь стримую сльози." 
        intervals [17]:
            xmin = 59.973302451992005 
            xmax = 70.09980433826965 
            text = "" 
        intervals [18]:
            xmin = 70.09980433826965 
            xmax = 74.19729445369134 
            text = "І це я навіть не згадую про те, що він заподіяв М’ю." 
        intervals [19]:
            xmin = 74.19729445369134 
            xmax = 80.94661998510917 
            text = "" 
        intervals [20]:
            xmin = 80.94661998510917 
            xmax = 81.15912027694333 
            text = "*цок*" 
        intervals [21]:
            xmin = 81.15912027694333 
            xmax = 81.26878936319932 
            text = "" 
        intervals [22]:
            xmin = 81.26878936319932 
            xmax = 82.68779302671801 
            text = "Ну звісно-звісно." 
        intervals [23]:
            xmin = 82.68779302671801 
            xmax = 92.25279187085668 
            text = "" 
        intervals [24]:
            xmin = 92.25279187085668 
            xmax = 96.67712523220203 
            text = "Альо. У Вегаса принаймні була якась мотивація?" 
        intervals [25]:
            xmin = 96.67712523220203 
            xmax = 103.29181731934115 
            text = "Він – син мафії, усе його життя – це буквально межова ситуація, крок вліво – куля, крок вправо – ґрати." 
        intervals [26]:
            xmin = 103.29181731934115 
            xmax = 105.73293227871683 
            text = "" 
        intervals [27]:
            xmin = 105.73293227871683 
            xmax = 110.73759635670714 
            text = "Так його батько його бив! І тиснув на нього постійно! То що ти від нього хочеш?" 
        intervals [28]:
            xmin = 110.73759635670714 
            xmax = 116.46471304121877 
            text = "" 
        intervals [29]:
            xmin = 116.46471304121877 
            xmax = 117.39086731922876 
            text = "Ну то й шо?" 
        intervals [30]:
            xmin = 117.39086731922876 
            xmax = 123.31020333268002 
            text = "" 
        intervals [31]:
            xmin = 123.31020333268002 
            xmax = 125.23691931848896 
            text = "О боже, почалось." 
        intervals [32]:
            xmin = 125.23691931848896 
            xmax = 128.84462585034012 
            text = "" 
