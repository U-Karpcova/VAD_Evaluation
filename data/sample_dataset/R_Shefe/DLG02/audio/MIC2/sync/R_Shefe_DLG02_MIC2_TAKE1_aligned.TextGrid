item []: 
    item [1]:
        class = "IntervalTier" 
        name = "SPK-A-text" 
        xmin = 0 
        xmax = 132.0910657596372 
        intervals: size = 29 
        intervals [1]:
            xmin = 0 
            xmax = 3.7791117210467955 
            text = "" 
        intervals [2]:
            xmin = 3.7791117210467955 
            xmax = 7.6686836504133 
            text = "*у* Нарешті дописала проєкт зі стилеметрії." 
        intervals [3]:
            xmin = 7.6686836504133 
            xmax = 10.499115170331395 
            text = "Ну це звісно убитись можна з цими ідіостилями." 
        intervals [4]:
            xmin = 10.499115170331395 
            xmax = 18.52360473187097 
            text = "Зате тепер, коли в мене з’явилося трохи часу, подивилася оцей серіал, про який всі говорять – ""Лише друзі""." 
        intervals [5]:
            xmin = 18.52360473187097 
            xmax = 18.797428132204836 
            text = "" 
        intervals [6]:
            xmin = 18.797428132204836 
            xmax = 20.329419375403386 
            text = "Повна туфта." 
        intervals [7]:
            xmin = 20.329419375403386 
            xmax = 22.52669489458829 
            text = "" 
        intervals [8]:
            xmin = 22.52669489458829 
            xmax = 23.545933785768785 
            text = "Зачекай." 
        intervals [9]:
            xmin = 23.545933785768785 
            xmax = 23.80952990626761 
            text = "" 
        intervals [10]:
            xmin = 23.80952990626761 
            xmax = 27.369679866031323 
            text = "В сенсі «класний»? Там же буквально немає сюжету." 
        intervals [11]:
            xmin = 27.369679866031323 
            xmax = 36.23243535785369 
            text = "" 
        intervals [12]:
            xmin = 36.23243535785369 
            xmax = 40.21010871206736 
            text = "Ну стосунки може й складні, але не мають ніякого сенсу." 
        intervals [13]:
            xmin = 40.21010871206736 
            xmax = 45.690606356449706 
            text = "Вибачте, але мене геть не хвилюють страждання багатих підлітків." 
        intervals [14]:
            xmin = 45.690606356449706 
            xmax = 45.95794770495616 
            text = "" 
        intervals [15]:
            xmin = 45.95794770495616 
            xmax = 53.694137977361734 
            text = "*сарк* «Моя мама була алкоголічка, померла, бо спилась, і я тепер теж буду пити, бо мене ніхто не любить»," 
        intervals [16]:
            xmin = 53.694137977361734 
            xmax = 61.14038784929689 
            text = "- каже чувак і витирає сльози пачкою купюр. Дуже на часі, *сміх* нічого не скажеш. Ледь стримую сльози." 
        intervals [17]:
            xmin = 61.14038784929689 
            xmax = 69.76550498693095 
            text = "" 
        intervals [18]:
            xmin = 69.76550498693095 
            xmax = 74.18289140051652 
            text = "І я це навіть не згадала про те, що він заподіяв М’ю." 
        intervals [19]:
            xmin = 74.18289140051652 
            xmax = 81.9147443950233 
            text = "" 
        intervals [20]:
            xmin = 81.9147443950233 
            xmax = 83.12917673153214 
            text = "*цок* Ну звісно." 
        intervals [21]:
            xmin = 83.12917673153214 
            xmax = 92.18746831091615 
            text = "" 
        intervals [22]:
            xmin = 92.18746831091615 
            xmax = 103.8461203491483 
            text = "Альо. У Вегаса принаймні була тіпа якась мотивація? Він – син мафії, усе його життя – це буквально межова ситуація, крок вліво – куля, крок вправо – ґрати, а" 
        intervals [23]:
            xmin = 103.8461203491483 
            xmax = 106.7309076693382 
            text = "" 
        intervals [24]:
            xmin = 106.7309076693382 
            xmax = 111.78907961903339 
            text = "Так його його батько бив! І тиснув на нього постійно! То що ти від нього хочеш тепер?" 
        intervals [25]:
            xmin = 111.78907961903339 
            xmax = 118.90737597163194 
            text = "" 
        intervals [26]:
            xmin = 118.90737597163194 
            xmax = 119.70053296469115 
            text = "Ну то й шо?" 
        intervals [27]:
            xmin = 119.70053296469115 
            xmax = 126.5858330786508 
            text = "" 
        intervals [28]:
            xmin = 126.5858330786508 
            xmax = 128.4486351117443 
            text = "*сміх* Ой все, почалось." 
        intervals [29]:
            xmin = 128.4486351117443 
            xmax = 132.0910657596372 
            text = "" 
