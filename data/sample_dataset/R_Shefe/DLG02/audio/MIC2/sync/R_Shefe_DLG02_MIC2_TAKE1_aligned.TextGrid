    item [3]:
        class = "IntervalTier" 
        name = "SPK-B-text" 
        xmin = 0 
        xmax = 132.0910657596372 
        intervals: size = 23 
        intervals [1]:
            xmin = 0 
            xmax = 18.137212939107872 
            text = "" 
        intervals [2]:
            xmin = 18.137212939107872 
            xmax = 20.329419375403386 
            text = "*у* *роз* О такий" 
        intervals [3]:
            xmin = 20.329419375403386 
            xmax = 22.15492333182163 
            text = "класний серіал." 
        intervals [4]:
            xmin = 22.15492333182163 
            xmax = 28.24775756089805 
            text = "" 
        intervals [5]:
            xmin = 28.24775756089805 
            xmax = 35.83860949446217 
            text = "В сенсі «немає сюжету»? Там такі перипетії, складні стосунки між персонажами! Не розумію, про що ти говориш." 
        intervals [6]:
            xmin = 35.83860949446217 
            xmax = 49.15746186713735 
            text = "" 
        intervals [7]:
            xmin = 49.15746186713735 
            xmax = 51.042116708592175 
            text = "Там так не було!" 
        intervals [8]:
            xmin = 51.042116708592175 
            xmax = 61.296913387414584 
            text = "" 
        intervals [9]:
            xmin = 61.296913387414584 
            xmax = 70.27512443252138 
            text = "Там не так все було! Рей просто загубився на життєвому шляху, йому взагалі-то не просто! Як ти можеш просто так" 
        intervals [10]:
            xmin = 70.27512443252138 
            xmax = 73.88129292356888 
            text = "" 
        intervals [11]:
            xmin = 73.88129292356888 
            xmax = 76.58170120428608 
            text = "*роз* Ну так, він винний." 
        intervals [12]:
            xmin = 76.58170120428608 
            xmax = 82.44547317961585 
            text = "Але і що? *м-м* Всі не без гріха. Ми всі помиляємось. Чого зразу здіймати ґвалт?" 
        intervals [13]:
            xmin = 82.44547317961585 
            xmax = 83.48039430957132 
            text = "" 
        intervals [14]:
            xmin = 83.48039430957132 
            xmax = 91.48815508886479 
            text = "А взагалі, я вважаю, *сміх* людина, якій подобається *сміх* Вегас з «Кіннпорша», не *роз* може *вд* так казати про Рея." 
        intervals [15]:
            xmin = 91.48815508886479 
            xmax = 103.27615184107059 
            text = "" 
        intervals [16]:
            xmin = 103.27615184107059 
            xmax = 106.16340238632314 
            text = "Він буквально катував людей." 
        intervals [17]:
            xmin = 106.16340238632314 
            xmax = 111.15164168026662 
            text = "" 
        intervals [18]:
            xmin = 111.15164168026662 
            xmax = 118.6186614033801 
            text = "А нічо шо той факт, шо у Рея мама померла, *пскл* мама! *сміх* Це тебе не хвилює?" 
        intervals [19]:
            xmin = 118.6186614033801 
            xmax = 119.90046807546429 
            text = "" 
        intervals [20]:
            xmin = 119.90046807546429 
            xmax = 122.64442284948623 
            text = "В сенсі ""то й шо?"" Ти взагалі розумієш, шо говориш?" 
        intervals [21]:
            xmin = 122.64442284948623 
            xmax = 123.00651625936109 
            text = "" 
        intervals [22]:
            xmin = 123.00651625936109 
            xmax = 126.18580607345571 
            text = "І це ти мені кажеш про співчуття до нужденних." 
        intervals [23]:
            xmin = 126.18580607345571 
            xmax = 132.0910657596372 
            text = "" 
