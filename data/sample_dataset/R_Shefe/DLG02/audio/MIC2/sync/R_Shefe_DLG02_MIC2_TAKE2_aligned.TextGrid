    item [3]:
        class = "IntervalTier" 
        name = "SPK-B-text" 
        xmin = 0 
        xmax = 128.84462585034012 
        intervals: size = 24 
        intervals [1]:
            xmin = 0 
            xmax = 17.022407594011796 
            text = "" 
        intervals [2]:
            xmin = 17.022407594011796 
            xmax = 18.69145898534847 
            text = "*у* Блін, такий класний серіал." 
        intervals [3]:
            xmin = 18.69145898534847 
            xmax = 25.926338852989513 
            text = "" 
        intervals [4]:
            xmin = 25.926338852989513 
            xmax = 27.132043507209655 
            text = "В сенсі «немає сюжету»?" 
        intervals [5]:
            xmin = 27.132043507209655 
            xmax = 27.44625470964354 
            text = "" 
        intervals [6]:
            xmin = 27.44625470964354 
            xmax = 34.38907825541425 
            text = "Там такі перипетії, такі складні стосунки між персонажами! Не розумію, про що ти говориш." 
        intervals [7]:
            xmin = 34.38907825541425 
            xmax = 46.547520964707005 
            text = "" 
        intervals [8]:
            xmin = 46.547520964707005 
            xmax = 48.569653350481666 
            text = "*вд* Там не так було!" 
        intervals [9]:
            xmin = 48.569653350481666 
            xmax = 58.21582881471516 
            text = "" 
        intervals [10]:
            xmin = 58.21582881471516 
            xmax = 68.72643026169568 
            text = "Так там не так було! Рей просто загубився на життєвому шляху. Ти не розумієш, йому взагалі-то не просто! Як ти можеш так просто" 
        intervals [11]:
            xmin = 68.72643026169568 
            xmax = 72.74233148185075 
            text = "" 
        intervals [12]:
            xmin = 72.74233148185075 
            xmax = 75.49989374646533 
            text = "*роз* Ну так, він тут винний." 
        intervals [13]:
            xmin = 75.49989374646533 
            xmax = 79.08519554278983 
            text = "Але то й що? Всі не без гріха. Ми всі помиляємось." 
        intervals [14]:
            xmin = 79.08519554278983 
            xmax = 80.69482974594544 
            text = "" 
        intervals [15]:
            xmin = 80.69482974594544 
            xmax = 89.90215483155136 
            text = "А взагалі, я вважаю, шо людина, якій подобається Вєгас з «Кіннпорша», *роз* не має права шось говорити про Рея. *м-м* І скаржитись взагалі." 
        intervals [16]:
            xmin = 89.90215483155136 
            xmax = 99.29299374112918 
            text = "" 
        intervals [17]:
            xmin = 99.29299374112918 
            xmax = 103.33721903604985 
            text = "Да-да-да. Він буквально катував людей." 
        intervals [18]:
            xmin = 103.33721903604985 
            xmax = 108.16268604472184 
            text = "" 
        intervals [19]:
            xmin = 108.16268604472184 
            xmax = 114.20088116796198 
            text = "А нічо шо той факт, шо у Рея мама померла, *пскл* мама! Це тебе не хвилює?" 
        intervals [20]:
            xmin = 114.20088116796198 
            xmax = 115.3648886648152 
            text = "" 
        intervals [21]:
            xmin = 115.3648886648152 
            xmax = 116.44981224762691 
            text = "В сенсі то й шо?" 
        intervals [22]:
            xmin = 116.44981224762691 
            xmax = 118.43089535031949 
            text = "Ти взагалі розумієш, шо говориш?" 
        intervals [23]:
            xmin = 118.43089535031949 
            xmax = 121.98098123651069 
            text = "І це ти мені кажеш про співчуття нужденних." 
        intervals [24]:
            xmin = 121.98098123651069 
            xmax = 128.84462585034012 
            text = "" 
