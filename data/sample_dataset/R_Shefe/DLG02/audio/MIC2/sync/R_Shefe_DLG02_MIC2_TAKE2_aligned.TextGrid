item []: 
    item [1]:
        class = "IntervalTier" 
        name = "SPK-A-text" 
        xmin = 0 
        xmax = 128.84462585034012 
        intervals: size = 32 
        intervals [1]:
            xmin = 0 
            xmax = 2.6797656005235506 
            text = "" 
        intervals [2]:
            xmin = 2.6797656005235506 
            xmax = 6.1880255691114305 
            text = "*у* Нарешті дописала проєкт зі стилеметрії!" 
        intervals [3]:
            xmin = 6.1880255691114305 
            xmax = 9.110054058808618 
            text = "Це звісно убитись можна з цими ідіостилями." 
        intervals [4]:
            xmin = 9.110054058808618 
            xmax = 9.851956159598046 
            text = "" 
        intervals [5]:
            xmin = 9.851956159598046 
            xmax = 17.493311291066046 
            text = "Зате тепер, коли в мене з’явилося трохи часу, подивилася серіал оцей, про який зараз всі говорять – ""Лише друзі"" називається.n" 
        intervals [6]:
            xmin = 17.493311291066046 
            xmax = 18.322332675493783 
            text = "" 
        intervals [7]:
            xmin = 18.322332675493783 
            xmax = 19.410045039368857 
            text = "Тупо туфта." 
        intervals [8]:
            xmin = 19.410045039368857 
            xmax = 20.115489977363264 
            text = "" 
        intervals [9]:
            xmin = 20.115489977363264 
            xmax = 21.28111217994057 
            text = "Зачекай." 
        intervals [10]:
            xmin = 21.28111217994057 
            xmax = 21.47036788944127 
            text = "" 
        intervals [11]:
            xmin = 21.47036788944127 
            xmax = 24.993841090927667 
            text = "В сенсі «класний»? Там же буквально немає сюжету." 
        intervals [12]:
            xmin = 24.993841090927667 
            xmax = 35.00419706970118 
            text = "" 
        intervals [13]:
            xmin = 35.00419706970118 
            xmax = 43.892810385273904 
            text = "Ну стосунки може й складні, *сміх* але не мають ніякого сенсу. *сміх* Вибачте, але мене геть не хвилюють страждання багатих підлітків." 
        intervals [14]:
            xmin = 43.892810385273904 
            xmax = 44.39706031331573 
            text = "" 
        intervals [15]:
            xmin = 44.39706031331573 
            xmax = 50.93422191332744 
            text = "«Моя мама була алкоголічка, померла, бо спилась, і я тепер теж буду пити, бо мене ніхто не любить»," 
        intervals [16]:
            xmin = 50.93422191332744 
            xmax = 57.841477594377295 
            text = "- каже чувак і витирає сльози пачкою купюр. Дуже на часі, *сміх* нічого не скажеш. *сміх* Ледь стримую сльози." 
        intervals [17]:
            xmin = 57.841477594377295 
            xmax = 67.96797948065495 
            text = "" 
        intervals [18]:
            xmin = 67.96797948065495 
            xmax = 72.06546959607664 
            text = "І це я навіть не згадую про те, що він заподіяв М’ю." 
        intervals [19]:
            xmin = 72.06546959607664 
            xmax = 78.81479512749446 
            text = "" 
        intervals [20]:
            xmin = 78.81479512749446 
            xmax = 79.02729541932862 
            text = "*цок*" 
        intervals [21]:
            xmin = 79.02729541932862 
            xmax = 79.13696450558461 
            text = "" 
        intervals [22]:
            xmin = 79.13696450558461 
            xmax = 80.55596816910331 
            text = "Ну звісно-звісно." 
        intervals [23]:
            xmin = 80.55596816910331 
            xmax = 90.12096701324198 
            text = "" 
        intervals [24]:
            xmin = 90.12096701324198 
            xmax = 94.54530037458733 
            text = "Альо. У Вегаса принаймні була якась мотивація?" 
        intervals [25]:
            xmin = 94.54530037458733 
            xmax = 101.15999246172645 
            text = "Він – син мафії, усе його життя – це буквально межова ситуація, крок вліво – куля, крок вправо – ґрати." 
        intervals [26]:
            xmin = 101.15999246172645 
            xmax = 103.60110742110213 
            text = "" 
        intervals [27]:
            xmin = 103.60110742110213 
            xmax = 108.60577149909244 
            text = "Так його батько його бив! І тиснув на нього постійно! То що ти від нього хочеш?" 
        intervals [28]:
            xmin = 108.60577149909244 
            xmax = 114.33288818360407 
            text = "" 
        intervals [29]:
            xmin = 114.33288818360407 
            xmax = 115.25904246161406 
            text = "Ну то й шо?" 
        intervals [30]:
            xmin = 115.25904246161406 
            xmax = 121.17837847506532 
            text = "" 
        intervals [31]:
            xmin = 121.17837847506532 
            xmax = 123.10509446087426 
            text = "О боже, почалось." 
        intervals [32]:
            xmin = 123.10509446087426 
            xmax = 128.84462585034012 
            text = "" 
