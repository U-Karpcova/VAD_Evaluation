    item [3]:
        class = "IntervalTier" 
        name = "SPK-B-text" 
        xmin = 0 
        xmax = 135.75256235827663 
        intervals: size = 23 
        intervals [1]:
            xmin = 0 
            xmax = 3.7751068934320258 
            text = "" 
        intervals [2]:
            xmin = 3.7751068934320258 
            xmax = 8.031822653350577 
            text = "*у* Це шо ви мені таке продали вчора? Ви взагалі дивилися, шо кладете в пакет?" 
        intervals [3]:
            xmin = 8.031822653350577 
            xmax = 14.778439252763283 
            text = "" 
        intervals [4]:
            xmin = 14.778439252763283 
            xmax = 15.807054379384068 
            text = "Свіжий?" 
        intervals [5]:
            xmin = 15.807054379384068 
            xmax = 21.442755946519952 
            text = "Половина картоплі, шо ви мені продали, гнила! Вона смердить, її неможливо їсти." 
        intervals [6]:
            xmin = 21.442755946519952 
            xmax = 32.7630399510857 
            text = "" 
        intervals [7]:
            xmin = 32.7630399510857 
            xmax = 39.15217878393639 
            text = "*гкхм* Серйозно? Я винна, шо ви мені гниль продали? Це вже занадто." 
        intervals [8]:
            xmin = 39.15217878393639 
            xmax = 44.74731915545695 
            text = "" 
        intervals [9]:
            xmin = 44.74731915545695 
            xmax = 51.76017295491351 
            text = "Не перекладайте на мене відповідальність. Я заплатила гроші за нормальний продукт, а ви продали мені казна-що." 
        intervals [10]:
            xmin = 51.76017295491351 
            xmax = 55.435536926152615 
            text = "" 
        intervals [11]:
            xmin = 55.435536926152615 
            xmax = 57.68245161742888 
            text = "Бо, мабуть, інші просто мовчать." 
        intervals [12]:
            xmin = 57.68245161742888 
            xmax = 60.309025713065424 
            text = "А я мовчати не буду, я вас дістану!" 
        intervals [13]:
            xmin = 60.309025713065424 
            xmax = 68.16827914096608 
            text = "" 
        intervals [14]:
            xmin = 68.16827914096608 
            xmax = 73.2167531496351 
            text = "Якшо треба — влаштую. І скаргу напишу на ваш ларьок смердючий!" 
        intervals [15]:
            xmin = 73.2167531496351 
            xmax = 80.21124268925459 
            text = "" 
        intervals [16]:
            xmin = 80.21124268925459 
            xmax = 84.11129425180489 
            text = "*сарк* Бачу я, як ви йдете назустріч. Ви навіть не вибачились." 
        intervals [17]:
            xmin = 84.11129425180489 
            xmax = 96.23892455898932 
            text = "" 
        intervals [18]:
            xmin = 96.23892455898932 
            xmax = 99.57284641047177 
            text = "На чорта мені ваш буряк? *сміх* Поверніть мені гроші." 
        intervals [19]:
            xmin = 99.57284641047177 
            xmax = 108.13130205657983 
            text = "" 
        intervals [20]:
            xmin = 108.13130205657983 
            xmax = 111.00030538718937 
            text = "Та який в біса буряк? Ви показилися чи шо?" 
        intervals [21]:
            xmin = 111.00030538718937 
            xmax = 127.01798075471292 
            text = "" 
        intervals [22]:
            xmin = 127.01798075471292 
            xmax = 131.62141299062745 
            text = "Не потрібно мені ваш буряк. Все. До побачення." 
        intervals [23]:
            xmin = 131.62141299062745 
            xmax = 135.75256235827663 
            text = "" 
