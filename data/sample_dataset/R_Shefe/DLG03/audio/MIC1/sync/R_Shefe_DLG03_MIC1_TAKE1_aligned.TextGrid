item []: 
    item [1]:
        class = "IntervalTier" 
        name = "SPK-A-text" 
        xmin = 0 
        xmax = 135.75256235827663 
        intervals: size = 31 
        intervals [1]:
            xmin = 0 
            xmax = 8.64849409896204 
            text = "" 
        intervals [2]:
            xmin = 8.64849409896204 
            xmax = 9.63699809209868 
            text = "*у* *сміх* Доброго дня." 
        intervals [3]:
            xmin = 9.63699809209868 
            xmax = 9.887671353516106 
            text = "" 
        intervals [4]:
            xmin = 9.887671353516106 
            xmax = 12.390163794530798 
            text = "У нас завжди свіжий товар." 
        intervals [5]:
            xmin = 12.390163794530798 
            xmax = 12.59354021417135 
            text = "" 
        intervals [6]:
            xmin = 12.59354021417135 
            xmax = 14.181047136922523 
            text = "Чого ви зразу так накинулись?" 
        intervals [7]:
            xmin = 14.181047136922523 
            xmax = 15.722924178848578 
            text = "Поговорімо спокійно." 
        intervals [8]:
            xmin = 15.722924178848578 
            xmax = 21.02515259197987 
            text = "" 
        intervals [9]:
            xmin = 21.02515259197987 
            xmax = 22.67324283555071 
            text = "Ну-ну-ну-ну, не перебільшуйте." 
        intervals [10]:
            xmin = 22.67324283555071 
            xmax = 34.741139740765796 
            text = "Я кожен день перебираю овочі оцими руками, і все в мене в порядку. До вас до речі ніхто не жалівся, все нормально було.Може, ви неправильно зберігали якось ту картоплю чи ще щось?" 
        intervals [11]:
            xmin = 34.741139740765796 
            xmax = 39.230800196511325 
            text = "" 
        intervals [12]:
            xmin = 39.230800196511325 
            xmax = 44.93251773293499 
            text = "*м-м* Дивіться, я не казала, що ви винні. Іноді покупці самі псують товар, ну буває таке." 
        intervals [13]:
            xmin = 44.93251773293499 
            xmax = 52.02413414580175 
            text = "" 
        intervals [14]:
            xmin = 52.02413414580175 
            xmax = 55.435536926152615 
            text = "Усі інші беруть і не скаржаться. Тільки у вас якісь проблеми." 
        intervals [15]:
            xmin = 55.435536926152615 
            xmax = 60.77753038558744 
            text = "" 
        intervals [16]:
            xmin = 60.77753038558744 
            xmax = 64.02554094631468 
            text = "Боже ну і що ви тепер пропонуєте? Скандал влаштувати?" 
        intervals [17]:
            xmin = 64.02554094631468 
            xmax = 69.69802105199611 
            text = "Ну це ж не мішок картоплі врещті-решт, а всього пару кіло. Не варто роздувати з мухи слона." 
        intervals [18]:
            xmin = 69.69802105199611 
            xmax = 73.47911202770293 
            text = "" 
        intervals [19]:
            xmin = 73.47911202770293 
            xmax = 77.07292053204253 
            text = "Жіночко, що ви собі дозволяєте? Не треба погрожувати." 
        intervals [20]:
            xmin = 77.07292053204253 
            xmax = 80.51300443514036 
            text = "Ми *м-м* завжди йдемо назустріч клієнтам." 
        intervals [21]:
            xmin = 80.51300443514036 
            xmax = 84.11129425180489 
            text = "" 
        intervals [22]:
            xmin = 84.11129425180489 
            xmax = 87.22732665792435 
            text = "*вд* *м-м* *цок* Ну добре, якщо вам так принципово." 
        intervals [23]:
            xmin = 87.22732665792435 
            xmax = 88.07451261209879 
            text = "" 
        intervals [24]:
            xmin = 88.07451261209879 
            xmax = 90.68548626859457 
            text = "Ну вибачте, мені шкода, що так сталося." 
        intervals [25]:
            xmin = 90.68548626859457 
            xmax = 96.23892455898932 
            text = "*вд* Якщо вже вам так приспічило, можете он – буряків собі набрати. Безкоштовно." 
        intervals [26]:
            xmin = 96.23892455898932 
            xmax = 99.57284641047177 
            text = "" 
        intervals [27]:
            xmin = 99.57284641047177 
            xmax = 108.56363636867931 
            text = "Будь ласка, пані, давайте обійдемося без сварок. Гроші я вам повернути не можу, а от буряк – беріть скільки душа влізе." 
        intervals [28]:
            xmin = 108.56363636867931 
            xmax = 111.364232371425 
            text = "" 
        intervals [29]:
            xmin = 111.364232371425 
            xmax = 112.52442065199577 
            text = "Чого ж ви так?" 
        intervals [30]:
            xmin = 112.52442065199577 
            xmax = 128.53900796999287 
            text = "Буряк – надзвичайно корисний коренеплід, багатий на залізо, фолієву кислоту, магній та калій. Він покращує кровотворення, знижує артеріальний тиск, покращує травлення та зміцнює імунітет і має ще" 
        intervals [31]:
            xmin = 128.53900796999287 
            xmax = 135.75256235827663 
            text = "" 
