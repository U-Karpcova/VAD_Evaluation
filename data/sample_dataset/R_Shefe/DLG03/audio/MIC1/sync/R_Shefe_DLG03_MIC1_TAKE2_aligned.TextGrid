item []: 
    item [1]:
        class = "IntervalTier" 
        name = "SPK-A-text" 
        xmin = 0 
        xmax = 139.5591836734694 
        intervals: size = 27 
        intervals [1]:
            xmin = 0 
            xmax = 8.073533149879447 
            text = "" 
        intervals [2]:
            xmin = 8.073533149879447 
            xmax = 9.3547029659611 
            text = "*у* Доброго дня." 
        intervals [3]:
            xmin = 9.3547029659611 
            xmax = 9.711600271869559 
            text = "" 
        intervals [4]:
            xmin = 9.711600271869559 
            xmax = 11.770623190572213 
            text = "У нас завжди свіжий товар." 
        intervals [5]:
            xmin = 11.770623190572213 
            xmax = 12.026857153788542 
            text = "" 
        intervals [6]:
            xmin = 12.026857153788542 
            xmax = 15.135358667282013 
            text = "І чого ви зразу так накинулись? Поговорімо спершу спокійно." 
        intervals [7]:
            xmin = 15.135358667282013 
            xmax = 21.439956316431676 
            text = "" 
        intervals [8]:
            xmin = 21.439956316431676 
            xmax = 34.6497169478594 
            text = "Не перебільшуйте. Я кожен день *об* перебіряю перебираю овочі оцими руками, і все нормально. До вас ніхто не жалівся, все було в порядку. Може, ви якось неправильно зберігали ту картоплю, я не знаю." 
        intervals [9]:
            xmin = 34.6497169478594 
            xmax = 39.05433484317626 
            text = "" 
        intervals [10]:
            xmin = 39.05433484317626 
            xmax = 44.93624057877097 
            text = "Ну дивіться, я не казала, що ви винні! Іноді покупці самі псують товар, ну буває таке." 
        intervals [11]:
            xmin = 44.93624057877097 
            xmax = 52.23437697686202 
            text = "" 
        intervals [12]:
            xmin = 52.23437697686202 
            xmax = 55.856211640366965 
            text = "Усі інші беруть і не скаржаться. Тільки у вас якісь проблеми." 
        intervals [13]:
            xmin = 55.856211640366965 
            xmax = 60.5687277157725 
            text = "" 
        intervals [14]:
            xmin = 60.5687277157725 
            xmax = 68.61876873481853 
            text = "І що ви тепер пропонуєте? Скандал влаштувати? Ну слухайте, це ж не мішок картоплі, а всього пару кіло. Не варто роздувати з мухи слона." 
        intervals [15]:
            xmin = 68.61876873481853 
            xmax = 72.74745319819948 
            text = "" 
        intervals [16]:
            xmin = 72.74745319819948 
            xmax = 80.15402008616032 
            text = "Жіночко, що ви собі дозволяєте? Не треба погрожувати. Ми тут завжди йдемо назустріч клієнтам." 
        intervals [17]:
            xmin = 80.15402008616032 
            xmax = 84.34525836047624 
            text = "" 
        intervals [18]:
            xmin = 84.34525836047624 
            xmax = 88.63418549906984 
            text = "Добре, ну якщо вам так принципово вже" 
        intervals [19]:
            xmin = 88.63418549906984 
            xmax = 89.2536971968667 
            text = "" 
        intervals [20]:
            xmin = 89.2536971968667 
            xmax = 101.30721833362024 
            text = "*вд* *вд* Ну ну вибачте, мені шкода, що так сталось. Якщо вже вам так приспічило, слухайте, *вд* *пл* візьміть можете… от – буряків собі набрати. Безкоштовно." 
        intervals [21]:
            xmin = 101.30721833362024 
            xmax = 105.55387848985097 
            text = "" 
        intervals [22]:
            xmin = 105.55387848985097 
            xmax = 114.44489843257351 
            text = "Будь ласка, пані, давайте обійдемося без сварок. Гроші я вам повернути не можу, а от буряк – беріть скільки душі влізе." 
        intervals [23]:
            xmin = 114.44489843257351 
            xmax = 117.3291416398275 
            text = "" 
        intervals [24]:
            xmin = 117.3291416398275 
            xmax = 118.2999375145824 
            text = "Ну чого ж ви так?" 
        intervals [25]:
            xmin = 118.2999375145824 
            xmax = 118.70704546206026 
            text = "" 
        intervals [26]:
            xmin = 118.70704546206026 
            xmax = 132.6991153164972 
            text = "Буряк – надзвичайно корисний коренеплід, багатий на залізо, фолієву кислоту, магній та кальцій. Він покращує кровотворення, знижує артеріальний тиск, покращує травлення та зміцнює імунітет і має" 
        intervals [27]:
            xmin = 132.6991153164972 
            xmax = 139.5591836734694 
            text = "" 
