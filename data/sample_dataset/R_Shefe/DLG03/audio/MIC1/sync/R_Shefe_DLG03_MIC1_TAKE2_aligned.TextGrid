    item [3]:
        class = "IntervalTier" 
        name = "SPK-B-text" 
        xmin = 0 
        xmax = 139.5591836734694 
        intervals: size = 21 
        intervals [1]:
            xmin = 0 
            xmax = 2.9318435748186276 
            text = "" 
        intervals [2]:
            xmin = 2.9318435748186276 
            xmax = 7.687429442615938 
            text = "*у* Це шо ви мені продали таке вчора? Ви взагалі дивилися, шо кладете в пакет?" 
        intervals [3]:
            xmin = 7.687429442615938 
            xmax = 14.715113689927371 
            text = "" 
        intervals [4]:
            xmin = 14.715113689927371 
            xmax = 21.254679470114347 
            text = "Свіжий? Половина картоплі, шо ви мені продали, гнила! Вона смердить, її неможливо їсти." 
        intervals [5]:
            xmin = 21.254679470114347 
            xmax = 33.05948217612025 
            text = "" 
        intervals [6]:
            xmin = 33.05948217612025 
            xmax = 38.801738559923116 
            text = "Серйозно? Я винна, шо ви мені гниль продали? Це вже занадто." 
        intervals [7]:
            xmin = 38.801738559923116 
            xmax = 44.217548242000824 
            text = "" 
        intervals [8]:
            xmin = 44.217548242000824 
            xmax = 51.83754809785783 
            text = "Не перекладайте на мене відповідальність. Я заплатила гроші за нормальний продукт, а ви мені продали казна-шо." 
        intervals [9]:
            xmin = 51.83754809785783 
            xmax = 55.74234730872097 
            text = "" 
        intervals [10]:
            xmin = 55.74234730872097 
            xmax = 60.0046462656838 
            text = "Бо, мабуть, інші просто мовчать. А я мовчати не буду, я вас дістану!" 
        intervals [11]:
            xmin = 60.0046462656838 
            xmax = 67.85295090953426 
            text = "" 
        intervals [12]:
            xmin = 67.85295090953426 
            xmax = 72.49008761621032 
            text = "Якщо треба — влаштую. І скаргу напишу на ваш ларьок смердючий!" 
        intervals [13]:
            xmin = 72.49008761621032 
            xmax = 80.0758365185297 
            text = "" 
        intervals [14]:
            xmin = 80.0758365185297 
            xmax = 83.96402039260126 
            text = "*сарк* Бачу я, як ви йдете назустріч. Ви навіть не вибачились." 
        intervals [15]:
            xmin = 83.96402039260126 
            xmax = 101.64681903883988 
            text = "" 
        intervals [16]:
            xmin = 101.64681903883988 
            xmax = 105.00042157596206 
            text = "На чорта мені ваш буряк? *сміх* Поверніть мені гроші." 
        intervals [17]:
            xmin = 105.00042157596206 
            xmax = 113.72419558110896 
            text = "" 
        intervals [18]:
            xmin = 113.72419558110896 
            xmax = 116.55173776221888 
            text = "Який на біса буряк? Ви показилися чи шо?" 
        intervals [19]:
            xmin = 116.55173776221888 
            xmax = 131.45842274407806 
            text = "" 
        intervals [20]:
            xmin = 131.45842274407806 
            xmax = 135.3715956391563 
            text = "Так. Не потрібен мені ваш буряк. Все. До побачення." 
        intervals [21]:
            xmin = 135.3715956391563 
            xmax = 139.5591836734694 
            text = "" 
