item []: 
    item [1]:
        class = "IntervalTier" 
        name = "SPK-A-text" 
        xmin = 0 
        xmax = 135.75256235827663 
        intervals: size = 31 
        intervals [1]:
            xmin = 0 
            xmax = 7.366644002108785 
            text = "" 
        intervals [2]:
            xmin = 7.366644002108785 
            xmax = 8.355147995245426 
            text = "*у* *сміх* Доброго дня." 
        intervals [3]:
            xmin = 8.355147995245426 
            xmax = 8.605821256662852 
            text = "" 
        intervals [4]:
            xmin = 8.605821256662852 
            xmax = 11.108313697677543 
            text = "У нас завжди свіжий товар." 
        intervals [5]:
            xmin = 11.108313697677543 
            xmax = 11.311690117318095 
            text = "" 
        intervals [6]:
            xmin = 11.311690117318095 
            xmax = 12.899197040069268 
            text = "Чого ви зразу так накинулись?" 
        intervals [7]:
            xmin = 12.899197040069268 
            xmax = 14.441074081995323 
            text = "Поговорімо спокійно." 
        intervals [8]:
            xmin = 14.441074081995323 
            xmax = 19.743302495126613 
            text = "" 
        intervals [9]:
            xmin = 19.743302495126613 
            xmax = 21.391392738697455 
            text = "Ну-ну-ну-ну, не перебільшуйте." 
        intervals [10]:
            xmin = 21.391392738697455 
            xmax = 33.45928964391254 
            text = "Я кожен день перебираю овочі оцими руками, і все в мене в порядку. До вас до речі ніхто не жалівся, все нормально було.Може, ви неправильно зберігали якось ту картоплю чи ще щось?" 
        intervals [11]:
            xmin = 33.45928964391254 
            xmax = 37.94895009965807 
            text = "" 
        intervals [12]:
            xmin = 37.94895009965807 
            xmax = 43.650667636081735 
            text = "*м-м* Дивіться, я не казала, що ви винні. Іноді покупці самі псують товар, ну буває таке." 
        intervals [13]:
            xmin = 43.650667636081735 
            xmax = 50.7422840489485 
            text = "" 
        intervals [14]:
            xmin = 50.7422840489485 
            xmax = 54.15368682929936 
            text = "Усі інші беруть і не скаржаться. Тільки у вас якісь проблеми." 
        intervals [15]:
            xmin = 54.15368682929936 
            xmax = 59.495680288734185 
            text = "" 
        intervals [16]:
            xmin = 59.495680288734185 
            xmax = 62.743690849461416 
            text = "Боже ну і що ви тепер пропонуєте? Скандал влаштувати?" 
        intervals [17]:
            xmin = 62.743690849461416 
            xmax = 68.41617095514285 
            text = "Ну це ж не мішок картоплі врещті-решт, а всього пару кіло. Не варто роздувати з мухи слона." 
        intervals [18]:
            xmin = 68.41617095514285 
            xmax = 72.19726193084966 
            text = "" 
        intervals [19]:
            xmin = 72.19726193084966 
            xmax = 75.79107043518927 
            text = "Жіночко, що ви собі дозволяєте? Не треба погрожувати." 
        intervals [20]:
            xmin = 75.79107043518927 
            xmax = 79.2311543382871 
            text = "Ми *м-м* завжди йдемо назустріч клієнтам." 
        intervals [21]:
            xmin = 79.2311543382871 
            xmax = 82.82944415495163 
            text = "" 
        intervals [22]:
            xmin = 82.82944415495163 
            xmax = 85.94547656107109 
            text = "*вд* *м-м* *цок* Ну добре, якщо вам так принципово." 
        intervals [23]:
            xmin = 85.94547656107109 
            xmax = 86.79266251524552 
            text = "" 
        intervals [24]:
            xmin = 86.79266251524552 
            xmax = 89.40363617174131 
            text = "Ну вибачте, мені шкода, що так сталося." 
        intervals [25]:
            xmin = 89.40363617174131 
            xmax = 94.95707446213606 
            text = "*вд* Якщо вже вам так приспічило, можете он – буряків собі набрати. Безкоштовно." 
        intervals [26]:
            xmin = 94.95707446213606 
            xmax = 98.2909963136185 
            text = "" 
        intervals [27]:
            xmin = 98.2909963136185 
            xmax = 107.28178627182605 
            text = "Будь ласка, пані, давайте обійдемося без сварок. Гроші я вам повернути не можу, а от буряк – беріть скільки душа влізе." 
        intervals [28]:
            xmin = 107.28178627182605 
            xmax = 110.08238227457174 
            text = "" 
        intervals [29]:
            xmin = 110.08238227457174 
            xmax = 111.2425705551425 
            text = "Чого ж ви так?" 
        intervals [30]:
            xmin = 111.2425705551425 
            xmax = 127.25715787313962 
            text = "Буряк – надзвичайно корисний коренеплід, багатий на залізо, фолієву кислоту, магній та калій. Він покращує кровотворення, знижує артеріальний тиск, покращує травлення та зміцнює імунітет і має ще" 
        intervals [31]:
            xmin = 127.25715787313962 
            xmax = 135.75256235827663 
            text = "" 
