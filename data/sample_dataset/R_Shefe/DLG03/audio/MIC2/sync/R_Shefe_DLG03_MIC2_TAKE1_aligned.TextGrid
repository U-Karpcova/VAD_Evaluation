    item [3]:
        class = "IntervalTier" 
        name = "SPK-B-text" 
        xmin = 0 
        xmax = 135.75256235827663 
        intervals: size = 23 
        intervals [1]:
            xmin = 0 
            xmax = 2.4932567965787706 
            text = "" 
        intervals [2]:
            xmin = 2.4932567965787706 
            xmax = 6.7499725564973225 
            text = "*у* Це шо ви мені таке продали вчора? Ви взагалі дивилися, шо кладете в пакет?" 
        intervals [3]:
            xmin = 6.7499725564973225 
            xmax = 13.496589155910028 
            text = "" 
        intervals [4]:
            xmin = 13.496589155910028 
            xmax = 14.525204282530813 
            text = "Свіжий?" 
        intervals [5]:
            xmin = 14.525204282530813 
            xmax = 20.160905849666698 
            text = "Половина картоплі, шо ви мені продали, гнила! Вона смердить, її неможливо їсти." 
        intervals [6]:
            xmin = 20.160905849666698 
            xmax = 31.481189854232447 
            text = "" 
        intervals [7]:
            xmin = 31.481189854232447 
            xmax = 37.87032868708314 
            text = "*гкхм* Серйозно? Я винна, шо ви мені гниль продали? Це вже занадто." 
        intervals [8]:
            xmin = 37.87032868708314 
            xmax = 43.465469058603695 
            text = "" 
        intervals [9]:
            xmin = 43.465469058603695 
            xmax = 50.47832285806025 
            text = "Не перекладайте на мене відповідальність. Я заплатила гроші за нормальний продукт, а ви продали мені казна-що." 
        intervals [10]:
            xmin = 50.47832285806025 
            xmax = 54.15368682929936 
            text = "" 
        intervals [11]:
            xmin = 54.15368682929936 
            xmax = 56.40060152057563 
            text = "Бо, мабуть, інші просто мовчать." 
        intervals [12]:
            xmin = 56.40060152057563 
            xmax = 59.02717561621217 
            text = "А я мовчати не буду, я вас дістану!" 
        intervals [13]:
            xmin = 59.02717561621217 
            xmax = 66.88642904411282 
            text = "" 
        intervals [14]:
            xmin = 66.88642904411282 
            xmax = 71.93490305278183 
            text = "Якшо треба — влаштую. І скаргу напишу на ваш ларьок смердючий!" 
        intervals [15]:
            xmin = 71.93490305278183 
            xmax = 78.92939259240133 
            text = "" 
        intervals [16]:
            xmin = 78.92939259240133 
            xmax = 82.82944415495163 
            text = "*сарк* Бачу я, як ви йдете назустріч. Ви навіть не вибачились." 
        intervals [17]:
            xmin = 82.82944415495163 
            xmax = 94.95707446213606 
            text = "" 
        intervals [18]:
            xmin = 94.95707446213606 
            xmax = 98.2909963136185 
            text = "На чорта мені ваш буряк? *сміх* Поверніть мені гроші." 
        intervals [19]:
            xmin = 98.2909963136185 
            xmax = 106.84945195972657 
            text = "" 
        intervals [20]:
            xmin = 106.84945195972657 
            xmax = 109.71845529033611 
            text = "Та який в біса буряк? Ви показилися чи шо?" 
        intervals [21]:
            xmin = 109.71845529033611 
            xmax = 125.73613065785966 
            text = "" 
        intervals [22]:
            xmin = 125.73613065785966 
            xmax = 130.3395628937742 
            text = "Не потрібно мені ваш буряк. Все. До побачення." 
        intervals [23]:
            xmin = 130.3395628937742 
            xmax = 135.75256235827663 
            text = "" 
