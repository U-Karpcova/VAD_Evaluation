item []: 
    item [1]:
        class = "IntervalTier" 
        name = "SPK-A-text" 
        xmin = 0 
        xmax = 139.5591836734694 
        intervals: size = 27 
        intervals [1]:
            xmin = 0 
            xmax = 7.903148169896619 
            text = "" 
        intervals [2]:
            xmin = 7.903148169896619 
            xmax = 9.184317985978272 
            text = "*у* Доброго дня." 
        intervals [3]:
            xmin = 9.184317985978272 
            xmax = 9.541215291886731 
            text = "" 
        intervals [4]:
            xmin = 9.541215291886731 
            xmax = 11.600238210589385 
            text = "У нас завжди свіжий товар." 
        intervals [5]:
            xmin = 11.600238210589385 
            xmax = 11.856472173805715 
            text = "" 
        intervals [6]:
            xmin = 11.856472173805715 
            xmax = 14.964973687299185 
            text = "І чого ви зразу так накинулись? Поговорімо спершу спокійно." 
        intervals [7]:
            xmin = 14.964973687299185 
            xmax = 21.26957133644885 
            text = "" 
        intervals [8]:
            xmin = 21.26957133644885 
            xmax = 34.479331967876576 
            text = "Не перебільшуйте. Я кожен день *об* перебіряю перебираю овочі оцими руками, і все нормально. До вас ніхто не жалівся, все було в порядку. Може, ви якось неправильно зберігали ту картоплю, я не знаю." 
        intervals [9]:
            xmin = 34.479331967876576 
            xmax = 38.88394986319343 
            text = "" 
        intervals [10]:
            xmin = 38.88394986319343 
            xmax = 44.76585559878814 
            text = "Ну дивіться, я не казала, що ви винні! Іноді покупці самі псують товар, ну буває таке." 
        intervals [11]:
            xmin = 44.76585559878814 
            xmax = 52.063991996879196 
            text = "" 
        intervals [12]:
            xmin = 52.063991996879196 
            xmax = 55.68582666038414 
            text = "Усі інші беруть і не скаржаться. Тільки у вас якісь проблеми." 
        intervals [13]:
            xmin = 55.68582666038414 
            xmax = 60.398342735789676 
            text = "" 
        intervals [14]:
            xmin = 60.398342735789676 
            xmax = 68.4483837548357 
            text = "І що ви тепер пропонуєте? Скандал влаштувати? Ну слухайте, це ж не мішок картоплі, а всього пару кіло. Не варто роздувати з мухи слона." 
        intervals [15]:
            xmin = 68.4483837548357 
            xmax = 72.57706821821665 
            text = "" 
        intervals [16]:
            xmin = 72.57706821821665 
            xmax = 79.98363510617749 
            text = "Жіночко, що ви собі дозволяєте? Не треба погрожувати. Ми тут завжди йдемо назустріч клієнтам." 
        intervals [17]:
            xmin = 79.98363510617749 
            xmax = 84.17487338049341 
            text = "" 
        intervals [18]:
            xmin = 84.17487338049341 
            xmax = 88.46380051908702 
            text = "Добре, ну якщо вам так принципово вже" 
        intervals [19]:
            xmin = 88.46380051908702 
            xmax = 89.08331221688387 
            text = "" 
        intervals [20]:
            xmin = 89.08331221688387 
            xmax = 101.13683335363741 
            text = "*вд* *вд* Ну ну вибачте, мені шкода, що так сталось. Якщо вже вам так приспічило, слухайте, *вд* *пл* візьміть можете… от – буряків собі набрати. Безкоштовно." 
        intervals [21]:
            xmin = 101.13683335363741 
            xmax = 105.38349350986815 
            text = "" 
        intervals [22]:
            xmin = 105.38349350986815 
            xmax = 114.27451345259068 
            text = "Будь ласка, пані, давайте обійдемося без сварок. Гроші я вам повернути не можу, а от буряк – беріть скільки душі влізе." 
        intervals [23]:
            xmin = 114.27451345259068 
            xmax = 117.15875665984467 
            text = "" 
        intervals [24]:
            xmin = 117.15875665984467 
            xmax = 118.12955253459957 
            text = "Ну чого ж ви так?" 
        intervals [25]:
            xmin = 118.12955253459957 
            xmax = 118.53666048207744 
            text = "" 
        intervals [26]:
            xmin = 118.53666048207744 
            xmax = 132.52873033651437 
            text = "Буряк – надзвичайно корисний коренеплід, багатий на залізо, фолієву кислоту, магній та кальцій. Він покращує кровотворення, знижує артеріальний тиск, покращує травлення та зміцнює імунітет і має" 
        intervals [27]:
            xmin = 132.52873033651437 
            xmax = 139.5591836734694 
            text = "" 
