    item [3]:
        class = "IntervalTier" 
        name = "SPK-B-text" 
        xmin = 0 
        xmax = 139.5591836734694 
        intervals: size = 21 
        intervals [1]:
            xmin = 0 
            xmax = 2.7614585948358004 
            text = "" 
        intervals [2]:
            xmin = 2.7614585948358004 
            xmax = 7.517044462633111 
            text = "*у* Це шо ви мені продали таке вчора? Ви взагалі дивилися, шо кладете в пакет?" 
        intervals [3]:
            xmin = 7.517044462633111 
            xmax = 14.544728709944543 
            text = "" 
        intervals [4]:
            xmin = 14.544728709944543 
            xmax = 21.08429449013152 
            text = "Свіжий? Половина картоплі, шо ви мені продали, гнила! Вона смердить, її неможливо їсти." 
        intervals [5]:
            xmin = 21.08429449013152 
            xmax = 32.88909719613742 
            text = "" 
        intervals [6]:
            xmin = 32.88909719613742 
            xmax = 38.63135357994029 
            text = "Серйозно? Я винна, шо ви мені гниль продали? Це вже занадто." 
        intervals [7]:
            xmin = 38.63135357994029 
            xmax = 44.047163262017996 
            text = "" 
        intervals [8]:
            xmin = 44.047163262017996 
            xmax = 51.667163117875 
            text = "Не перекладайте на мене відповідальність. Я заплатила гроші за нормальний продукт, а ви мені продали казна-шо." 
        intervals [9]:
            xmin = 51.667163117875 
            xmax = 55.571962328738145 
            text = "" 
        intervals [10]:
            xmin = 55.571962328738145 
            xmax = 59.834261285700975 
            text = "Бо, мабуть, інші просто мовчать. А я мовчати не буду, я вас дістану!" 
        intervals [11]:
            xmin = 59.834261285700975 
            xmax = 67.68256592955143 
            text = "" 
        intervals [12]:
            xmin = 67.68256592955143 
            xmax = 72.31970263622749 
            text = "Якщо треба — влаштую. І скаргу напишу на ваш ларьок смердючий!" 
        intervals [13]:
            xmin = 72.31970263622749 
            xmax = 79.90545153854687 
            text = "" 
        intervals [14]:
            xmin = 79.90545153854687 
            xmax = 83.79363541261843 
            text = "*сарк* Бачу я, як ви йдете назустріч. Ви навіть не вибачились." 
        intervals [15]:
            xmin = 83.79363541261843 
            xmax = 101.47643405885705 
            text = "" 
        intervals [16]:
            xmin = 101.47643405885705 
            xmax = 104.83003659597924 
            text = "На чорта мені ваш буряк? *сміх* Поверніть мені гроші." 
        intervals [17]:
            xmin = 104.83003659597924 
            xmax = 113.55381060112613 
            text = "" 
        intervals [18]:
            xmin = 113.55381060112613 
            xmax = 116.38135278223605 
            text = "Який на біса буряк? Ви показилися чи шо?" 
        intervals [19]:
            xmin = 116.38135278223605 
            xmax = 131.28803776409524 
            text = "" 
        intervals [20]:
            xmin = 131.28803776409524 
            xmax = 135.20121065917348 
            text = "Так. Не потрібен мені ваш буряк. Все. До побачення." 
        intervals [21]:
            xmin = 135.20121065917348 
            xmax = 139.5591836734694 
            text = "" 
