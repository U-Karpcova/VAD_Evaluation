    item [3]:
        class = "IntervalTier" 
        name = "SPK-B-text" 
        xmin = 0 
        xmax = 98.71435039111934 
        intervals: size = 43 
        intervals [1]:
            xmin = 0 
            xmax = 5.67705198141142 
            text = "" 
        intervals [2]:
            xmin = 5.67705198141142 
            xmax = 8.54662665856 
            text = "*у* Люда, ну коли ми нарешті оберемо фільм" 
        intervals [3]:
            xmin = 8.54662665856 
            xmax = 8.73167365999122 
            text = "" 
        intervals [4]:
            xmin = 8.73167365999122 
            xmax = 10.876663887864256 
            text = "Я вже задовбалася чекати, ти знаєш." 
        intervals [5]:
            xmin = 10.876663887864256 
            xmax = 15.884685754968123 
            text = "" 
        intervals [6]:
            xmin = 15.884685754968123 
            xmax = 17.363474282540725 
            text = "Не пройшло і пів року" 
        intervals [7]:
            xmin = 17.363474282540725 
            xmax = 21.91062615772548 
            text = "" 
        intervals [8]:
            xmin = 21.91062615772548 
            xmax = 26.79304324830677 
            text = "Це там, де твоя мама за тобою постійно *гарк* прибирає, готує і ходить за тобою з" 
        intervals [9]:
            xmin = 26.79304324830677 
            xmax = 29.14754503910418 
            text = "" 
        intervals [10]:
            xmin = 29.14754503910418 
            xmax = 30.198576964303236 
            text = "Да, правда…" 
        intervals [11]:
            xmin = 30.198576964303236 
            xmax = 30.847524316952367 
            text = "" 
        intervals [12]:
            xmin = 30.847524316952367 
            xmax = 31.826320371003725 
            text = "Ну так про що він?" 
        intervals [13]:
            xmin = 31.826320371003725 
            xmax = 35.82286042829745 
            text = "" 
        intervals [14]:
            xmin = 35.82286042829745 
            xmax = 37.8237940590888 
            text = "Ммм, це по-нашому. А, секс?" 
        intervals [15]:
            xmin = 37.8237940590888 
            xmax = 39.768884093074206 
            text = "" 
        intervals [16]:
            xmin = 39.768884093074206 
            xmax = 40.51652535945292 
            text = "*роз* Що?" 
        intervals [17]:
            xmin = 40.51652535945292 
            xmax = 50.15596674394449 
            text = "" 
        intervals [18]:
            xmin = 50.15596674394449 
            xmax = 53.124409573920396 
            text = "А я бачу! Такого дивитися не буду" 
        intervals [19]:
            xmin = 53.124409573920396 
            xmax = 53.46298188821026 
            text = "" 
        intervals [20]:
            xmin = 53.46298188821026 
            xmax = 54.31852548711586 
            text = "Це аморально!" 
        intervals [21]:
            xmin = 54.31852548711586 
            xmax = 56.20148869962692 
            text = "" 
        intervals [22]:
            xmin = 56.20148869962692 
            xmax = 58.213257711090435 
            text = "Ей, а не пішла б ти на магістратуру" 
        intervals [23]:
            xmin = 58.213257711090435 
            xmax = 58.37217662761538 
            text = "" 
        intervals [24]:
            xmin = 58.37217662761538 
            xmax = 58.57804886038634 
            text = "*сміх*" 
        intervals [25]:
            xmin = 58.57804886038634 
            xmax = 58.95199640820147 
            text = "" 
        intervals [26]:
            xmin = 58.95199640820147 
            xmax = 60.970989006779746 
            text = "кажуть стипендію підвищили.." 
        intervals [27]:
            xmin = 60.970989006779746 
            xmax = 62.84550986306263 
            text = "" 
        intervals [28]:
            xmin = 62.84550986306263 
            xmax = 63.80370727058389 
            text = "Я пропоную" 
        intervals [29]:
            xmin = 63.80370727058389 
            xmax = 65.54423501806495 
            text = "" 
        intervals [30]:
            xmin = 65.54423501806495 
            xmax = 66.8408689051662 
            text = "Вєра, дай *о* договорити" 
        intervals [31]:
            xmin = 66.8408689051662 
            xmax = 70.17642018159405 
            text = "" 
        intervals [32]:
            xmin = 70.17642018159405 
            xmax = 72.56064089043686 
            text = "Вєра, для цього є окремі сайти" 
        intervals [33]:
            xmin = 72.56064089043686 
            xmax = 72.91134254932103 
            text = "" 
        intervals [34]:
            xmin = 72.91134254932103 
            xmax = 75.37819754901507 
            text = "Давай щось хороше, от наприклад, «Опенгеймер»." 
        intervals [35]:
            xmin = 75.37819754901507 
            xmax = 78.47052892462156 
            text = "" 
        intervals [36]:
            xmin = 78.47052892462156 
            xmax = 82.02453378508854 
            text = "Так, зачепили! Давай, давай, це шедевр Нолана" 
        intervals [37]:
            xmin = 82.02453378508854 
            xmax = 82.44028736658103 
            text = "" 
        intervals [38]:
            xmin = 82.44028736658103 
            xmax = 84.08365343519125 
            text = "своє там ти глянеш патом" 
        intervals [39]:
            xmin = 84.08365343519125 
            xmax = 90.64179848674388 
            text = "" 
        intervals [40]:
            xmin = 90.64179848674388 
            xmax = 93.27590774346723 
            text = "Люда… Є додатки, *англ* you know?" 
        intervals [41]:
            xmin = 93.27590774346723 
            xmax = 95.58416187187872 
            text = "" 
        intervals [42]:
            xmin = 95.58416187187872 
            xmax = 97.34310533432529 
            text = "От і добре, пішла гуглити." 
        intervals [43]:
            xmin = 97.34310533432529 
            xmax = 98.71435039111934 
            text = "" 
