item []: 
    item [1]:
        class = "IntervalTier" 
        name = "SPK-A-text" 
        xmin = 0 
        xmax = 98.71435039111934 
        intervals: size = 41 
        intervals [1]:
            xmin = 0 
            xmax = 10.876663887864256 
            text = "" 
        intervals [2]:
            xmin = 10.876663887864256 
            xmax = 13.600364978898847 
            text = "*у* Коли рік на *об* го рік на горі свисне…" 
        intervals [3]:
            xmin = 13.600364978898847 
            xmax = 14.173027594766832 
            text = "" 
        intervals [4]:
            xmin = 14.173027594766832 
            xmax = 14.815329682500389 
            text = "жартую" 
        intervals [5]:
            xmin = 14.815329682500389 
            xmax = 15.030426195601859 
            text = "" 
        intervals [6]:
            xmin = 15.030426195601859 
            xmax = 15.813138507165542 
            text = "ну давай обирати!" 
        intervals [7]:
            xmin = 15.813138507165542 
            xmax = 17.363474282540725 
            text = "" 
        intervals [8]:
            xmin = 17.363474282540725 
            xmax = 21.15449318661005 
            text = "Перестань вазмущаться і вмикай голову! Я пропоную «Служницю»." 
        intervals [9]:
            xmin = 21.15449318661005 
            xmax = 26.79304324830677 
            text = "" 
        intervals [10]:
            xmin = 26.79304324830677 
            xmax = 27.895091757503888 
            text = "Дуже смішно!" 
        intervals [11]:
            xmin = 27.895091757503888 
            xmax = 28.29154996600392 
            text = "" 
        intervals [12]:
            xmin = 28.29154996600392 
            xmax = 29.14754503910418 
            text = "Ти така сама…" 
        intervals [13]:
            xmin = 29.14754503910418 
            xmax = 31.945509558397433 
            text = "" 
        intervals [14]:
            xmin = 31.945509558397433 
            xmax = 32.796086941161626 
            text = "Милий трилер," 
        intervals [15]:
            xmin = 32.796086941161626 
            xmax = 33.03433492772942 
            text = "" 
        intervals [16]:
            xmin = 33.03433492772942 
            xmax = 35.684488450460734 
            text = "де одна жінка допомагає іншій вибратися з лайна." 
        intervals [17]:
            xmin = 35.684488450460734 
            xmax = 38.21220106984123 
            text = "" 
        intervals [18]:
            xmin = 38.21220106984123 
            xmax = 39.511793948281 
            text = "Так, але з її чоловіком." 
        intervals [19]:
            xmin = 39.511793948281 
            xmax = 40.8651233639233 
            text = "" 
        intervals [20]:
            xmin = 40.8651233639233 
            xmax = 43.77984076473308 
            text = "Шо, шо. Ну, гарна жінка ходить по дому, от" 
        intervals [21]:
            xmin = 43.77984076473308 
            xmax = 44.0032963023862 
            text = "" 
        intervals [22]:
            xmin = 44.0032963023862 
            xmax = 44.94958621442109 
            text = "І сцени, кажуть, агонь." 
        intervals [23]:
            xmin = 44.94958621442109 
            xmax = 45.191576382765895 
            text = "" 
        intervals [24]:
            xmin = 45.191576382765895 
            xmax = 50.15596674394449 
            text = "Енівей, кажуть, гарний фільм. І актори хороші, а те, що подружня зрада, я не бачу в цьому *о* ніяк" 
        intervals [25]:
            xmin = 50.15596674394449 
            xmax = 54.31852548711586 
            text = "" 
        intervals [26]:
            xmin = 54.31852548711586 
            xmax = 55.93650561918823 
            text = "Тоді пропонуй сама, манашка…" 
        intervals [27]:
            xmin = 55.93650561918823 
            xmax = 60.970989006779746 
            text = "" 
        intervals [28]:
            xmin = 60.970989006779746 
            xmax = 62.84550986306263 
            text = "Ні, дякую. Давай пропонуй!" 
        intervals [29]:
            xmin = 62.84550986306263 
            xmax = 63.80370727058389 
            text = "" 
        intervals [30]:
            xmin = 63.80370727058389 
            xmax = 65.05338784143913 
            text = """Секс у великому місті""?" 
        intervals [31]:
            xmin = 65.05338784143913 
            xmax = 66.8408689051662 
            text = "" 
        intervals [32]:
            xmin = 66.8408689051662 
            xmax = 70.17642018159405 
            text = "Люда, я дам договорити, тільки, будь ласка, давай щось сочне" 
        intervals [33]:
            xmin = 70.17642018159405 
            xmax = 75.57363172350708 
            text = "" 
        intervals [34]:
            xmin = 75.57363172350708 
            xmax = 78.24997074952945 
            text = "Я бачу, світові події когось сильно зачепили." 
        intervals [35]:
            xmin = 78.24997074952945 
            xmax = 84.64812570638216 
            text = "" 
        intervals [36]:
            xmin = 84.64812570638216 
            xmax = 88.00709371475033 
            text = "*роз* Ти взагалі бачила трейлер?? Там є тоже на шо глянуть" 
        intervals [37]:
            xmin = 88.00709371475033 
            xmax = 88.18939066127938 
            text = "" 
        intervals [38]:
            xmin = 88.18939066127938 
            xmax = 90.64179848674388 
            text = "крім красавчика Мерфі, і загалом…" 
        intervals [39]:
            xmin = 90.64179848674388 
            xmax = 93.27590774346723 
            text = "" 
        intervals [40]:
            xmin = 93.27590774346723 
            xmax = 95.14872226772953 
            text = "Я хотіла сказати, що це хороший фільм!" 
        intervals [41]:
            xmin = 95.14872226772953 
            xmax = 98.71435039111934 
            text = "" 
