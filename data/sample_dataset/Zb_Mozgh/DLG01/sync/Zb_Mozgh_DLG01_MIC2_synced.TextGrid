item []: 
    item [1]:
        class = "IntervalTier" 
        name = "SPK-A-text" 
        xmin = 0 
        xmax = 97.49775457071723 
        intervals: size = 41 
        intervals [1]:
            xmin = 0 
            xmax = 9.660068067462145 
            text = "" 
        intervals [2]:
            xmin = 9.660068067462145 
            xmax = 12.383769158496737 
            text = "*у* Коли рік на *об* го рік на горі свисне…" 
        intervals [3]:
            xmin = 12.383769158496737 
            xmax = 12.956431774364722 
            text = "" 
        intervals [4]:
            xmin = 12.956431774364722 
            xmax = 13.598733862098278 
            text = "жартую" 
        intervals [5]:
            xmin = 13.598733862098278 
            xmax = 13.813830375199748 
            text = "" 
        intervals [6]:
            xmin = 13.813830375199748 
            xmax = 14.596542686763431 
            text = "ну давай обирати!" 
        intervals [7]:
            xmin = 14.596542686763431 
            xmax = 16.146878462138616 
            text = "" 
        intervals [8]:
            xmin = 16.146878462138616 
            xmax = 19.93789736620794 
            text = "Перестань вазмущаться і вмикай голову! Я пропоную «Служницю»." 
        intervals [9]:
            xmin = 19.93789736620794 
            xmax = 25.57644742790466 
            text = "" 
        intervals [10]:
            xmin = 25.57644742790466 
            xmax = 26.67849593710178 
            text = "Дуже смішно!" 
        intervals [11]:
            xmin = 26.67849593710178 
            xmax = 27.07495414560181 
            text = "" 
        intervals [12]:
            xmin = 27.07495414560181 
            xmax = 27.93094921870207 
            text = "Ти така сама…" 
        intervals [13]:
            xmin = 27.93094921870207 
            xmax = 30.728913737995324 
            text = "" 
        intervals [14]:
            xmin = 30.728913737995324 
            xmax = 31.579491120759513 
            text = "Милий трилер," 
        intervals [15]:
            xmin = 31.579491120759513 
            xmax = 31.817739107327306 
            text = "" 
        intervals [16]:
            xmin = 31.817739107327306 
            xmax = 34.46789263005862 
            text = "де одна жінка допомагає іншій вибратися з лайна." 
        intervals [17]:
            xmin = 34.46789263005862 
            xmax = 36.995605249439116 
            text = "" 
        intervals [18]:
            xmin = 36.995605249439116 
            xmax = 38.29519812787889 
            text = "Так, але з її чоловіком." 
        intervals [19]:
            xmin = 38.29519812787889 
            xmax = 39.64852754352119 
            text = "" 
        intervals [20]:
            xmin = 39.64852754352119 
            xmax = 42.56324494433097 
            text = "Шо, шо. Ну, гарна жінка ходить по дому, от" 
        intervals [21]:
            xmin = 42.56324494433097 
            xmax = 42.786700481984084 
            text = "" 
        intervals [22]:
            xmin = 42.786700481984084 
            xmax = 43.73299039401898 
            text = "І сцени, кажуть, агонь." 
        intervals [23]:
            xmin = 43.73299039401898 
            xmax = 43.97498056236378 
            text = "" 
        intervals [24]:
            xmin = 43.97498056236378 
            xmax = 48.93937092354238 
            text = "Енівей, кажуть, гарний фільм. І актори хороші, а те, що подружня зрада, я не бачу в цьому *о* ніяк" 
        intervals [25]:
            xmin = 48.93937092354238 
            xmax = 53.10192966671375 
            text = "" 
        intervals [26]:
            xmin = 53.10192966671375 
            xmax = 54.71990979878612 
            text = "Тоді пропонуй сама, манашка…" 
        intervals [27]:
            xmin = 54.71990979878612 
            xmax = 59.754393186377634 
            text = "" 
        intervals [28]:
            xmin = 59.754393186377634 
            xmax = 61.62891404266052 
            text = "Ні, дякую. Давай пропонуй!" 
        intervals [29]:
            xmin = 61.62891404266052 
            xmax = 62.58711145018178 
            text = "" 
        intervals [30]:
            xmin = 62.58711145018178 
            xmax = 63.83679202103703 
            text = """Секс у великому місті""?" 
        intervals [31]:
            xmin = 63.83679202103703 
            xmax = 65.6242730847641 
            text = "" 
        intervals [32]:
            xmin = 65.6242730847641 
            xmax = 68.95982436119195 
            text = "Люда, я дам договорити, тільки, будь ласка, давай щось сочне" 
        intervals [33]:
            xmin = 68.95982436119195 
            xmax = 74.35703590310497 
            text = "" 
        intervals [34]:
            xmin = 74.35703590310497 
            xmax = 77.03337492912735 
            text = "Я бачу, світові події когось сильно зачепили." 
        intervals [35]:
            xmin = 77.03337492912735 
            xmax = 83.43152988598005 
            text = "" 
        intervals [36]:
            xmin = 83.43152988598005 
            xmax = 86.79049789434822 
            text = "*роз* Ти взагалі бачила трейлер?? Там є тоже на шо глянуть" 
        intervals [37]:
            xmin = 86.79049789434822 
            xmax = 86.97279484087727 
            text = "" 
        intervals [38]:
            xmin = 86.97279484087727 
            xmax = 89.42520266634178 
            text = "крім красавчика Мерфі, і загалом…" 
        intervals [39]:
            xmin = 89.42520266634178 
            xmax = 92.05931192306512 
            text = "" 
        intervals [40]:
            xmin = 92.05931192306512 
            xmax = 93.93212644732742 
            text = "Я хотіла сказати, що це хороший фільм!" 
        intervals [41]:
            xmin = 93.93212644732742 
            xmax = 97.49775457071723 
            text = "" 
