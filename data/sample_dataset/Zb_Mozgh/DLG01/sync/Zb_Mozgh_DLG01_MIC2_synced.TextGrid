    item [3]:
        class = "IntervalTier" 
        name = "SPK-B-text" 
        xmin = 0 
        xmax = 97.49775457071723 
        intervals: size = 43 
        intervals [1]:
            xmin = 0 
            xmax = 4.4604561610093105 
            text = "" 
        intervals [2]:
            xmin = 4.4604561610093105 
            xmax = 7.330030838157889 
            text = "*у* Люда, ну коли ми нарешті оберемо фільм" 
        intervals [3]:
            xmin = 7.330030838157889 
            xmax = 7.515077839589109 
            text = "" 
        intervals [4]:
            xmin = 7.515077839589109 
            xmax = 9.660068067462145 
            text = "Я вже задовбалася чекати, ти знаєш." 
        intervals [5]:
            xmin = 9.660068067462145 
            xmax = 14.668089934566012 
            text = "" 
        intervals [6]:
            xmin = 14.668089934566012 
            xmax = 16.146878462138616 
            text = "Не пройшло і пів року" 
        intervals [7]:
            xmin = 16.146878462138616 
            xmax = 20.694030337323372 
            text = "" 
        intervals [8]:
            xmin = 20.694030337323372 
            xmax = 25.57644742790466 
            text = "Це там, де твоя мама за тобою постійно *гарк* прибирає, готує і ходить за тобою з" 
        intervals [9]:
            xmin = 25.57644742790466 
            xmax = 27.93094921870207 
            text = "" 
        intervals [10]:
            xmin = 27.93094921870207 
            xmax = 28.981981143901127 
            text = "Да, правда…" 
        intervals [11]:
            xmin = 28.981981143901127 
            xmax = 29.630928496550258 
            text = "" 
        intervals [12]:
            xmin = 29.630928496550258 
            xmax = 30.609724550601616 
            text = "Ну так про що він?" 
        intervals [13]:
            xmin = 30.609724550601616 
            xmax = 34.60626460789534 
            text = "" 
        intervals [14]:
            xmin = 34.60626460789534 
            xmax = 36.607198238686685 
            text = "Ммм, це по-нашому. А, секс?" 
        intervals [15]:
            xmin = 36.607198238686685 
            xmax = 38.552288272672094 
            text = "" 
        intervals [16]:
            xmin = 38.552288272672094 
            xmax = 39.29992953905081 
            text = "*роз* Що?" 
        intervals [17]:
            xmin = 39.29992953905081 
            xmax = 48.93937092354238 
            text = "" 
        intervals [18]:
            xmin = 48.93937092354238 
            xmax = 51.90781375351828 
            text = "А я бачу! Такого дивитися не буду" 
        intervals [19]:
            xmin = 51.90781375351828 
            xmax = 52.246386067808146 
            text = "" 
        intervals [20]:
            xmin = 52.246386067808146 
            xmax = 53.10192966671375 
            text = "Це аморально!" 
        intervals [21]:
            xmin = 53.10192966671375 
            xmax = 54.98489287922481 
            text = "" 
        intervals [22]:
            xmin = 54.98489287922481 
            xmax = 56.99666189068832 
            text = "Ей, а не пішла б ти на магістратуру" 
        intervals [23]:
            xmin = 56.99666189068832 
            xmax = 57.15558080721327 
            text = "" 
        intervals [24]:
            xmin = 57.15558080721327 
            xmax = 57.36145303998423 
            text = "*сміх*" 
        intervals [25]:
            xmin = 57.36145303998423 
            xmax = 57.735400587799354 
            text = "" 
        intervals [26]:
            xmin = 57.735400587799354 
            xmax = 59.754393186377634 
            text = "кажуть стипендію підвищили.." 
        intervals [27]:
            xmin = 59.754393186377634 
            xmax = 61.62891404266052 
            text = "" 
        intervals [28]:
            xmin = 61.62891404266052 
            xmax = 62.58711145018178 
            text = "Я пропоную" 
        intervals [29]:
            xmin = 62.58711145018178 
            xmax = 64.32763919766285 
            text = "" 
        intervals [30]:
            xmin = 64.32763919766285 
            xmax = 65.6242730847641 
            text = "Вєра, дай *о* договорити" 
        intervals [31]:
            xmin = 65.6242730847641 
            xmax = 68.95982436119195 
            text = "" 
        intervals [32]:
            xmin = 68.95982436119195 
            xmax = 71.34404507003475 
            text = "Вєра, для цього є окремі сайти" 
        intervals [33]:
            xmin = 71.34404507003475 
            xmax = 71.69474672891893 
            text = "" 
        intervals [34]:
            xmin = 71.69474672891893 
            xmax = 74.16160172861296 
            text = "Давай щось хороше, от наприклад, «Опенгеймер»." 
        intervals [35]:
            xmin = 74.16160172861296 
            xmax = 77.25393310421946 
            text = "" 
        intervals [36]:
            xmin = 77.25393310421946 
            xmax = 80.80793796468643 
            text = "Так, зачепили! Давай, давай, це шедевр Нолана" 
        intervals [37]:
            xmin = 80.80793796468643 
            xmax = 81.22369154617893 
            text = "" 
        intervals [38]:
            xmin = 81.22369154617893 
            xmax = 82.86705761478915 
            text = "своє там ти глянеш патом" 
        intervals [39]:
            xmin = 82.86705761478915 
            xmax = 89.42520266634178 
            text = "" 
        intervals [40]:
            xmin = 89.42520266634178 
            xmax = 92.05931192306512 
            text = "Люда… Є додатки, *англ* you know?" 
        intervals [41]:
            xmin = 92.05931192306512 
            xmax = 94.36756605147662 
            text = "" 
        intervals [42]:
            xmin = 94.36756605147662 
            xmax = 96.12650951392318 
            text = "От і добре, пішла гуглити." 
        intervals [43]:
            xmin = 96.12650951392318 
            xmax = 97.49775457071723 
            text = "" 
