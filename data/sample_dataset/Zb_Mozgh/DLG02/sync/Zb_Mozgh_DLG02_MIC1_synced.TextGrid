    item [3]:
        class = "IntervalTier" 
        name = "SPK-B-text" 
        xmin = 0 
        xmax = 126.0705628347568 
        intervals: size = 30 
        intervals [1]:
            xmin = 0 
            xmax = 7.63177088378943 
            text = "" 
        intervals [2]:
            xmin = 7.63177088378943 
            xmax = 11.319614688074314 
            text = "*у* Мам, я не хочу їхати збирати картошку!" 
        intervals [3]:
            xmin = 11.319614688074314 
            xmax = 21.274252680741437 
            text = "" 
        intervals [4]:
            xmin = 21.274252680741437 
            xmax = 24.1866346034383 
            text = "Я не розумію, до чого тут взагалі ставок?!" 
        intervals [5]:
            xmin = 24.1866346034383 
            xmax = 24.582562834756803 
            text = "" 
        intervals [6]:
            xmin = 24.582562834756803 
            xmax = 29.75818045584296 
            text = "Він належить Ржищівській громаді. Розумієш, громаді,а не тобі чи бабулі…" 
        intervals [7]:
            xmin = 29.75818045584296 
            xmax = 38.792510430620155 
            text = "" 
        intervals [8]:
            xmin = 38.792510430620155 
            xmax = 42.23669312640765 
            text = "Мама! Не кажи так, мені образливо" 
        intervals [9]:
            xmin = 42.23669312640765 
            xmax = 46.244698251216825 
            text = "" 
        intervals [10]:
            xmin = 46.244698251216825 
            xmax = 52.05507128549169 
            text = "Обійдуться. Нікуди я не поїду! Буду в Києві, пити айслате з Аньою!" 
        intervals [11]:
            xmin = 52.05507128549169 
            xmax = 52.44522712169548 
            text = "" 
        intervals [12]:
            xmin = 52.44522712169548 
            xmax = 55.4825628347568 
            text = "І взагалі, у мене повно роботи і тут у Києві!" 
        intervals [13]:
            xmin = 55.4825628347568 
            xmax = 66.12470752586763 
            text = "" 
        intervals [14]:
            xmin = 66.12470752586763 
            xmax = 68.00825007502237 
            text = "Мама, так не можна!" 
        intervals [15]:
            xmin = 68.00825007502237 
            xmax = 70.10539023284416 
            text = "Я думала, ти мене любиш, а ти" 
        intervals [16]:
            xmin = 70.10539023284416 
            xmax = 92.53182465130966 
            text = "" 
        intervals [17]:
            xmin = 92.53182465130966 
            xmax = 95.14843763625466 
            text = "Мам, у нас посудомийка, і вабще…" 
        intervals [18]:
            xmin = 95.14843763625466 
            xmax = 101.68171994973038 
            text = "" 
        intervals [19]:
            xmin = 101.68171994973038 
            xmax = 103.953307926985 
            text = "А вона що, збирається *о* припертися??" 
        intervals [20]:
            xmin = 103.953307926985 
            xmax = 111.83504393270337 
            text = "" 
        intervals [21]:
            xmin = 111.83504393270337 
            xmax = 114.7253164403485 
            text = "Я пішла збирати речі, їду до бабусі на" 
        intervals [22]:
            xmin = 114.7253164403485 
            xmax = 115.06483547605123 
            text = "" 
        intervals [23]:
            xmin = 115.06483547605123 
            xmax = 117.1063204391375 
            text = "Наскільки тьотя Валя приїжджає?" 
        intervals [24]:
            xmin = 117.1063204391375 
            xmax = 117.55834955338727 
            text = "" 
        intervals [25]:
            xmin = 117.55834955338727 
            xmax = 118.48909108494489 
            text = "На місяць??" 
        intervals [26]:
            xmin = 118.48909108494489 
            xmax = 119.7280964461494 
            text = "" 
        intervals [27]:
            xmin = 119.7280964461494 
            xmax = 122.90227629198031 
            text = "Ладно, от і добре, поїду до бабулі на місяць." 
        intervals [28]:
            xmin = 122.90227629198031 
            xmax = 123.09983935292415 
            text = "" 
        intervals [29]:
            xmin = 123.09983935292415 
            xmax = 125.34327766719746 
            text = "Все одно давно не плавала у ставку." 
        intervals [30]:
            xmin = 125.34327766719746 
            xmax = 126.0705628347568 
            text = "" 
