item []: 
    item [1]:
        class = "IntervalTier" 
        name = "SPK-A-text" 
        xmin = 0 
        xmax = 126.0705628347568 
        intervals: size = 52 
        intervals [1]:
            xmin = 0 
            xmax = 10.972781758861807 
            text = "" 
        intervals [2]:
            xmin = 10.972781758861807 
            xmax = 12.83865511222023 
            text = "*у* Нася, тебе ніхт не питав!" 
        intervals [3]:
            xmin = 12.83865511222023 
            xmax = 13.15644238463523 
            text = "" 
        intervals [4]:
            xmin = 13.15644238463523 
            xmax = 15.004754577020869 
            text = "Любиш їсти смажену картоплю?" 
        intervals [5]:
            xmin = 15.004754577020869 
            xmax = 15.184756476991915 
            text = "" 
        intervals [6]:
            xmin = 15.184756476991915 
            xmax = 16.7725628347568 
            text = "А купатися у ставочку, да?" 
        intervals [7]:
            xmin = 16.7725628347568 
            xmax = 17.270411876298716 
            text = "" 
        intervals [8]:
            xmin = 17.270411876298716 
            xmax = 18.526034885852855 
            text = "Тоді збирай манатки," 
        intervals [9]:
            xmin = 18.526034885852855 
            xmax = 18.78067171995824 
            text = "" 
        intervals [10]:
            xmin = 18.78067171995824 
            xmax = 21.063622646420306 
            text = "і щоб у п'ятницю ввечері була у бабусі!" 
        intervals [11]:
            xmin = 21.063622646420306 
            xmax = 29.882490409863614 
            text = "" 
        intervals [12]:
            xmin = 29.882490409863614 
            xmax = 32.82398487280513 
            text = "А до того, що твоя прекрасна «ж» забула" 
        intervals [13]:
            xmin = 32.82398487280513 
            xmax = 33.0917925776401 
            text = "" 
        intervals [14]:
            xmin = 33.0917925776401 
            xmax = 33.78545843606511 
            text = "шо бабул" 
        intervals [15]:
            xmin = 33.78545843606511 
            xmax = 34.07960788235926 
            text = "" 
        intervals [16]:
            xmin = 34.07960788235926 
            xmax = 35.51080548773609 
            text = "теж треба помагать" 
        intervals [17]:
            xmin = 35.51080548773609 
            xmax = 35.85763841694861 
            text = "" 
        intervals [18]:
            xmin = 35.85763841694861 
            xmax = 39.389589903694855 
            text = "а не лише сидіти в інтернеті і набирати *о* кілаграми" 
        intervals [19]:
            xmin = 39.389589903694855 
            xmax = 42.23669312640765 
            text = "" 
        intervals [20]:
            xmin = 42.23669312640765 
            xmax = 42.9925628347568 
            text = "шо мама?" 
        intervals [21]:
            xmin = 42.9925628347568 
            xmax = 43.296948220139555 
            text = "" 
        intervals [22]:
            xmin = 43.296948220139555 
            xmax = 44.24525091266995 
            text = "Всі родичі будуть," 
        intervals [23]:
            xmin = 44.24525091266995 
            xmax = 44.602729700261406 
            text = "" 
        intervals [24]:
            xmin = 44.602729700261406 
            xmax = 46.244698251216825 
            text = "і двоюрідні будуть, а ти — нє?" 
        intervals [25]:
            xmin = 46.244698251216825 
            xmax = 55.4825628347568 
            text = "" 
        intervals [26]:
            xmin = 55.4825628347568 
            xmax = 57.3425628347568 
            text = "Повно роботи? Цікаво якої." 
        intervals [27]:
            xmin = 57.3425628347568 
            xmax = 57.62358082180809 
            text = "" 
        intervals [28]:
            xmin = 57.62358082180809 
            xmax = 61.99615995607689 
            text = "Пити айслате?? За які шиши?? Не забувай, хто кладе гроші на твою картку." 
        intervals [29]:
            xmin = 61.99615995607689 
            xmax = 62.396458356406676 
            text = "" 
        intervals [30]:
            xmin = 62.396458356406676 
            xmax = 66.056900615692 
            text = "І хто може її випадково заблокувати, і взагалі щось ти" 
        intervals [31]:
            xmin = 66.056900615692 
            xmax = 70.02045626639395 
            text = "" 
        intervals [32]:
            xmin = 70.02045626639395 
            xmax = 73.18146524149529 
            text = "Люблю свою Настуню, порядну, слухняну дитину," 
        intervals [33]:
            xmin = 73.18146524149529 
            xmax = 73.37463801219593 
            text = "" 
        intervals [34]:
            xmin = 73.37463801219593 
            xmax = 76.17564318735516 
            text = "а не оце підліткове, язва" 
        intervals [35]:
            xmin = 76.17564318735516 
            xmax = 76.55320814827004 
            text = "" 
        intervals [36]:
            xmin = 76.55320814827004 
            xmax = 79.05567358689194 
            text = "яка не хоче улюбленій «ба» допомогти." 
        intervals [37]:
            xmin = 79.05567358689194 
            xmax = 79.3278715819701 
            text = "" 
        intervals [38]:
            xmin = 79.3278715819701 
            xmax = 87.802948536629 
            text = "Ти знаєш, деякі підлітки у твоєму віці вже і підробляють. Он Ксюша, з третього під’їзду, займається з першокласниками, робить з ними уроки" 
        intervals [39]:
            xmin = 87.802948536629 
            xmax = 90.06700273030508 
            text = "і сама заробляє собі на айслате," 
        intervals [40]:
            xmin = 90.06700273030508 
            xmax = 90.67034158819443 
            text = "" 
        intervals [41]:
            xmin = 90.67034158819443 
            xmax = 92.44401884644574 
            text = "і посуд миє за собою" 
        intervals [42]:
            xmin = 92.44401884644574 
            xmax = 95.01672892895877 
            text = "" 
        intervals [43]:
            xmin = 95.01672892895877 
            xmax = 101.66325175479335 
            text = "І «вабще» — ти їдеш до бабусі збирати картоплю чи залишаєшся вдома прибирати квартиру до приїзду тітки?" 
        intervals [44]:
            xmin = 101.66325175479335 
            xmax = 104.02718070673313 
            text = "" 
        intervals [45]:
            xmin = 104.02718070673313 
            xmax = 106.84358043463013 
            text = "Вона твоя тітка, не смій так про неї говорити!" 
        intervals [46]:
            xmin = 106.84358043463013 
            xmax = 107.43037944022183 
            text = "" 
        intervals [47]:
            xmin = 107.43037944022183 
            xmax = 111.82811835960199 
            text = "І так, вона погостює з Машою, твоєю меншою двоюрідною сестрою, буде тобі" 
        intervals [48]:
            xmin = 111.82811835960199 
            xmax = 117.10990098365184 
            text = "" 
        intervals [49]:
            xmin = 117.10990098365184 
            xmax = 117.65703075868849 
            text = "На місяць." 
        intervals [50]:
            xmin = 117.65703075868849 
            xmax = 118.44728300246383 
            text = "" 
        intervals [51]:
            xmin = 118.44728300246383 
            xmax = 119.29021872915752 
            text = "На місяць." 
        intervals [52]:
            xmin = 119.29021872915752 
            xmax = 126.0705628347568 
            text = "" 
