    item [3]:
        class = "IntervalTier" 
        name = "SPK-B-text" 
        xmin = 0 
        xmax = 125.1645472154303 
        intervals: size = 30 
        intervals [1]:
            xmin = 0 
            xmax = 6.725755264462933 
            text = "" 
        intervals [2]:
            xmin = 6.725755264462933 
            xmax = 10.413599068747818 
            text = "*у* Мам, я не хочу їхати збирати картошку!" 
        intervals [3]:
            xmin = 10.413599068747818 
            xmax = 20.368237061414938 
            text = "" 
        intervals [4]:
            xmin = 20.368237061414938 
            xmax = 23.280618984111804 
            text = "Я не розумію, до чого тут взагалі ставок?!" 
        intervals [5]:
            xmin = 23.280618984111804 
            xmax = 23.676547215430304 
            text = "" 
        intervals [6]:
            xmin = 23.676547215430304 
            xmax = 28.852164836516465 
            text = "Він належить Ржищівській громаді. Розумієш, громаді,а не тобі чи бабулі…" 
        intervals [7]:
            xmin = 28.852164836516465 
            xmax = 37.88649481129366 
            text = "" 
        intervals [8]:
            xmin = 37.88649481129366 
            xmax = 41.330677507081155 
            text = "Мама! Не кажи так, мені образливо" 
        intervals [9]:
            xmin = 41.330677507081155 
            xmax = 45.33868263189033 
            text = "" 
        intervals [10]:
            xmin = 45.33868263189033 
            xmax = 51.1490556661652 
            text = "Обійдуться. Нікуди я не поїду! Буду в Києві, пити айслате з Аньою!" 
        intervals [11]:
            xmin = 51.1490556661652 
            xmax = 51.539211502368985 
            text = "" 
        intervals [12]:
            xmin = 51.539211502368985 
            xmax = 54.5765472154303 
            text = "І взагалі, у мене повно роботи і тут у Києві!" 
        intervals [13]:
            xmin = 54.5765472154303 
            xmax = 65.21869190654114 
            text = "" 
        intervals [14]:
            xmin = 65.21869190654114 
            xmax = 67.10223445569588 
            text = "Мама, так не можна!" 
        intervals [15]:
            xmin = 67.10223445569588 
            xmax = 69.19937461351766 
            text = "Я думала, ти мене любиш, а ти" 
        intervals [16]:
            xmin = 69.19937461351766 
            xmax = 91.62580903198317 
            text = "" 
        intervals [17]:
            xmin = 91.62580903198317 
            xmax = 94.24242201692816 
            text = "Мам, у нас посудомийка, і вабще…" 
        intervals [18]:
            xmin = 94.24242201692816 
            xmax = 100.77570433040388 
            text = "" 
        intervals [19]:
            xmin = 100.77570433040388 
            xmax = 103.04729230765851 
            text = "А вона що, збирається *о* припертися??" 
        intervals [20]:
            xmin = 103.04729230765851 
            xmax = 110.92902831337688 
            text = "" 
        intervals [21]:
            xmin = 110.92902831337688 
            xmax = 113.819300821022 
            text = "Я пішла збирати речі, їду до бабусі на" 
        intervals [22]:
            xmin = 113.819300821022 
            xmax = 114.15881985672473 
            text = "" 
        intervals [23]:
            xmin = 114.15881985672473 
            xmax = 116.20030481981101 
            text = "Наскільки тьотя Валя приїжджає?" 
        intervals [24]:
            xmin = 116.20030481981101 
            xmax = 116.65233393406078 
            text = "" 
        intervals [25]:
            xmin = 116.65233393406078 
            xmax = 117.58307546561839 
            text = "На місяць??" 
        intervals [26]:
            xmin = 117.58307546561839 
            xmax = 118.8220808268229 
            text = "" 
        intervals [27]:
            xmin = 118.8220808268229 
            xmax = 121.99626067265382 
            text = "Ладно, от і добре, поїду до бабулі на місяць." 
        intervals [28]:
            xmin = 121.99626067265382 
            xmax = 122.19382373359765 
            text = "" 
        intervals [29]:
            xmin = 122.19382373359765 
            xmax = 124.43726204787096 
            text = "Все одно давно не плавала у ставку." 
        intervals [30]:
            xmin = 124.43726204787096 
            xmax = 125.1645472154303 
            text = "" 
