item []: 
    item [1]:
        class = "IntervalTier" 
        name = "SPK-A-text" 
        xmin = 0 
        xmax = 125.1645472154303 
        intervals: size = 52 
        intervals [1]:
            xmin = 0 
            xmax = 10.06676613953531 
            text = "" 
        intervals [2]:
            xmin = 10.06676613953531 
            xmax = 11.932639492893735 
            text = "*у* Нася, тебе ніхт не питав!" 
        intervals [3]:
            xmin = 11.932639492893735 
            xmax = 12.250426765308733 
            text = "" 
        intervals [4]:
            xmin = 12.250426765308733 
            xmax = 14.098738957694371 
            text = "Любиш їсти смажену картоплю?" 
        intervals [5]:
            xmin = 14.098738957694371 
            xmax = 14.278740857665419 
            text = "" 
        intervals [6]:
            xmin = 14.278740857665419 
            xmax = 15.866547215430304 
            text = "А купатися у ставочку, да?" 
        intervals [7]:
            xmin = 15.866547215430304 
            xmax = 16.36439625697222 
            text = "" 
        intervals [8]:
            xmin = 16.36439625697222 
            xmax = 17.620019266526356 
            text = "Тоді збирай манатки," 
        intervals [9]:
            xmin = 17.620019266526356 
            xmax = 17.87465610063174 
            text = "" 
        intervals [10]:
            xmin = 17.87465610063174 
            xmax = 20.15760702709381 
            text = "і щоб у п'ятницю ввечері була у бабусі!" 
        intervals [11]:
            xmin = 20.15760702709381 
            xmax = 28.976474790537118 
            text = "" 
        intervals [12]:
            xmin = 28.976474790537118 
            xmax = 31.91796925347863 
            text = "А до того, що твоя прекрасна «ж» забула" 
        intervals [13]:
            xmin = 31.91796925347863 
            xmax = 32.1857769583136 
            text = "" 
        intervals [14]:
            xmin = 32.1857769583136 
            xmax = 32.87944281673862 
            text = "шо бабул" 
        intervals [15]:
            xmin = 32.87944281673862 
            xmax = 33.173592263032766 
            text = "" 
        intervals [16]:
            xmin = 33.173592263032766 
            xmax = 34.6047898684096 
            text = "теж треба помагать" 
        intervals [17]:
            xmin = 34.6047898684096 
            xmax = 34.951622797622115 
            text = "" 
        intervals [18]:
            xmin = 34.951622797622115 
            xmax = 38.48357428436836 
            text = "а не лише сидіти в інтернеті і набирати *о* кілаграми" 
        intervals [19]:
            xmin = 38.48357428436836 
            xmax = 41.330677507081155 
            text = "" 
        intervals [20]:
            xmin = 41.330677507081155 
            xmax = 42.0865472154303 
            text = "шо мама?" 
        intervals [21]:
            xmin = 42.0865472154303 
            xmax = 42.39093260081306 
            text = "" 
        intervals [22]:
            xmin = 42.39093260081306 
            xmax = 43.33923529334346 
            text = "Всі родичі будуть," 
        intervals [23]:
            xmin = 43.33923529334346 
            xmax = 43.69671408093491 
            text = "" 
        intervals [24]:
            xmin = 43.69671408093491 
            xmax = 45.33868263189033 
            text = "і двоюрідні будуть, а ти — нє?" 
        intervals [25]:
            xmin = 45.33868263189033 
            xmax = 54.5765472154303 
            text = "" 
        intervals [26]:
            xmin = 54.5765472154303 
            xmax = 56.4365472154303 
            text = "Повно роботи? Цікаво якої." 
        intervals [27]:
            xmin = 56.4365472154303 
            xmax = 56.717565202481595 
            text = "" 
        intervals [28]:
            xmin = 56.717565202481595 
            xmax = 61.09014433675039 
            text = "Пити айслате?? За які шиши?? Не забувай, хто кладе гроші на твою картку." 
        intervals [29]:
            xmin = 61.09014433675039 
            xmax = 61.49044273708018 
            text = "" 
        intervals [30]:
            xmin = 61.49044273708018 
            xmax = 65.1508849963655 
            text = "І хто може її випадково заблокувати, і взагалі щось ти" 
        intervals [31]:
            xmin = 65.1508849963655 
            xmax = 69.11444064706745 
            text = "" 
        intervals [32]:
            xmin = 69.11444064706745 
            xmax = 72.2754496221688 
            text = "Люблю свою Настуню, порядну, слухняну дитину," 
        intervals [33]:
            xmin = 72.2754496221688 
            xmax = 72.46862239286943 
            text = "" 
        intervals [34]:
            xmin = 72.46862239286943 
            xmax = 75.26962756802867 
            text = "а не оце підліткове, язва" 
        intervals [35]:
            xmin = 75.26962756802867 
            xmax = 75.64719252894355 
            text = "" 
        intervals [36]:
            xmin = 75.64719252894355 
            xmax = 78.14965796756545 
            text = "яка не хоче улюбленій «ба» допомогти." 
        intervals [37]:
            xmin = 78.14965796756545 
            xmax = 78.4218559626436 
            text = "" 
        intervals [38]:
            xmin = 78.4218559626436 
            xmax = 86.89693291730251 
            text = "Ти знаєш, деякі підлітки у твоєму віці вже і підробляють. Он Ксюша, з третього під’їзду, займається з першокласниками, робить з ними уроки" 
        intervals [39]:
            xmin = 86.89693291730251 
            xmax = 89.16098711097858 
            text = "і сама заробляє собі на айслате," 
        intervals [40]:
            xmin = 89.16098711097858 
            xmax = 89.76432596886794 
            text = "" 
        intervals [41]:
            xmin = 89.76432596886794 
            xmax = 91.53800322711925 
            text = "і посуд миє за собою" 
        intervals [42]:
            xmin = 91.53800322711925 
            xmax = 94.11071330963227 
            text = "" 
        intervals [43]:
            xmin = 94.11071330963227 
            xmax = 100.75723613546685 
            text = "І «вабще» — ти їдеш до бабусі збирати картоплю чи залишаєшся вдома прибирати квартиру до приїзду тітки?" 
        intervals [44]:
            xmin = 100.75723613546685 
            xmax = 103.12116508740664 
            text = "" 
        intervals [45]:
            xmin = 103.12116508740664 
            xmax = 105.93756481530363 
            text = "Вона твоя тітка, не смій так про неї говорити!" 
        intervals [46]:
            xmin = 105.93756481530363 
            xmax = 106.52436382089533 
            text = "" 
        intervals [47]:
            xmin = 106.52436382089533 
            xmax = 110.92210274027549 
            text = "І так, вона погостює з Машою, твоєю меншою двоюрідною сестрою, буде тобі" 
        intervals [48]:
            xmin = 110.92210274027549 
            xmax = 116.20388536432534 
            text = "" 
        intervals [49]:
            xmin = 116.20388536432534 
            xmax = 116.751015139362 
            text = "На місяць." 
        intervals [50]:
            xmin = 116.751015139362 
            xmax = 117.54126738313734 
            text = "" 
        intervals [51]:
            xmin = 117.54126738313734 
            xmax = 118.38420310983102 
            text = "На місяць." 
        intervals [52]:
            xmin = 118.38420310983102 
            xmax = 125.1645472154303 
            text = "" 
