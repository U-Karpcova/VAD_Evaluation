item []: 
    item [1]:
        class = "IntervalTier" 
        name = "SPK-A-text" 
        xmin = 0 
        xmax = 126.3900181650872 
        intervals: size = 35 
        intervals [1]:
            xmin = 0 
            xmax = 6.876026983423353 
            text = "" 
        intervals [2]:
            xmin = 6.876026983423353 
            xmax = 10.010398012648256 
            text = "*у* Ліно, а який у тебе улюблений герой з Марвел?" 
        intervals [3]:
            xmin = 10.010398012648256 
            xmax = 13.611457903185325 
            text = "" 
        intervals [4]:
            xmin = 13.611457903185325 
            xmax = 15.035229697137053 
            text = "Цей дебіл і злодій??" 
        intervals [5]:
            xmin = 15.035229697137053 
            xmax = 15.199901739649324 
            text = "" 
        intervals [6]:
            xmin = 15.199901739649324 
            xmax = 15.530860171306612 
            text = "*о* Я" 
        intervals [7]:
            xmin = 15.530860171306612 
            xmax = 23.89341061190931 
            text = "" 
        intervals [8]:
            xmin = 23.89341061190931 
            xmax = 25.83308819638563 
            text = "Не треба сюди прив'язувати Наташу!" 
        intervals [9]:
            xmin = 25.83308819638563 
            xmax = 26.08352609165278 
            text = "" 
        intervals [10]:
            xmin = 26.08352609165278 
            xmax = 28.687782368498183 
            text = "Вона, по-перше, розумна, сильна, вірна" 
        intervals [11]:
            xmin = 28.687782368498183 
            xmax = 28.857087544898324 
            text = "" 
        intervals [12]:
            xmin = 28.857087544898324 
            xmax = 32.593224541858376 
            text = "і рятувала не раз дупу всіх ваших великих багів" 
        intervals [13]:
            xmin = 32.593224541858376 
            xmax = 32.92372083719709 
            text = "" 
        intervals [14]:
            xmin = 32.92372083719709 
            xmax = 38.89545276521197 
            text = "і супергероїв, не маючи жодних надприродних здібностей, окрім мозку і  витримки" 
        intervals [15]:
            xmin = 38.89545276521197 
            xmax = 43.29522683518788 
            text = "" 
        intervals [16]:
            xmin = 43.29522683518788 
            xmax = 46.81403799589357 
            text = "Так! Їй прийшлося! Вона хотіла вирватися! Вона…" 
        intervals [17]:
            xmin = 46.81403799589357 
            xmax = 54.21990759223887 
            text = "" 
        intervals [18]:
            xmin = 54.21990759223887 
            xmax = 60.021414217760785 
            text = "Хочу тобі нагадати, що Локі власного **обм брата ледь не вбив, двічі навіть, да?" 
        intervals [19]:
            xmin = 60.021414217760785 
            xmax = 60.9513967639938 
            text = "" 
        intervals [20]:
            xmin = 60.9513967639938 
            xmax = 67.78471497056493 
            text = "Матір не поважав, узурпував трон… Землю ледь не заграбастав — нічого? Нє? Раганосєц" 
        intervals [21]:
            xmin = 67.78471497056493 
            xmax = 77.54584402313252 
            text = "" 
        intervals [22]:
            xmin = 77.54584402313252 
            xmax = 83.55419966844025 
            text = "Да, да я нічого не розумію. Наташа померла заради Землі, розумієш? Пожертвувала своїм життям, а він шо?" 
        intervals [23]:
            xmin = 83.55419966844025 
            xmax = 90.31667290985412 
            text = "" 
        intervals [24]:
            xmin = 90.31667290985412 
            xmax = 91.66605857422154 
            text = "Да, да, да. Вся ця хєрня" 
        intervals [25]:
            xmin = 91.66605857422154 
            xmax = 92.10716922856129 
            text = "" 
        intervals [26]:
            xmin = 92.10716922856129 
            xmax = 93.84956803052172 
            text = "Просто скажи: гарний там актор." 
        intervals [27]:
            xmin = 93.84956803052172 
            xmax = 106.09531492632445 
            text = "" 
        intervals [28]:
            xmin = 106.09531492632445 
            xmax = 109.1128770973174 
            text = "Так, *пскл* ненада чіпати святу жінку!" 
        intervals [29]:
            xmin = 109.1128770973174 
            xmax = 109.56119395109263 
            text = "" 
        intervals [30]:
            xmin = 109.56119395109263 
            xmax = 116.5161880516554 
            text = "Вона багато чого добилася у своєму житті і дуже розумна. І взагалі, у неї хороша косметична компанія." 
        intervals [31]:
            xmin = 116.5161880516554 
            xmax = 116.83612907450807 
            text = "" 
        intervals [32]:
            xmin = 116.83612907450807 
            xmax = 119.58113724295971 
            text = "А у твого Гіддлстона тільки дупа гарна." 
        intervals [33]:
            xmin = 119.58113724295971 
            xmax = 119.85369124550101 
            text = "" 
        intervals [34]:
            xmin = 119.85369124550101 
            xmax = 125.38264386848164 
            text = "Ну і стосунки з Тейлор Свіфт можна теж зарахувати як плюс — подякуємо йому за «Midnight Rain»." 
        intervals [35]:
            xmin = 125.38264386848164 
            xmax = 126.3900181650872 
            text = "" 
