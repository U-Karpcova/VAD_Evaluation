    item [3]:
        class = "IntervalTier" 
        name = "SPK-B-text" 
        xmin = 0 
        xmax = 126.3900181650872 
        intervals: size = 23 
        intervals [1]:
            xmin = 0 
            xmax = 10.010398012648256 
            text = "" 
        intervals [2]:
            xmin = 10.010398012648256 
            xmax = 12.324610690708948 
            text = "*у* Юля, я ж тобі вже сто раз казала" 
        intervals [3]:
            xmin = 12.324610690708948 
            xmax = 13.696143386377758 
            text = "Мені подобається Локі" 
        intervals [4]:
            xmin = 13.696143386377758 
            xmax = 15.32644466940064 
            text = "" 
        intervals [5]:
            xmin = 15.32644466940064 
            xmax = 16.455596965643156 
            text = "Він не дебіл" 
        intervals [6]:
            xmin = 16.455596965643156 
            xmax = 16.83630998460607 
            text = "" 
        intervals [7]:
            xmin = 16.83630998460607 
            xmax = 20.009617299908307 
            text = "У нього складне життя було! І взагалі, хто б казав…" 
        intervals [8]:
            xmin = 20.009617299908307 
            xmax = 20.577875029867787 
            text = "" 
        intervals [9]:
            xmin = 20.577875029867787 
            xmax = 23.87880950463031 
            text = "Наташа Романова — колишня КГБшниця!" 
        intervals [10]:
            xmin = 23.87880950463031 
            xmax = 40.1639567879922 
            text = "" 
        intervals [11]:
            xmin = 40.1639567879922 
            xmax = 43.28881169735472 
            text = "Тобі нагадати, що вона підірвала дитину?" 
        intervals [12]:
            xmin = 43.28881169735472 
            xmax = 46.731363564338096 
            text = "" 
        intervals [13]:
            xmin = 46.731363564338096 
            xmax = 54.37927868348849 
            text = "Вона просто підірвала дитину разом з її батьком, залишила сестру і упіздючила в своє США." 
        intervals [14]:
            xmin = 54.37927868348849 
            xmax = 67.84068588180108 
            text = "" 
        intervals [15]:
            xmin = 67.84068588180108 
            xmax = 69.12314980447309 
            text = "Корона така!" 
        intervals [16]:
            xmin = 69.12314980447309 
            xmax = 69.44679583986247 
            text = "" 
        intervals [17]:
            xmin = 69.44679583986247 
            xmax = 73.52537180646262 
            text = "Ну і шо, шо узурпував? Ну, він потім виправився" 
        intervals [18]:
            xmin = 73.52537180646262 
            xmax = 77.76548946938502 
            text = "Ну, ну, там такий керектер-девелопмент… Ну ти нічого не *о* розумієш." 
        intervals [19]:
            xmin = 77.76548946938502 
            xmax = 84.21778227844436 
            text = "" 
        intervals [20]:
            xmin = 84.21778227844436 
            xmax = 90.3307791925849 
            text = "Поставив на місце світовий порядок! Він він врятував всесвіт, він пізнав себе" 
        intervals [21]:
            xmin = 90.3307791925849 
            xmax = 94.28635055606252 
            text = "" 
        intervals [22]:
            xmin = 94.28635055606252 
            xmax = 106.2689925963603 
            text = "Ну, ну, да! Ну, Том Хіддлстоун прекрасно зіграв Локі! Ну, і да він гарний! Але це не основне. Ти ж свою Наташу Романофф любиш не тільки за Скарлетт Йоханссон?" 
        intervals [23]:
            xmin = 106.2689925963603 
            xmax = 126.3900181650872 
            text = "" 
